# Magento 2 .gitignore

# Arquivos de configuração sensíveis
/app/etc/env.php
/app/etc/config.php
/app/etc/*.bak
/app/etc/*.bak*
/app/etc/*.bak-*
auth.json

# Arquivos de ambiente (NUNCA comite segredos)
.env
.env.*
!.env.example

# Cache e arquivos temporários
/var/*
!/var/.htaccess
/pub/media/*
!/pub/media/.htaccess
!/pub/media/customer
!/pub/media/downloadable
!/pub/media/import
!/pub/media/theme_customization
/pub/static/*
!/pub/static/.htaccess

# Arquivos gerados
/generated/*
!/generated/.htaccess

# Dependências (gerenciadas pelo Composer)
/vendor/

# Logs
*.log
nohup.out

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
__MACOSX/
**/__MACOSX/
Thumbs.db

# Node modules (se usar frontend build)
node_modules/

# Backup files
*.bak
*.backup
*.sql
*.gz
*.zip
_backups/
artifacts/

# Scripts utilitários e documentos locais
scripts/
docs/
relatorios/
analise_visual/
biblioteca/
_csv/

# Diretórios temporários
pub/media/import/
qwen-code/
opensearch/
dummy-opensearch/

# Configs de ferramentas AI
.agent/
.anima/
.claude/
.codacy/
.kombai/
.trae/

# Ignore vscode AI rules
.github/instructions/codacy.instructions.md

# Redis
dump.rdb

# MCP config with secrets
.vscode/mcp.json

# MCP debug tools
.mcp-debug-tools/

# PHPUnit cache
.phpunit.cache/
**/.phpunit.cache/
