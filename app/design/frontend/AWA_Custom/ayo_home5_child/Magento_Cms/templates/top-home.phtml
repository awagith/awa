/** @var \Magento\Framework\View\Element\Template $this */
$layout = $this->getLayout();

$renderCmsBlock = static function (string $blockId) use ($layout): string {
	/** @var \Magento\Cms\Block\Block|null $cmsBlock */
	$cmsBlock = $layout->createBlock('Magento\Cms\Block\Block');
	if (!$cmsBlock) {
		return '';
	}

	$cmsBlock->setBlockId($blockId);
	return trim((string)$cmsBlock->toHtml());
};

$renderTemplate = static function (string $template) use ($layout): string {
	/** @var \Magento\Framework\View\Element\Template|null $templateBlock */
	$templateBlock = $layout->createBlock('Magento\Framework\View\Element\Template');
	if (!$templateBlock) {
		return '';
	}

	return trim((string)$templateBlock->setTemplate($template)->toHtml());
};

