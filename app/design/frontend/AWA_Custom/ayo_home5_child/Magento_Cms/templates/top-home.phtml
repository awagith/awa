<?php
/** @var \Magento\Framework\View\Element\Template $this */
$layout = $this->getLayout();

$renderCmsBlock = static function (string $blockId) use ($layout): string {
    /** @var \Magento\Cms\Block\Block|null $cmsBlock */
    $cmsBlock = $layout->createBlock('Magento\Cms\Block\Block');
    if (!$cmsBlock) {
        return '';
    }

    $cmsBlock->setBlockId($blockId);

    return trim((string) $cmsBlock->toHtml());
};

$renderTemplate = static function (string $template) use ($layout): string {
    /** @var \Magento\Framework\View\Element\Template|null $templateBlock */
    $templateBlock = $layout->createBlock('Magento\Framework\View\Element\Template');
    if (!$templateBlock) {
        return '';
    }

    return trim((string) $templateBlock->setTemplate($template)->toHtml());
};

$renderHomeShelf = static function (array $shelfConfig) use ($layout): string {
    $type = (string) ($shelfConfig['type'] ?? '');
    $blockData = $shelfConfig['block_data'] ?? [];
    $blockClass = '';
    $template = null;

    switch ($type) {
        case 'bestseller':
            $blockClass = 'GrupoAwamotos\\Theme\\Block\\Widget\\HomeBestseller';
            $template = 'GrupoAwamotos_Theme::home/product-shelf.phtml';
            break;

        case 'newproduct':
            $blockClass = 'GrupoAwamotos\\Theme\\Block\\Widget\\HomeNewproduct';
            $template = 'GrupoAwamotos_Theme::home/product-shelf.phtml';
            break;

        case 'category':
            $blockClass = 'Rokanthemes\\Categorytab\\Block\\CateWidget';
            $template = isset($blockData['template']) ? (string) $blockData['template'] : 'GrupoAwamotos_Theme::home/category-shelf.phtml';
            unset($blockData['template']);
            break;

        default:
            return '';
    }

    /** @var \Magento\Framework\View\Element\Template|null $block */
    $block = $layout->createBlock($blockClass);
    if (!$block) {
        return '';
    }

    $block->addData($blockData);
    if ($template !== null) {
        $block->setTemplate($template);
    }

    $html = trim((string) $block->toHtml());
    if ($html === '' || strpos($html, 'There are no products matching the selection.') !== false) {
        return '';
    }

    return $html;
};

