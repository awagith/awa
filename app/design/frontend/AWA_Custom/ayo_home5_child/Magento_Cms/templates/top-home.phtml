$renderedShelves = [];
$renderedShelvesByKey = [];

if ($categoryCarouselVm) {
    foreach ($categoryCarouselCategories as &$cat) {
        $catData = $categoryCarouselVm->getCategoryData((int) $cat['id']);
        $cat['url'] = $catData['url'] !== '' ? $catData['url'] : '#';
        $cat['name'] = $catData['name'] !== '' ? $catData['name'] : $cat['name'];
        $cat['count'] = $catData['count'];
    }
    unset($cat);
}

foreach ($homeShelves as $shelfConfig) {
    $shelfHtml = $renderHomeShelf($shelfConfig);
    if ($shelfHtml === '') {
        continue;
    }

    $renderedShelf = $shelfConfig + ['html' => $shelfHtml];
    $renderedShelves[] = $renderedShelf;
    $renderedShelvesByKey[(string) ($shelfConfig['key'] ?? '')] = $renderedShelf;
}

if ($benefitsHtml !== '' && strpos($benefitsHtml, 'velaServicesInner--home5') === false) {
    $patchedBenefitsHtml = preg_replace(
        '/class=(["\'])velaServicesInner\b([^"\']*)\1/',
        'class=$1velaServicesInner$2 velaServicesInner--home5$1',
        $benefitsHtml,
        1
    );
    if (is_string($patchedBenefitsHtml) && $patchedBenefitsHtml !== '') {
        $benefitsHtml = $patchedBenefitsHtml;
    }
}
