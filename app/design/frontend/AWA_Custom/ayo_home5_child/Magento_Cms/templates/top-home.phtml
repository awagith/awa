// Build category URLs
/** @var \Magento\Catalog\Model\CategoryFactory|null */
try {
	$categoryFactory = \Magento\Framework\App\ObjectManager::getInstance()->get('Magento\Catalog\Model\CategoryFactory');
	foreach ($categoryCarouselCategories as &$cat) {
		$catModel = $categoryFactory->create()->load($cat['id']);
		if ($catModel->getId()) {
			$cat['url'] = $catModel->getUrl();
			$cat['name'] = $catModel->getName(); // Use actual DB name
		} else {
			$cat['url'] = '#';
		}
	}
	unset($cat);
} catch (\Exception $e) {
	// Fallback: keep default names/urls
}



