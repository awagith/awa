<?php
/**
 * Header search form override (Magento_Search) - AWA Home5 child
 *
 * @var \Magento\Framework\View\Element\Template $block
 */
declare(strict_types=1);

// @codingStandardsIgnoreFile
/** @var \Magento\Search\Helper\Data $searchHelper */
$searchHelper = $this->helper('Magento\Search\Helper\Data');
?>
<div class="block block-search"
     role="search"
     aria-label="<?= $block->escapeHtmlAttr(__('Busca de produtos')) ?>"
     data-awa-component="search-autocomplete"
     data-awa-variant="awa-search-compat">
    <div class="block-content">
        <form class="form minisearch search-content"
              id="search_mini_form"
              data-awa-search-form="true"
              action="<?= $block->escapeUrl($searchHelper->getResultUrl()) ?>"
              method="get">
            <div class="field search">
                <label class="label" for="search" id="awa-search-label" data-role="minisearch-label">
                    <span><?= $block->escapeHtml(__('Buscar')) ?></span>
                </label>
                <div class="control" data-awa-search-control="true">
                    <input id="search"
                           data-awa-search-input="true"
                           type="search"
                           name="<?= $block->escapeHtmlAttr($searchHelper->getQueryParamName()) ?>"
                           value="<?= $block->escapeHtmlAttr($searchHelper->getEscapedQueryText()) ?>"
                           placeholder="<?= $block->escapeHtmlAttr(__('Busca por SKU, EAN ou Nome...')) ?>"
                           class="input-text"
                           minlength="2"
                           maxlength="<?= (int) $searchHelper->getMaxQueryLength() ?>"
                           role="combobox"
                           aria-labelledby="awa-search-label"
                           aria-label="<?= $block->escapeHtmlAttr(__('Buscar')) ?>"
                           aria-autocomplete="both"
                           aria-expanded="false"
                           aria-haspopup="listbox"
                           aria-controls="search_autocomplete"
                           autocomplete="off"
                           autocapitalize="off"
                           autocorrect="off"
                           spellcheck="false" />
                    <?= /* @noEscape */ $block->getChildHtml() ?>
                </div>
            </div>
            <div class="actions" data-awa-search-actions="true">
                <button type="submit"
                        title="<?= $block->escapeHtmlAttr(__('Buscar')) ?>"
                        aria-label="<?= $block->escapeHtmlAttr(__('Buscar produtos')) ?>"
                        class="action search"
                        data-awa-search-submit="true">
                    <span><?= $block->escapeHtml(__('Buscar')) ?></span>
                </button>
            </div>
        </form>
    </div>
</div>
