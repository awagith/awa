$creditPercentage = $block->getUsagePercent();
$progressBarColor = $creditPercentage > 80 ? '#b73337' : '#10b981';
$hasCreditEnabled = $creditTotal > 0;
?>
<?php if ($hasCreditEnabled): ?>
<div class="awa-b2b-erp-status-card" style="margin-bottom: 24px;">
    <div class="awa-b2b-credit-header" style="margin-bottom: 12px;">
        <h3 style="margin: 0; font-size: 18px; color: #1e293b;">
            <?= $block->escapeHtml(__("Limite de Crédito B2B")) ?>
        </h3>
    </div>
    <div class="awa-b2b-credit-body" style="padding: 16px; background: #fff; border: 1px solid #e5e7eb; border-radius: 8px;">
        <div style="display: flex; justify-content: space-between; margin-bottom: 8px;">
            <span>
                <strong><?= $block->escapeHtml(__("Utilizado:")) ?></strong>
                <?= /* @noEscape */ $block->formatPrice($creditUsed) ?>
            </span>
            <span>
                <strong><?= $block->escapeHtml(__("Disponível:")) ?></strong>
                <?= /* @noEscape */ $block->formatPrice($creditAvailable) ?>
            </span>
        </div>
        <div class="awa-b2b-progress-bg"
             style="width: 100%; height: 16px; background: #f1f5f9; border-radius: 99px; overflow: hidden;"
