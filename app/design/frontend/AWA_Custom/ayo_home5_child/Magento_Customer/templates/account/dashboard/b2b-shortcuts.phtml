// Real credit data (array with keys: limit, used, available)
$creditData      = $block->getCreditLimit();
$creditTotal     = (float) ($creditData['limit'] ?? 0);
$creditUsed      = (float) ($creditData['used'] ?? 0);
$creditAvailable = (float) ($creditData['available'] ?? 0);
$creditPct       = $creditTotal > 0 ? min(100, ($creditUsed / $creditTotal) * 100) : 0;
$barColor        = $creditPct > 80 ? '#b73337' : '#10b981';
$hasCreditData   = $creditTotal > 0;
$isApproved      = $block->isApproved();
?>
<?php if (!$isApproved): ?>
<div class="message warning awa-b2b-approval-notice" role="alert" style="margin-bottom:16px;padding:14px 18px;background:#fefce8;border:1px solid #fde047;border-radius:8px;display:flex;align-items:flex-start;gap:12px;">
