<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <remove src="css/awa-plp-final-polish.css"/>
        <css src="css/layers/pages/plp-search.css"/>
        <css src="GrupoAwamotos_Fitment::css/fitment-bar.css"/>
    </head>
    <body>
        <!-- Fitment bar: above product list, inside columns.top container -->
        <referenceContainer name="columns.top">
            <block class="GrupoAwamotos\Fitment\Block\FitmentBar"
                   name="awa.fitment.bar"
                   template="GrupoAwamotos_Fitment::fitment-bar.phtml"
                   before="category.view.container"/>
        </referenceContainer>
    </body>
</page>
