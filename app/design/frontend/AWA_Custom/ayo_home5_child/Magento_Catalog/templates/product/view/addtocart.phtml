<?php if ($_product->isSaleable()) :?>
<div class="box-tocart">
    <div class="fieldset">
        <?php if ($block->shouldRenderQuantity()) :?>
        <div class="awa-catalog-qty-box field qty">
            <label class="label awa-sr-only" for="qty"><span><?= $block->escapeHtml(__('Qty')) ?></span></label>
            <div class="control awa-stepper-control" data-awa-role="qty-control">
                <button type="button"
                        class="awa-qty-btn awa-qty-minus"
                        data-awa-role="qty-trigger"
                        data-awa-direction="decrement"
                        aria-controls="qty"
                        aria-label="<?= $block->escapeHtmlAttr(__('Diminuir quantidade')) ?>">
                    <span aria-hidden="true">-</span>
                </button>
                <input type="number"
                       name="qty"
                       id="qty"
                       min="1"
                       step="1"
                       inputmode="numeric"
                       pattern="[0-9]*"
