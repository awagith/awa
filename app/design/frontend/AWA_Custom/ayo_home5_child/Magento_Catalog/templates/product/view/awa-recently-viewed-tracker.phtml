<?php
/**
 * AWA B2B — Recently Viewed Tracker (PDP)
 * Registra o produto atual no localStorage e renderiza o widget abaixo da galeria.
 *
 * @var \Magento\Catalog\Block\Product\View $block
 * @var \Magento\Framework\Escaper $escaper
 */
declare(strict_types=1);

$product = $block->getProduct();
if (!$product || !$product->getId()) {
    return;
}

$productId   = (int) $product->getId();
$productName = $block->escapeHtml((string) $product->getName());
$productUrl  = $block->escapeUrl((string) $product->getProductUrl());
$productSku  = $block->escapeHtml((string) $product->getSku());

$imageHelper = $block->getData('image_helper');
$imageUrl = '';
if ($imageHelper) {
    try {
        $imageUrl = $block->escapeUrl(
            $imageHelper->init($product, 'product_thumbnail_image')->getUrl()
        );
    } catch (\Exception $e) {
        $imageUrl = '';
    }
}

$priceHelper = $block->getData('price_helper');
$formattedPrice = '';
if ($priceHelper) {
    try {
        $finalPrice = $product->getFinalPrice();
        $formattedPrice = $block->escapeHtml(
            $priceHelper->currency((float) $finalPrice, true, false)
        );
    } catch (\Exception $e) {
        $formattedPrice = '';
    }
}
?>
<?php if ($productId): ?>
<script type="text/x-magento-init">
{
    "*": {
        "AWA_Custom/js/recently-viewed": {
            "action": "track",
            "product": {
                "id": <?= (int) $productId ?>,
                "name": <?= /* @noEscape */ json_encode($productName) ?>,
                "url": <?= /* @noEscape */ json_encode($productUrl) ?>,
                "imageUrl": <?= /* @noEscape */ json_encode($imageUrl) ?>,
                "price": <?= /* @noEscape */ json_encode($formattedPrice) ?>,
                "sku": <?= /* @noEscape */ json_encode($productSku) ?>
            }
        }
    }
}
</script>

<div id="awa-recently-viewed-widget"
     class="awa-recently-viewed"
     data-product-id="<?= (int) $productId ?>"
     aria-label="<?= $block->escapeHtmlAttr(__('Vistos recentemente')) ?>"
     style="display:none">
    <div class="awa-recently-viewed__header">
        <h3 class="awa-recently-viewed__title"><?= $block->escapeHtml(__('Vistos recentemente')) ?></h3>
    </div>
    <div class="awa-recently-viewed__grid" id="awa-rv-grid"></div>
</div>

<script type="text/x-magento-init">
{
    "#awa-recently-viewed-widget": {
        "AWA_Custom/js/recently-viewed": {
            "action": "widget",
            "excludeId": <?= (int) $productId ?>,
            "maxItems": 4
        }
    }
}
</script>
<?php endif; ?>
