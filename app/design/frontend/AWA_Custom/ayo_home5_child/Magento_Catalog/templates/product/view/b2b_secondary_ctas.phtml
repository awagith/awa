<?php
/**
 * B2B Secondary CTAs — PDP actions for B2B customers
 * Routes: shoppinglist/additem (POST), quote (GET), whatsapp (external)
 */
/** @var $block \Magento\Catalog\Block\Product\View */
$_product = $block->getProduct();
$addToListUrl = $block->getUrl('b2b/shoppinglist/additem');
$quoteUrl = $block->getUrl('b2b/quote', ['product_id' => $_product->getId()]);
$whatsappMsg = rawurlencode(sprintf(
    "Olá, gostaria de solicitar cotação para lote do produto: %s (SKU: %s) — %s",
    $_product->getName(),
    $_product->getSku(),
    $block->getUrl($_product->getUrlKey() . '.html')
));
$whatsappUrl = 'https://wa.me/5516997367588?text=' . $whatsappMsg;
?>
<div class="awa-b2b-secondary-ctas" data-awa-component="awa-secondary-ctas">
    <form action="<?= $block->escapeUrl($addToListUrl) ?>" method="post" id="b2b-add-to-list-form" class="awa-b2b-secondary-ctas__form">
        <?= /* @noEscape */ $block->getBlockHtml('formkey') ?>
        <input type="hidden" name="product_id" value="<?= (int) $_product->getId() ?>"/>
        <button type="submit"
                class="action secondary b2b-cta-list awa-b2b-secondary-ctas__button awa-b2b-secondary-ctas__button--primary"
                aria-label="<?= $block->escapeHtmlAttr(__('Adicionar %1 à Lista de Reposição', $_product->getName())) ?>">
            <svg class="awa-b2b-secondary-ctas__icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
            <span><?= $block->escapeHtml(__('Adicionar à Lista de Reposição')) ?></span>
        </button>
    </form>

    <div class="awa-b2b-secondary-ctas__row">
        <a href="<?= $block->escapeUrl($whatsappUrl) ?>"
           class="action secondary b2b-cta-quote awa-b2b-secondary-ctas__button"
           target="_blank"
           rel="noopener noreferrer"
           aria-label="<?= $block->escapeHtmlAttr(__('Abrir WhatsApp para cotação do produto %1', $_product->getName())) ?>">
            <svg class="awa-b2b-secondary-ctas__icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line></svg>
            <span><?= $block->escapeHtml(__('Cotação para Lote')) ?></span>
        </a>
        <a href="<?= $block->escapeUrl($quoteUrl) ?>"
           class="action secondary b2b-cta-quotes awa-b2b-secondary-ctas__button"
           aria-label="<?= $block->escapeHtmlAttr(__('Abrir Minhas Cotações')) ?>">
            <svg class="awa-b2b-secondary-ctas__icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
            <span><?= $block->escapeHtml(__('Minhas Cotações')) ?></span>
        </a>
