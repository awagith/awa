<?php
/** @var \Magento\Catalog\Block\Product\AbstractProduct $block */
use GrupoAwamotos\Theme\Block\Widget\HomeNewproduct;
use Magento\Framework\App\Action\Action;

if ((string) $block->getConfig('enabled') === '0' || !$block->hasRenderableProducts()) {
    return;
}

$_productCollection = $block->getProducts();
$_helper = $this->helper('Magento\Catalog\Helper\Output');
$viewMode = 'grid';
$image = 'category_page_grid';
$templateType = \Magento\Catalog\Block\Product\ReviewRendererInterface::SHORT_VIEW;
$pos = $block->getPositioned();
$rows = $block->getShelfRowCount();
$carouselDomId = $block->getCarouselDomId();
$carouselVariant = $block->getCarouselVariant();
$legacyRootClass = $block instanceof HomeNewproduct ? 'rokan-newproduct' : 'rokan-bestseller';
?>
<div id="<?php echo $block->escapeHtmlAttr($carouselDomId); ?>" class="<?php echo $block->escapeHtmlAttr($legacyRootClass); ?> awa-home-merch-shelf <?php echo $block->escapeHtmlAttr($carouselVariant); ?>">
    <div class="row">
        <ul class="owl">
            <?php $i = 0; foreach ($_productCollection as $_product): ?>
                <?php if ($i % $rows === 0): ?>
                    <li class="item awa-home-merch-shelf__slide">
                <?php endif; ?>
                <div class="product-item">
                    <?php
                    $newFromDate = $_product->getNewsFromDate();
                    $newToDate = $_product->getNewsToDate();
                    $now = date('Y-m-d H:i:s');
                    $specialPrice = $_product->getSpecialPrice();
                    $specialPriceFromDate = $_product->getSpecialFromDate();
                    $specialPriceToDate = $_product->getSpecialToDate();
                    if ($specialPrice && ($specialPriceFromDate <= $now && $specialPriceToDate >= $now)) {
                        echo '<span class="icon-sale icon-product">' . $block->escapeHtml(__('Sale')) . '</span>';
                    } elseif ($newFromDate <= $now && $newToDate >= $now) {
                        echo '<span class="icon-new icon-product">' . $block->escapeHtml(__('Hot')) . '</span>';
                    }
                    ?>
                    <?php $productImage = $block->getImage($_product, $image); ?>
                    <?php if ($pos !== null): ?>
                        <?php $position = ' style="left:' . $productImage->getWidth() . 'px;top:' . $productImage->getHeight() . 'px;"'; ?>
                    <?php endif; ?>
                    <a href="<?php echo $block->escapeUrl($_product->getProductUrl()); ?>" class="product photo product-item-photo" tabindex="-1">
                        <?php echo $productImage->toHtml(); ?>
                    </a>
                    <strong class="product name product-item-name">
                        <a class="product-item-link" href="<?php echo $block->escapeUrl($_product->getProductUrl()); ?>">
                            <?php echo $_helper->productAttribute($_product, $_product->getName(), 'name'); ?>
                        </a>
                    </strong>
                    <?php if ((string) $block->getConfig('show_price') !== '0'): ?>
                        <?php echo $this->helper('Rokanthemes\Themeoption\Helper\Data')->getPriceDisplayCustom($block->getProductPrice($_product)); ?>
                    <?php endif; ?>
                    <div class="product-ratting">
                        <?php if ((string) $block->getConfig('review') !== '0'): ?>
                            <?php echo $block->getReviewsSummaryHtml($_product, $templateType); ?>
                        <?php endif; ?>
                    </div>
                    <div class="actions clearfix">
                        <div class="action-inner">
                            <?php if ((string) $block->getConfig('addtocart') !== '0'): ?>
                                <div class="actions-primary<?php echo isset($position) && strpos((string) $pos, $viewMode . '-primary') !== false ? $position : ''; ?>">
                                    <?php if ($_product->isSaleable()): ?>
                                        <?php $postParams = $block->getAddToCartPostParams($_product); ?>
                                        <form data-role="tocart-form" action="<?php echo $block->escapeUrl($postParams['action']); ?>" method="post">
                                            <input type="hidden" name="product" value="<?php echo (int) $postParams['data']['product']; ?>">
                                            <input type="hidden" name="<?php echo $block->escapeHtmlAttr(Action::PARAM_NAME_URL_ENCODED); ?>" value="<?php echo $block->escapeHtmlAttr($postParams['data'][Action::PARAM_NAME_URL_ENCODED]); ?>">
                                            <?php echo $block->getBlockHtml('formkey'); ?>
                                            <button type="submit" title="<?php echo $block->escapeHtmlAttr(__('Add to Cart')); ?>" class="action tocart primary">
                                                <span><?php echo $block->escapeHtml(__('Add to Cart')); ?></span>
                                            </button>
                                        </form>
                                    <?php elseif ($_product->getIsSalable()): ?>
                                        <div class="stock available"><span><?php echo $block->escapeHtml(__('In stock')); ?></span></div>
                                    <?php else: ?>
                                        <div class="stock unavailable"><span><?php echo $block->escapeHtml(__('Out of stock')); ?></span></div>
                                    <?php endif; ?>
                                </div>
                            <?php endif; ?>
                        </div>
                    </div>
                </div>
                <?php $i++; ?>
                <?php if ($i % $rows === 0 || $i === (int) $_productCollection->count()): ?>
                    </li>
                <?php endif; ?>
            <?php endforeach; ?>
        </ul>
    </div>
</div>
<?php if (!$block->isRedirectToCartEnabled()): ?>
<script type="text/x-magento-init">
{
    "[data-role=tocart-form], .form.map.checkout": {
        "catalogAddToCart": {}
    }
}
</script>
<?php endif; ?>
<script>
require(['jquery', 'mage/mage', 'rokanthemes/owl'], function ($) {
    'use strict';

    $('#<?php echo $block->escapeJsQuote($carouselDomId); ?> .owl').owlCarousel({
        lazyLoad: true,
        autoPlay: false,
        items: <?php echo (int) $block->getDefaultItems(); ?>,
        itemsDesktop: [1366, <?php echo (int) $block->getItemsDesktop(); ?>],
        itemsDesktopSmall: [1199, <?php echo (int) $block->getItemsDesktopSmall(); ?>],
        itemsTablet: [991, <?php echo (int) $block->getItemsTablet(); ?>],
        itemsMobile: [680, <?php echo (int) $block->getItemsMobile(); ?>],
        slideSpeed: 500,
        paginationSpeed: 500,
        rewindSpeed: 500,
        navigation: <?php echo $block->isNavigationEnabled() ? 'true' : 'false'; ?>,
        stopOnHover: true,
        pagination: <?php echo $block->isPaginationEnabled() ? 'true' : 'false'; ?>,
        scrollPerPage: true
    });
});
</script>
