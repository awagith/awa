<?php
/** @var \Rokanthemes\Categorytab\Block\CateWidget $block */
$categoryIds = array_filter(array_map('trim', explode(',', (string) $block->getCategoryIds())));
$categoryId = (int) reset($categoryIds);
if ($categoryId < 1) {
    return;
}

$collection = $block->getProductCate($categoryId);
if ((int) $collection->getSize() < 1) {
    return;
}

$image = 'new_products_content_widget_grid';
$templateType = \Magento\Catalog\Block\Product\ReviewRendererInterface::DEFAULT_VIEW;
$domId = preg_replace('/[^a-zA-Z0-9_-]+/', '-', (string) ($block->getData('dom_id') ?: $block->getIdentify())) ?: 'awa-home-category-shelf';
$itemsDesktop = max(1, (int) ($block->getdesktop() ?: 4));
$itemsDesktopSmall = max(1, (int) ($block->getdesktop_small() ?: 3));
$itemsTablet = max(1, (int) ($block->gettablet() ?: 2));
$itemsMobile = max(1, (int) ($block->getmobile() ?: 1));
$defaultItems = max(1, (int) ($block->getdefault() ?: $itemsDesktop));
?>
<div id="<?php echo $block->escapeHtmlAttr($domId); ?>" class="categorytab-container awa-home-merch-shelf awa-home-merch-shelf--category">
    <div class="owl-container">
        <div class="category_tab_slider owl-carousel">
            <?php foreach ($collection as $_item): ?>
                <?php $productImage = $block->getImage($_item, $image); ?>
                <div class="item">
                    <div class="item-inner">
                        <div class="image-container">
                            <a href="<?php echo $block->escapeUrl($block->getProductUrl($_item)); ?>" class="product-item-photo">
                                <?php echo $productImage->toHtml(); ?>
                            </a>
                            <div class="actions">
                                <div class="actions-primary">
                                    <?php if ($_item->isSaleable()): ?>
                                        <?php if ($_item->getTypeInstance()->hasRequiredOptions($_item)): ?>
                                            <button class="action tocart"
                                                    data-mage-init='{"redirectUrl":{"url":"<?php echo $block->escapeUrl($block->getAddToCartUrl($_item)); ?>"}}'
                                                    type="button" title="<?php echo $block->escapeHtmlAttr(__('Add to Cart')); ?>">
                                                <span><?php echo $block->escapeHtml(__('Add to Cart')); ?></span>
                                            </button>
                                        <?php else: ?>
                                            <?php
                                            $postDataHelper = $this->helper('Magento\Framework\Data\Helper\PostHelper');
                                            $postData = $postDataHelper->getPostData($block->getAddToCartUrl($_item), ['product' => $_item->getEntityId()]);
                                            ?>
                                            <button class="action tocart"
                                                    data-post='<?php echo $postData; ?>'
                                                    type="button" title="<?php echo $block->escapeHtmlAttr(__('Add to Cart')); ?>">
                                                <span><?php echo $block->escapeHtml(__('Add to Cart')); ?></span>
                                            </button>
                                        <?php endif; ?>
                                    <?php elseif ($_item->getIsSalable()): ?>
                                        <div class="stock available"><span><?php echo $block->escapeHtml(__('In stock')); ?></span></div>
                                    <?php else: ?>
                                        <div class="stock unavailable"><span><?php echo $block->escapeHtml(__('Out of stock')); ?></span></div>
                                    <?php endif; ?>
                                </div>
                            </div>
                        </div>
                        <div class="des">
                            <div class="product-name">
                                <strong class="product-item-name">
                                    <a title="<?php echo $block->escapeHtmlAttr($_item->getName()); ?>"
                                       href="<?php echo $block->escapeUrl($block->getProductUrl($_item)); ?>"
                                       class="product-item-link">
                                        <?php echo $block->escapeHtml($_item->getName()); ?>
                                    </a>
                                </strong>
                            </div>
                            <?php echo $this->helper('Rokanthemes\Themeoption\Helper\Data')->getPriceDisplayCustom($block->getProductPrice($_item)); ?>
                            <?php echo $block->getReviewsSummaryHtml($_item, $templateType, true); ?>
                        </div>
                    </div>
                </div>
            <?php endforeach; ?>
        </div>
    </div>
</div>
<script>
require(['jquery', 'rokanthemes/owl'], function ($) {
    'use strict';

    if (typeof $.fn.owlCarousel !== 'function') {
        return;
    }

    $('#<?php echo $block->escapeJsQuote($domId); ?> .category_tab_slider').owlCarousel({
        lazyLoad: true,
        autoPlay: false,
        items: <?php echo $defaultItems; ?>,
        itemsDesktop: [1366, <?php echo $itemsDesktop; ?>],
        itemsDesktopSmall: [1199, <?php echo $itemsDesktopSmall; ?>],
        itemsTablet: [991, <?php echo $itemsTablet; ?>],
        itemsMobile: [680, <?php echo $itemsMobile; ?>],
        slideSpeed: 500,
        paginationSpeed: 500,
        rewindSpeed: 500,
        navigation: true,
        stopOnHover: true,
        pagination: false,
        scrollPerPage: true
    });
});
</script>
