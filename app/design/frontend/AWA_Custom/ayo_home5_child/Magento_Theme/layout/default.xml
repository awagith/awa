<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <attribute name="class" value="b2b-theme"/>
        <!-- Announcement bar: CMS block "awa-announcement-bar" controla o conteúdo -->
        <referenceContainer name="before.body.end">
            <block class="Magento\Framework\View\Element\Template"
                   name="awa.announcement.bar"
                   template="Magento_Theme::html/announcement-bar.phtml"
                   before="-"/>
            <!-- Compare bar: sticky tray at bottom, preenchida via JS -->
            <block class="Magento\Catalog\Block\Product\Compare\ListCompare"
                   name="awa.compare.bar"
                   template="Magento_Catalog::product/compare/awa-compare-bar.phtml"
                   after="-"/>
        </referenceContainer>
    </body>
</page>

