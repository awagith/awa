<script>
(function() {
    'use strict';
    function injectB2BPanel() {
        var panel = document.querySelector('[data-awa-mobile-b2b="true"]');
        if (!panel) return;
        // Look for the nav-sections drawer content or vertical menu wrapper
        var targets = [
            document.querySelector('.nav-sections .nav-sections-items'),
            document.querySelector('.nav-sections'),
            document.querySelector('.category-dropdown .nav-sections-items'),
            document.querySelector('.category-dropdown')
        ];
        for (var i = 0; i < targets.length; i++) {
            if (targets[i]) {
                targets[i].insertBefore(panel, targets[i].firstChild);
                panel.style.display = '';
                return;
            }
        }
    }
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', function() { setTimeout(injectB2BPanel, 500); });
    } else {
        setTimeout(injectB2BPanel, 500);
    }
})();
</script>
