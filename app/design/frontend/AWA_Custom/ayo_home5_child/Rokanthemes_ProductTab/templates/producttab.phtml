	$buildOperationalMeta = static function ($product): array {
		$soldBy = $product->getAttributeText('sold_by');
		if (is_array($soldBy)) {
			$soldBy = implode(', ', array_filter(array_map('trim', $soldBy)));
		}

		$meta = [
			[
				'label' => (string) __('Cod'),
				'value' => trim((string) $product->getSku()),
			],
			[
				'label' => (string) __('EAN'),
				'value' => trim((string) $product->getData('ean')),
			],
			[
				'label' => (string) __('Caixa'),
				'value' => trim((string) $product->getData('master_box_qty')),
			],
			[
				'label' => (string) __('Linha'),
				'value' => trim((string) $soldBy),
			],
		];

		return array_values(array_filter($meta, static fn (array $item): bool => $item['value'] !== ''));
	};
	$imageBlock =  $block->getLayout()->createBlock('Magento\Catalog\Block\Product\Image');
	$image = 'new_products_content_widget_grid';
