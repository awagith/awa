<?php
    $_helper = $this->helper('Rokanthemes\VerticalMenu\Helper\Data');
    $_config = $_helper->getConfig('verticalmenu');
    if (!empty($_config['general']['enable'])):
        $limitShow = (int)($_config['general']['limit_show'] ?? 0);
        $menuId    = 'awa-vertical-menu-' . uniqid('', false);
        $_menu     = $this->getVerticalMenuHtml();
?>

<nav class="navigation verticalmenu side-verticalmenu"
     aria-label="<?= $escaper->escapeHtmlAttr(__('Product Categories')) ?>"
     data-role="awa-vertical-menu">
    <h2 class="our_categories title-category-dropdown"
        data-role="awa-vertical-menu-trigger"
        aria-controls="<?= $escaper->escapeHtmlAttr($menuId) ?>"
        aria-expanded="false"
        role="button"
        tabindex="0">
        <span class="vm-icon"><i class="fa fa-bars" aria-hidden="true"></i></span>
        <span><?= $escaper->escapeHtml(__('Categories')) ?></span>
    </h2>
    <ul id="<?= $escaper->escapeHtmlAttr($menuId) ?>"
        class="togge-menu list-category-dropdown"
        data-limit-show="<?= $limitShow ?>">
        <?= /** @noEscape */ $_menu ?>
        <?php
            $_bgBlock  = $this->getLayout()->createBlock(\Magento\Cms\Block\Block::class);
            $_bgImages = $_bgBlock ? trim($_bgBlock->setBlockId('vertical_background_images')->toHtml()) : '';
        ?>
        <?php if ($_bgImages !== ''): ?>
        <li class="vertical-bg-img"><?= /** @noEscape */ $_bgImages ?></li>
        <?php endif; ?>
        <?php if ($limitShow > 0): ?>
        <li class="expand-category-link">
            <a class="viewall vm-toggle-categories"
               href="#"
               role="button"
               aria-expanded="false"
               data-show-text="<?= $escaper->escapeHtmlAttr(__('Show More')) ?>"
               data-hide-text="<?= $escaper->escapeHtmlAttr(__('Show Less')) ?>">
                <span><?= $escaper->escapeHtml(__('All Categories')) ?></span>
                <i class="fa fa-angle-down vm-toggle-icon" aria-hidden="true"></i>
            </a>
        </li>
        <?php endif; ?>
    </ul>
</nav>

<script type="text/x-magento-init">
{
    "[data-role='awa-vertical-menu']": {
        "js/vertical-menu-init": {
            "desktopBreakpoint": 992,
            "overlaySelector": ".shadow_bkg_show",
            "limitShow": <?= (int)$limitShow ?>
        }
    }
}
</script>
