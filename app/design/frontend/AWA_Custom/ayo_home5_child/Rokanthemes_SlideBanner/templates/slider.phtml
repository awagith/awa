<?php
/** @var \Rokanthemes\SlideBanner\Block\Slider $block */
/**
 * AWA SlideBanner — Single-render responsive slider
 *
 * Eliminates double DOM (hidden-xs + visible-xs) by using <picture><source media>
 * for responsive images in a single carousel instance.
 *
 * @var \Rokanthemes\SlideBanner\Block\Slider $block
 */

// @codingStandardsIgnoreFile
if ($banners = $block->getBannerCollection()):
    $slider = $block->getSlider();
    $sliderId = $block->getSliderId();
    $settings = $slider->getSliderSetting();
    $owlConfig = [
        'singleItem' => true,
        'autoHeight' => true,
        'lazyLoad' => true,
        'touchDrag' => true,
        'mouseDrag' => true,
        'transitionStyle' => 'fade',
    ];
    $booleanKeys = ['autoPlay', 'navigation', 'stopOnHover', 'pagination', 'scrollPerPage'];

    $legacyHosts = ['srv1113343.hstgr.cloud', 'www.srv1113343.hstgr.cloud'];
    $baseUrl = rtrim((string) $block->getBaseUrl(), '/');
    $baseHost = (string) parse_url($baseUrl, PHP_URL_HOST);
    $baseScheme = (string) parse_url($baseUrl, PHP_URL_SCHEME);
    $resolveSlideLink = static function (?string $link) use ($legacyHosts, $baseHost, $baseScheme): string {
        if (!is_string($link)) {
            return '';
        }

        $link = trim($link);
        if ($link === '') {
            return '';
        }

        $parts = parse_url($link);
        if (!is_array($parts)) {
            return $link;
        }

        $linkHost = isset($parts['host']) ? strtolower((string) $parts['host']) : '';
        if ($linkHost === '' || !in_array($linkHost, $legacyHosts, true) || $baseHost === '' || $baseScheme === '') {
            return $link;
        }

        $path = isset($parts['path']) ? (string) $parts['path'] : '/';
        $path = $path !== '' ? $path : '/';
        $query = isset($parts['query']) ? ('?' . $parts['query']) : '';
        $fragment = isset($parts['fragment']) ? ('#' . $parts['fragment']) : '';

        return $baseScheme . '://' . $baseHost . $path . $query . $fragment;
    };

    foreach ($settings as $key => $value) {
        if (in_array($key, $booleanKeys, true)) {
            $owlConfig[$key] = ((int) $value) === 1;
            continue;
        }

        if (is_string($value)) {
            $trimmed = trim($value);

            if (is_numeric($trimmed)) {
                $owlConfig[$key] = (strpos($trimmed, '.') !== false) ? (float) $trimmed : (int) $trimmed;
                continue;
            }
        }

        $owlConfig[$key] = $value;
    }

    $totalSlides = is_countable($banners) ? count($banners) : 0;
?>
<div class="wrapper_slider slider_<?php echo (int) $sliderId; ?>"
     role="region"
     aria-label="<?php echo $block->escapeHtml(__('Apresentação de slides promocional')); ?>"
     aria-roledescription="carousel">
    <div class="owl" role="list">
        <?php
        $slideIndex = 0;
        foreach ($banners as $banner):
            if ($banner->getSlideStatus() == '2') { continue; }
            $slideIndex++;
            $isFirst = ($slideIndex === 1);
            $slideAlt = $banner->getSlideText() ?: ($banner->getSlideTitle() ?: '');
            $desktopSrc = $banner->getSlideImage();
            $mobileSrc = $banner->getSlideImageMobile();
            $pictureHtml = $block->getPictureElement($desktopSrc, $mobileSrc, $slideAlt, $isFirst);
            $link = $resolveSlideLink($banner->getSlideLink());
            if ($link !== '') {
                $pictureHtml = '<a href="' . $block->escapeUrl($link) . '">' . $pictureHtml . '</a>';
            }
        ?>
        <div class="banner_item" role="listitem"
             aria-label="<?php echo $block->escapeHtml(__('Slide %1 de %2', $slideIndex, $totalSlides)); ?>">
            <div class="banner_item_bg">
                <?php echo $pictureHtml; ?>
            </div>
            <div class="text-banner">
                <?php if ($text = $banner->getSlideText()) {
                    echo $block->getContentText($text);
                } ?>
            </div>
        </div>
        <?php endforeach; ?>
    </div>
</div>
<script type="text/x-magento-init">
{
    "*": {
        "js/awa-slider-init": {
            "sliderId": <?php echo (int) $sliderId; ?>,
            "owlConfig": <?php echo json_encode($owlConfig, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES | JSON_HEX_TAG | JSON_HEX_AMP); ?>
        }
    }
}
</script>
<?php endif; ?>
