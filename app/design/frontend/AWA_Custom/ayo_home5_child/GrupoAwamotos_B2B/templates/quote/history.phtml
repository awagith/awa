<?php
/**
 * AWA B2B quote history.
 *
 * @var \GrupoAwamotos\B2B\Block\Quote\History $block
 */
?>
<div class="b2b-quote-history b2b-page-shell awa-b2b-flow-page awa-b2b-flow-page--quote-history">
    <header class="awa-b2b-flow-hero">
        <div>
            <p class="awa-b2b-flow-hero__eyebrow"><?= $block->escapeHtml(__('Negociacao')) ?></p>
            <h1 class="awa-b2b-flow-hero__title"><?= $block->escapeHtml(__('Historico de cotacoes')) ?></h1>
            <p class="awa-b2b-flow-hero__lead">
                <?= $block->escapeHtml(__('Acompanhe propostas em andamento, aprovacoes, validade e proximo passo comercial em um unico painel.')) ?>
            </p>
        </div>
        <div class="awa-b2b-flow-hero__meta">
            <span><?= $block->escapeHtml(__('Fluxo de aprovacao visivel')) ?></span>
            <span><?= $block->escapeHtml(__('Estados destacados por prioridade')) ?></span>
        </div>
    </header>

    <?php if (!$block->hasQuoteRequests()): ?>
        <section class="awa-b2b-flow-panel awa-b2b-empty-state">
            <div class="awa-b2b-empty-state__copy">
                <p class="awa-b2b-flow-panel__eyebrow"><?= $block->escapeHtml(__('Primeira cotacao')) ?></p>
                <h2 class="awa-b2b-flow-panel__title"><?= $block->escapeHtml(__('Nenhuma solicitacao registrada')) ?></h2>
                <p><?= $block->escapeHtml(__('Abra uma nova cotacao para negociar preco, disponibilidade e condicoes especiais para a conta.')) ?></p>
            </div>
            <div class="actions">
                <a href="<?= $block->escapeUrl($block->getUrl('/')) ?>" class="action primary">
                    <span><?= $block->escapeHtml(__('Continuar comprando')) ?></span>
                </a>
            </div>
        </section>
    <?php else: ?>
        <section class="awa-b2b-flow-panel awa-b2b-flow-panel--table">
            <div class="awa-b2b-flow-panel__header">
                <div>
                    <p class="awa-b2b-flow-panel__eyebrow"><?= $block->escapeHtml(__('Pipeline comercial')) ?></p>
                    <h2 class="awa-b2b-flow-panel__title"><?= $block->escapeHtml(__('Cotacoes da conta')) ?></h2>
                </div>
            </div>
            <div class="table-wrapper quote-history awa-b2b-table-wrap">
                <table class="data table table-quote-history awa-b2b-table" id="quote-history-table">
                    <caption class="table-caption"><?= $block->escapeHtml(__('Minhas Cotacoes')) ?></caption>
                    <thead>
                        <tr>
                            <th scope="col" class="col id"><?= $block->escapeHtml(__('Nº')) ?></th>
                            <th scope="col" class="col date"><?= $block->escapeHtml(__('Data')) ?></th>
                            <th scope="col" class="col status"><?= $block->escapeHtml(__('Status')) ?></th>
                            <th scope="col" class="col total"><?= $block->escapeHtml(__('Valor')) ?></th>
                            <th scope="col" class="col expires"><?= $block->escapeHtml(__('Validade')) ?></th>
                            <th scope="col" class="col actions"><?= $block->escapeHtml(__('Acoes')) ?></th>
                        </tr>
                    </thead>
                    <tbody>
                        <?php foreach ($block->getQuoteRequests() as $quote): ?>
                            <?php
                            $statusClass = '';
                            switch ($quote->getStatus()) {
                                case 'approved':
                                case 'quoted':
                                    $statusClass = 'status-success';
                                    break;
                                case 'pending':
                                case 'processing':
                                    $statusClass = 'status-pending';
                                    break;
                                case 'rejected':
                                case 'expired':
                                    $statusClass = 'status-failed';
                                    break;
                                case 'converted':
                                    $statusClass = 'status-complete';
                                    break;
                            }
                            ?>
                            <tr>
                                <td data-th="<?= $block->escapeHtmlAttr(__('Nº')) ?>" class="col id">#<?= (int) $quote->getRequestId() ?></td>
                                <td data-th="<?= $block->escapeHtmlAttr(__('Data')) ?>" class="col date"><?= $block->escapeHtml($block->formatQuoteDate($quote->getCreatedAt())) ?></td>
                                <td data-th="<?= $block->escapeHtmlAttr(__('Status')) ?>" class="col status">
                                    <span class="quote-status <?= $block->escapeHtmlAttr($statusClass) ?>"><?= $block->escapeHtml($quote->getStatusLabel()) ?></span>
                                </td>
                                <td data-th="<?= $block->escapeHtmlAttr(__('Valor')) ?>" class="col total">
                                    <?php if ($quote->getQuotedTotal()): ?>
                                        <?= /* @noEscape */ $block->formatPrice($quote->getQuotedTotal()) ?>
                                    <?php else: ?>
                                        <span class="no-value"><?= $block->escapeHtml(__('Aguardando')) ?></span>
                                    <?php endif; ?>
                                </td>
                                <td data-th="<?= $block->escapeHtmlAttr(__('Validade')) ?>" class="col expires">
                                    <?php if ($quote->getExpiresAt()): ?>
                                        <?php if ($quote->isExpired()): ?>
                                            <span class="expired"><?= $block->escapeHtml(__('Expirada')) ?></span>
                                        <?php else: ?>
                                            <?= $block->escapeHtml($block->formatQuoteDate($quote->getExpiresAt())) ?>
                                        <?php endif; ?>
                                    <?php else: ?>
                                        -
                                    <?php endif; ?>
                                </td>
                                <td data-th="<?= $block->escapeHtmlAttr(__('Acoes')) ?>" class="col actions">
                                    <a href="<?= $block->escapeUrl($block->getViewUrl($quote->getRequestId())) ?>"
                                       class="action view"
                                       title="<?= $block->escapeHtmlAttr(__('Ver detalhes')) ?>">
                                        <span><?= $block->escapeHtml(__('Ver')) ?></span>
                                    </a>
                                </td>
                            </tr>
                        <?php endforeach; ?>
                    </tbody>
                </table>
            </div>
        </section>
    <?php endif; ?>
</div>
