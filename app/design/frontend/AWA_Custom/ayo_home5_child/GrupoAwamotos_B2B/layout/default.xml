<?xml version="1.0"?>
<!--
/**
 * AWA — Unified B2B header status panel
 * Replaces compact badge with full status panel (trigger + dropdown).
 * For B2B logged-in: shows name, company, credit, quick actions.
 * For guests: shows registration CTA.
 */
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <!-- Remove original module block (rendered without alias, header.phtml can't reach it) -->
        <referenceBlock name="b2b.header.status.panel" remove="true"/>

        <referenceBlock name="toki_header">
            <block class="GrupoAwamotos\B2B\Block\Header\StatusPanel"
                   name="awa.b2b.mode.badge"
                   as="awaB2bModeBadge"
                   template="GrupoAwamotos_B2B::header/status-panel.phtml"/>
        </referenceBlock>
    </body>
</page>
