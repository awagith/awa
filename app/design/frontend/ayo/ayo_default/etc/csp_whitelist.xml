<?xml version="1.0"?>
<csp_whitelist xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Csp:etc/csp_whitelist.xsd">
    <policies>
        <policy id="script-src">
            <values>
                <value id="vlibras-gov" type="host">https://vlibras.gov.br</value>
                <value id="jsdelivr" type="host">https://cdn.jsdelivr.net</value>
            </values>
        </policy>
        <policy id="img-src">
            <values>
                <value id="vlibras-img" type="host">https://vlibras.gov.br</value>
                <value id="jsdelivr-img" type="host">https://cdn.jsdelivr.net</value>
            </values>
        </policy>
        <policy id="frame-src">
            <values>
                <value id="vlibras-frame" type="host">https://vlibras.gov.br</value>
            </values>
        </policy>
        <policy id="connect-src">
            <values>
                <value id="vlibras-connect" type="host">https://vlibras.gov.br</value>
                <value id="jsdelivr-connect" type="host">https://cdn.jsdelivr.net</value>
            </values>
        </policy>
    </policies>
</csp_whitelist>
