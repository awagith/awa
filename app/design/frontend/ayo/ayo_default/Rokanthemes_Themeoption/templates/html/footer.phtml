<script type="text/javascript">
require(['jquery'], function ($) {
    'use strict';

    var responsiveflag = false;

    function accordionFooter(status) {
        var $titles = $('.velaFooterMenu h4.velaFooterTitle');
        if (status === 'enable') {
            $titles.on('click.footerAccordion', function (e) {
                $(this).toggleClass('active')
                    .parent().find('.velaContent').stop().slideToggle('medium');
                e.preventDefault();
            });
        } else {
            $titles.removeClass('active').off('.footerAccordion')
                .parent().find('.velaContent').slideDown('fast');
        }
    }

    function responsiveResize() {
        if ($(window).width() <= 767 && !responsiveflag) {
            accordionFooter('enable');
            responsiveflag = true;
        } else if ($(window).width() >= 768) {
            accordionFooter('disable');
            responsiveflag = false;
        }
    }

    $(document).ready(function () {
        responsiveResize();
        $(window).on('resize.footerAccordion', responsiveResize);
    });
});
</script>