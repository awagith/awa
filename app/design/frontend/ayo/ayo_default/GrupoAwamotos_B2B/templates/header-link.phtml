<?php
/**
 * B2B Header Link - Inline template for theme integration
 * This template injects itself into the header using JavaScript
 */
?>
<?php
$customerSession = \Magento\Framework\App\ObjectManager::getInstance()
    ->get(\Magento\Customer\Model\Session::class);

// Only render for non-logged in users
if (!$customerSession->isLoggedIn()):
    $registerUrl = $block->getUrl('b2b/register');
?>
<div id="b2b-header-link-source" style="display:none;">
    <a href="<?= $block->escapeUrl($registerUrl) ?>" 
       class="b2b-header-link"
       title="<?= $block->escapeHtmlAttr(__('Cadastro B2B para Empresas e Revendedores')) ?>">
        <span class="b2b-icon">🏢</span>
        <span class="b2b-text"><?= $block->escapeHtml(__('Seja Revendedor')) ?></span>
    </a>
</div>
<style>
.b2b-header-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: linear-gradient(90deg, #f39c12, #e67e22);
    color: #fff !important;
    padding: 6px 14px;
    border-radius: 4px;
    font-weight: 600;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-right: 15px;
    transition: all 0.3s ease;
    text-decoration: none !important;
}
.b2b-header-link:hover {
    background: linear-gradient(90deg, #e67e22, #d35400);
    transform: translateY(-1px);
    box-shadow: 0 2px 8px rgba(243, 156, 18, 0.4);
    color: #fff !important;
}
.b2b-header-link .b2b-icon {
    font-size: 14px;
}
@media (max-width: 767px) {
    .b2b-header-link {
        padding: 4px 10px;
        font-size: 10px;
    }
    .b2b-header-link .b2b-text {
        display: none;
    }
}
</style>
<script>
document.addEventListener('DOMContentLoaded', function() {
    var source = document.getElementById('b2b-header-link-source');
    if (!source) return;
    
    var link = source.querySelector('.b2b-header-link');
    if (!link) return;
    
    // Try to find the header area to inject
    var targets = [
        '.top-bar-right .top-info',
        '.top-account.has-child',
        '.header.links',
        '.top-header .container .row > div:last-child'
    ];
    
    var target = null;
    for (var i = 0; i < targets.length; i++) {
        target = document.querySelector(targets[i]);
        if (target) break;
    }
    
    if (target) {
        // Clone and prepend
        var clonedLink = link.cloneNode(true);
        target.insertBefore(clonedLink, target.firstChild);
        source.remove();
    }
});
</script>
<?php endif; ?>

