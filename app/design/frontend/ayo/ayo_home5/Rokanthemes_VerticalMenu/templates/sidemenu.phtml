<script>
(function () {
    'use strict';

    function isDesktop() {
        return window.matchMedia && window.matchMedia('(min-width: 992px)').matches;
    }

    function syncDesktopState(nav, title, menu) {
        var shouldBeOpen;

        if (!nav || !title || !menu) {
            return;
        }

        if (isDesktop()) {
            shouldBeOpen = title.classList.contains('active') || menu.classList.contains('menu-open');

            title.classList.toggle('active', shouldBeOpen);
            title.setAttribute('aria-expanded', shouldBeOpen ? 'true' : 'false');
            menu.classList.toggle('menu-open', shouldBeOpen);
            menu.style.display = shouldBeOpen ? 'block' : 'none';
            return;
        }

        title.classList.remove('active');
        title.setAttribute('aria-expanded', 'false');
        menu.classList.remove('menu-open');
        menu.style.display = 'none';
    }

    function initFallbackMenu(nav) {
        var title;
        var menu;

        if (!nav || nav.getAttribute('data-awa-fallback-init') === '1') {
            return;
        }

        title = nav.querySelector('.title-category-dropdown');
        menu = nav.querySelector('.togge-menu');

        if (!title || !menu) {
            return;
        }

        nav.setAttribute('data-awa-fallback-init', '1');
        title.setAttribute('role', 'button');
        title.setAttribute('tabindex', '0');

        title.addEventListener('click', function (event) {
            var willOpen;

            event.preventDefault();
            willOpen = !title.classList.contains('active');

            title.classList.toggle('active', willOpen);
            title.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
            menu.classList.toggle('menu-open', willOpen);
            menu.style.display = willOpen ? 'block' : 'none';
        });

        title.addEventListener('keydown', function (event) {
            if (event.key === 'Enter' || event.key === ' ') {
                event.preventDefault();
                title.click();
            }
        });

        nav.addEventListener('click', function (event) {
            var toggle = event.target.closest('.open-children-toggle');
            var parent;
            var submenu;
            var willExpand;

            if (!toggle || isDesktop()) {
                return;
            }

            event.preventDefault();
            event.stopPropagation();

            parent = toggle.parentElement;
            submenu = parent ? parent.querySelector(':scope > .submenu, :scope > ul.level0') : null;

            if (!parent || !submenu) {
                return;
            }

            willExpand = !parent.classList.contains('_active');
            parent.classList.toggle('_active', willExpand);
            toggle.setAttribute('aria-expanded', willExpand ? 'true' : 'false');
            submenu.style.display = willExpand ? 'block' : 'none';
        });

        syncDesktopState(nav, title, menu);

        window.addEventListener('resize', function () {
            syncDesktopState(nav, title, menu);
        });
    }

    function initAllFallbackMenus() {
        var menus = document.querySelectorAll('[data-role="awa-vertical-menu"]');

        if (!menus.length) {
            return;
        }

        menus.forEach(initFallbackMenu);
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initAllFallbackMenus);
    } else {
        initAllFallbackMenus();
    }
})();
</script>
