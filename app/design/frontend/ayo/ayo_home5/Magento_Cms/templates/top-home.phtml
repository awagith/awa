if ($benefitsHtml !== '' && strpos($benefitsHtml, 'velaServicesInner--home5') === false) {
	$patchedBenefitsHtml = preg_replace(
		'/class=(["\'])velaServicesInner\b([^"\']*)\1/',
		'class=$1velaServicesInner$2 velaServicesInner--home5$1',
		$benefitsHtml,
		1
	);
	if (is_string($patchedBenefitsHtml) && $patchedBenefitsHtml !== '') {
