<?php
/** @var \Magento\Framework\View\Element\Template $this */
$layout = $this->getLayout();

$renderCmsBlock = static function (string $blockId) use ($layout): string {
	/** @var \Magento\Cms\Block\Block|null $cmsBlock */
	$cmsBlock = $layout->createBlock('Magento\Cms\Block\Block');
	if (!$cmsBlock) {
		return '';
	}

	$cmsBlock->setBlockId($blockId);
	return trim((string)$cmsBlock->toHtml());
};

/** @var \Rokanthemes\SlideBanner\Block\Slider|null $heroSliderBlock */
$heroSliderBlock = $layout->createBlock('Rokanthemes\SlideBanner\Block\Slider');
$heroSliderHtml = '';
if ($heroSliderBlock) {
	$heroSliderHtml = trim((string)$heroSliderBlock->setslider_id('homepageslider')->toHtml());
}

$heroFallbackHtml = $renderCmsBlock('home_hero');
$schemaOrgHtml = $renderCmsBlock('home_schema_org');
$benefitsHtml = $renderCmsBlock('block_top');
$bannerMidHtml = $renderCmsBlock('banner_mid_home5');
