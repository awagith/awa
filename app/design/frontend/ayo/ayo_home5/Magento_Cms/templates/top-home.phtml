<?php
/** @var \Magento\Framework\View\Element\Template $this */
$layout = $this->getLayout();

$renderCmsBlock = static function (string $blockId) use ($layout): string {
	/** @var \Magento\Cms\Block\Block|null $cmsBlock */
	$cmsBlock = $layout->createBlock('Magento\Cms\Block\Block');
	if (!$cmsBlock) {
		return '';
	}

	$cmsBlock->setBlockId($blockId);
	return trim((string)$cmsBlock->toHtml());
};

/** @var \Rokanthemes\SlideBanner\Block\Slider|null $heroSliderBlock */
$heroSliderBlock = $layout->createBlock('Rokanthemes\SlideBanner\Block\Slider');
$heroSliderHtml = '';
if ($heroSliderBlock) {
	$heroSliderHtml = trim((string)$heroSliderBlock->setslider_id('homepage5slider')->toHtml());
}

$heroFallbackHtml = $renderCmsBlock('home_hero');
$benefitsHtml = $renderCmsBlock('block_top');
$bannerMidHtml = $renderCmsBlock('banner_mid_home5');
$notificationHtml = $renderCmsBlock('notification_home5');
$bestSellersHtml = $renderCmsBlock('category1_home5');
$popularCategoriesHtml = $renderCmsBlock('category2_home5');
$launchesHtml = $renderCmsBlock('home_new_products');
$trustBadgesHtml = $renderCmsBlock('trust_badges_homepage');
$faqQuickHtml = $renderCmsBlock('home_faq_quick');

/** @var \GrupoAwamotos\B2B\Block\PromoBlock|null $b2bPromoBlock */
$b2bPromoBlock = $layout->createBlock('GrupoAwamotos\\B2B\\Block\\PromoBlock');
$b2bPromoHtml = '';
if ($b2bPromoBlock) {
	$b2bPromoHtml = trim((string)$b2bPromoBlock->toHtml());
}

/** @var \Rokanthemes\Superdeals\Block\ProductByCat|null $hotDealBlock */
$hotDealBlock = $layout->createBlock('Rokanthemes\Superdeals\Block\ProductByCat');
$hotDealHtml = '';
if ($hotDealBlock) {
	$hotDealHtml = trim((string)$hotDealBlock->setTemplate('Rokanthemes_Superdeals::category.phtml')->toHtml());
}



if ($benefitsHtml !== '' && strpos($benefitsHtml, 'velaServicesInner--home5') === false) {
	$patchedBenefitsHtml = preg_replace(
		'/class=(["\'])velaServicesInner\b([^"\']*)\1/',
		'class=$1velaServicesInner$2 velaServicesInner--home5$1',
		$benefitsHtml,
		1
	);
	if (is_string($patchedBenefitsHtml) && $patchedBenefitsHtml !== '') {
		$benefitsHtml = $patchedBenefitsHtml;
	}
}
?>

<!-- ① Hero Slider (above-the-fold) -->
<div class="top-home-content top-home-content--above-fold">
	<?php if ($heroSliderHtml !== ''): ?>
		<div class="banner-slider banner-slider2">
			<?php echo $heroSliderHtml; ?>
		</div>
	<?php elseif ($heroFallbackHtml !== ''): ?>
		<div class="banner-slider banner-slider2 banner-slider2--fallback">
			<?php echo $heroFallbackHtml; ?>
		</div>
	<?php endif; ?>
</div>

<!-- ② Benefits + Banners + Super Deals -->
<?php if ($benefitsHtml !== '' || $bannerMidHtml !== '' || $hotDealHtml !== ''): ?>
<section class="top-home-content top-home-content--trust-and-offers awa-home-section" aria-label="<?php echo $this->escapeHtmlAttr(__('Confiança e ofertas')); ?>">
	<div class="container top-home-content__trust-offers-grid" data-role="trust-offers-grid">
		<?php if ($benefitsHtml !== ''): ?>
			<?php echo $benefitsHtml; ?>
		<?php endif; ?>

		<?php if ($bannerMidHtml !== ''): ?>
			<div class="banner_mid_1 top-home-content__trust-offers-banner" data-role="trust-offers-banner">
				<?php echo $bannerMidHtml; ?>
			</div>
		<?php endif; ?>

		<?php if ($hotDealHtml !== ''): ?>
			<div class="hot-deal top-home-content__trust-offers-deals" data-role="trust-offers-deals">
				<?php echo $hotDealHtml; ?>
			</div>
		<?php endif; ?>
	</div>
</section>
<?php endif; ?>

<!-- ③ Notification Ticker (transição ofertas → catálogo) -->
<?php if ($notificationHtml !== ''): ?>
<div class="block_notification awa-home-section awa-home-section--compact">
	<div class="container">
		<div class="awa-ticker-wrap" aria-label="<?php echo $this->escapeHtmlAttr(__('Notificações')); ?>">
			<div class="awa-ticker-content">
				<?php echo $notificationHtml; ?>
			</div>
		</div>
	</div>
</div>
<?php endif; ?>

<!-- ④ Mais Vendidos -->
<?php if ($bestSellersHtml !== ''): ?>
<section class="top-home-content top-home-content--bestsellers awa-home-section" aria-label="<?php echo $this->escapeHtmlAttr(__('Mais Vendidos')); ?>">
	<div class="container">
		<?php echo $bestSellersHtml; ?>
	</div>
</section>
<?php endif; ?>

<!-- ⑤ B2B / Atacado (após mais vendidos — público B2C já viu o catálogo) -->
<?php if ($b2bPromoHtml !== ''): ?>
<section class="top-home-content top-home-content--b2b-promo awa-home-section awa-home-section--highlight" aria-label="<?php echo $this->escapeHtmlAttr(__('Atacado e Revenda')); ?>">
	<div class="container">
		<?php echo $b2bPromoHtml; ?>
	</div>
</section>
<?php endif; ?>

<!-- ⑥ Lançamentos / Novidades -->
<?php if ($launchesHtml !== ''): ?>
<section class="top-home-content top-home-content--launches awa-home-section" aria-label="<?php echo $this->escapeHtmlAttr(__('Lançamentos')); ?>">
	<div class="container">
		<div class="ayo-home5-launches">
			<header class="awa-intent-heading">
				<h2><?php echo $this->escapeHtml(__('Novidades')); ?></h2>
			</header>
			<?php echo $launchesHtml; ?>
		</div>
	</div>
</section>
<?php endif; ?>

<!-- ⑦ Categorias Populares -->
<?php if ($popularCategoriesHtml !== ''): ?>
<section class="top-home-content top-home-content--popular-categories awa-home-section" aria-label="<?php echo $this->escapeHtmlAttr(__('Categorias Populares')); ?>">
	<div class="container">
		<?php echo $popularCategoriesHtml; ?>
	</div>
</section>
<?php endif; ?>

<!-- ⑧ Trust Badges + FAQ (fechamento com confiança) -->
<?php if ($trustBadgesHtml !== '' || $faqQuickHtml !== ''): ?>
<section class="top-home-content top-home-content--trust-close awa-home-section awa-home-section--highlight" aria-label="<?php echo $this->escapeHtmlAttr(__('Confiança e Perguntas Frequentes')); ?>">
	<div class="container">
		<?php if ($trustBadgesHtml !== ''): ?>
			<div class="awa-trust-badges-wrap">
				<?php echo $trustBadgesHtml; ?>
			</div>
		<?php endif; ?>

		<?php if ($faqQuickHtml !== ''): ?>
			<div class="awa-faq-quick-wrap">
				<header class="awa-intent-heading">
					<h2><?php echo $this->escapeHtml(__('Perguntas Frequentes')); ?></h2>
				</header>
				<?php echo $faqQuickHtml; ?>
			</div>
		<?php endif; ?>
	</div>
</section>
<?php endif; ?>
