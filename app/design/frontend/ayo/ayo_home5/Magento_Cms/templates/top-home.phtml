		<?php endif; ?>

		<?php if ($hotDealHtml !== ''): ?>
			<div class="hot-deal">
				<?php echo $hotDealHtml; ?>
			</div>
		<?php endif; ?>
	</div>
</div>
<?php endif; ?>

<?php if ($b2bPromoHtml !== ''): ?>
<div class="top-home-content top-home-content--b2b-promo">
	<div class="container">
		<?php echo $b2bPromoHtml; ?>
	</div>
</div>
