<?php
/**
 * AWA Motos - Slideshow Template
 * Atualizado com acessibilidade, performance e <picture> responsivo
 * Eliminado HTML duplicado desktop/mobile: usa <picture><source> + <img>
 */

// @codingStandardsIgnoreFile
if ($banners = $block->getBannerCollection()):
    $slider = $block->getSlider();
    $sliderId = $block->getSliderId();
    $sliderSettings = $slider->getSliderSetting();
    $totalSlides = is_countable($banners) ? count($banners) : 0;
    $sliderConfig = ['lazyLoad' => true, 'singleItem' => true];
    $booleanKeys = ['autoPlay', 'navigation', 'stopOnHover', 'pagination', 'scrollPerPage'];

    foreach ($sliderSettings as $key => $value) {
        if (in_array($key, $booleanKeys, true)) {
            $sliderConfig[$key] = ((int)$value) !== 0;
            continue;
        }

        if (is_string($value)) {
            $trimmed = trim($value);

            if (preg_match('/^\[.*\]$/', $trimmed)) {
                $decoded = json_decode($trimmed, true);
                if (json_last_error() === JSON_ERROR_NONE && is_array($decoded)) {
                    $sliderConfig[$key] = $decoded;
                    continue;
                }
            }

            if (is_numeric($trimmed)) {
                $sliderConfig[$key] = (strpos($trimmed, '.') !== false) ? (float)$trimmed : (int)$trimmed;
                continue;
            }
        }

        $sliderConfig[$key] = $value;
    }
?>

<!-- Slider unificado com <picture> responsivo -->
<div class="wrapper_slider slider_<?php echo $sliderId; ?>"
     role="region"
     aria-label="<?php echo $block->escapeHtml(__('Apresentação de slides promocional')); ?>"
     aria-roledescription="carousel"
     aria-live="off">
    <div class="owl" role="list">
        <?php
        $slideIndex = 0;
        foreach ($banners as $banner):
            if ($banner->getSlideStatus() == '2') { continue; }
            $slideIndex++;
            $slideAlt = $banner->getSlideText() ?: ($banner->getSlideTitle() ?: __('Slide %1', $slideIndex));
        ?>
        <div class="banner_item" role="listitem" aria-label="<?php echo $block->escapeHtml(__('Slide %1 de %2', $slideIndex, $totalSlides)); ?>">
            <?php
                $isFirst = ($slideIndex === 1);
                $desktopSrc = $banner->getSlideImage();
                $mobileSrc = $banner->getSlideImageMobile();
                $html = $block->getPictureElement($desktopSrc, $mobileSrc, $slideAlt, $isFirst);
                if ($link = $banner->getSlideLink()) {
                    $html = '<a href="' . $block->escapeUrl($link) . '" title="' . $block->escapeHtml($slideAlt) . '">' . $html . '</a>';
                }
                echo $html;
            ?>
        </div>
        <?php endforeach; ?>
    </div>
</div>

<script type="text/x-magento-init">
{
    ".slider_<?php echo $block->escapeJsQuote($sliderId); ?>": {
        "js/slide-banner-init": {
            "owl": <?php echo json_encode($sliderConfig, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES); ?>,
            "labels": {
                "prev": "<?php echo $block->escapeJsQuote(__('Slide anterior')); ?>",
                "next": "<?php echo $block->escapeJsQuote(__('Próximo slide')); ?>",
                "pagination": "<?php echo $block->escapeJsQuote(__('Indicadores de slides')); ?>",
                "goTo": "<?php echo $block->escapeJsQuote(__('Ir para slide')); ?>"
            }
        }
    }
}
</script>
<?php endif; ?>
