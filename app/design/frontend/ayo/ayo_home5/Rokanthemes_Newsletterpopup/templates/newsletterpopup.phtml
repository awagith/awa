// Popup behavior settings — can be changed in admin via
// Rokanthemes > Theme Settings > Newsletter Popup
$top     = 120;
$speed   = 500;
$timeout = 1;   // days until cookie expires (show again)
?>

<script>
require(["jquery"], function($){
    var pPopup;

    function setCookie(name, value, days) {
        var expires = "";
        if (days) {
            var date = new Date();
            date.setTime(date.getTime() + (days * 24 * 60 * 60 * 1000));
            expires = "; expires=" + date.toGMTString();
        }
        document.cookie = name + "=" + value + expires + "; path=/";
    }

    function getCookie(name) {
        var nameEQ = name + "=";
        var ca = document.cookie.split(";");
        for (var i = 0; i < ca.length; i++) {
            var c = ca[i].trim();
            if (c.indexOf(nameEQ) === 0) {
                return c.substring(nameEQ.length, c.length);
            }
        }
        return null;
    }

    if (getCookie("shownewsletter") != 1) {
        if (typeof $.fn.bPopup === 'function') {
            pPopup = $("#newsletter_pop_up_simple").bPopup({
                position: ["auto", <?php echo (int)$top; ?>],
                speed: <?php echo (int)$speed; ?>,
                transition: "slideDown",
                onClose: function() {
                    setCookie("shownewsletter", "1", <?php echo (int)$timeout; ?>);
                }
            });
        } else {
            pPopup = {
                close: function () {
                    $("#newsletter_pop_up_simple").hide();
                }
            };
            $("#newsletter_pop_up_simple").show();
        }

        $(".newletter_popup_close_simple").on("click", function() {
            pPopup.close();
        });
    }

    $("#newsletter_pop_up_simple form").submit(function() {
        setCookie("shownewsletter", "1", 1);
    });

    $("#newsletter_popup_dont_show_again_simple").on("change", function() {
        if (getCookie("shownewsletter") != 1) {
            setCookie("shownewsletter", "1", 1);
        } else {
            setCookie("shownewsletter", "0", 1);
        }
    });
});
</script>
