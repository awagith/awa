<?php
/** @var $block \Rokanthemes\SearchbyCat\Block\Form */
/** @var $helper \Magento\Search\Helper\Data */
$helper = $this->helper('Magento\Search\Helper\Data');
/** @var \Magento\Search\Helper\Data $searchHelper */
$searchHelper = $helper;
$searchDelay = 300;
$searchSuiteUrl = $block->getUrl('rokanthemes_searchsuiteautocomplete/ajax/index');
?>
<div class="block block-search" role="search" aria-label="<?php echo $block->escapeHtmlAttr(__('Busca de produtos')) ?>">
    <div class="block-content">
        <form class="form minisearch search-content" id="search_mini_form" action="<?php echo $block->escapeUrl($searchHelper->getResultUrl()) ?>" method="get">
            <div class="field search">
                <label class="label" for="search" data-role="minisearch-label">
                    <span><?php echo $block->escapeHtml(__('Buscar')) ?></span>
                </label>
                <div class="control">
                    <input id="search"
                           data-mage-init='{"quickSearch":{
                               "formSelector":"#search_mini_form",
                               "url":"<?php echo $block->escapeUrl($block->getUrl('search/ajax/suggest')); ?>",
                               "destinationSelector":"#search_autocomplete"
                           }}'
                           type="search"
                           name="<?php echo $block->escapeHtmlAttr($searchHelper->getQueryParamName()) ?>"
                           value="<?php echo $block->escapeHtmlAttr($searchHelper->getEscapedQueryText()) ?>"
                           placeholder="<?php echo $block->escapeHtmlAttr(__('Buscar peças, capacetes, acessórios...')) ?>"
                           class="input-text"
                           minlength="2"
                           maxlength="<?php echo (int)$searchHelper->getMaxQueryLength() ?>"
                           role="combobox"
                           aria-label="<?php echo $block->escapeHtmlAttr(__('Buscar')) ?>"
                           aria-autocomplete="both"
                           aria-expanded="false"
                                                     aria-haspopup="listbox"
                           aria-controls="search_autocomplete"
                           autocomplete="off"
                           autocapitalize="off"
                           autocorrect="off"
                           spellcheck="false" />
                                        <div id="search_autocomplete"
                                                 class="search-autocomplete searchsuite-autocomplete"
                                                 data-role="search-autocomplete"
                                                 role="listbox"
                                                 aria-hidden="true"
                                                 aria-label="<?php echo $block->escapeHtmlAttr(__('Sugestões de busca')) ?>"></div>
                    <div data-bind="scope: 'searchsuiteautocomplete_form'">
                        <!-- ko template: getTemplate() --><!-- /ko -->
                    </div>
                    <?php echo $block->getChildHtml() ?>
                </div>
            </div>
            <div class="actions">
                <button type="submit"
                        title="<?php echo $block->escapeHtml(__('Buscar')) ?>"
                        class="action search">
                    <span><?php echo $block->escapeHtml(__('Buscar')) ?></span>
                </button>
            </div>
        </form>
    </div>
</div>
<script type="text/x-magento-init">
{
    "*": {
        "Magento_Ui/js/core/app": {
            "components": {
                "searchsuiteautocompleteDataProvider": {
                    "component": "Rokanthemes_SearchSuiteAutocomplete/js/dataProvider",
                    "config": {
                        "url": "<?php echo $block->escapeUrl($searchSuiteUrl) ?>"
                    }
                },
                "searchsuiteautocomplete_form": {
                    "component": "Rokanthemes_SearchSuiteAutocomplete/js/autocomplete"
                },
                "searchsuiteautocompleteBindEvents": {
                    "component": "Rokanthemes_SearchSuiteAutocomplete/js/bindEvents",
                    "config": {
                        "searchFormSelector": "#search_mini_form",
                        "searchButtonSelector": "button.search",
                        "inputSelector": "#search",
                        "searchDelay": "<?php echo (int)$searchDelay ?>"
                    }
                }
            }
        }
    }
}
</script>
