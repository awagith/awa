	 data-role="awa-vertical-menu">
	<h2 class="our_categories title-category-dropdown"
		data-role="awa-vertical-menu-trigger"
		aria-controls="<?= $escaper->escapeHtmlAttr($menuId) ?>"
		aria-expanded="false">
		<span class="vm-icon"><i class="fa fa-bars" aria-hidden="true"></i></span>
		<span><?= $escaper->escapeHtml(__('Categories')) ?></span>
	</h2>
	<ul id="<?= $escaper->escapeHtmlAttr($menuId) ?>" class="togge-menu list-category-dropdown" data-limit-show="<?= (int)$limitShow ?>">
		<?= /** @noEscape */ $_menu; ?>
		<?php
			$_bgBlock = $this->getLayout()->createBlock('Magento\Cms\Block\Block');
			$_bgImages = $_bgBlock ? $_bgBlock->setBlockId('vertical_background_images')->toHtml() : '';
			$_bgImages = trim($_bgImages);
		?>
		<?php if (!empty($_bgImages)): ?>
			<li class="vertical-bg-img"><?= /** @noEscape */ $_bgImages; ?></li>
		<?php endif; ?>
