	$_config = $_helper->getConfig('verticalmenu');
	$columnsLimit = 0;
	if (!empty($_config['general']['enable'])) {
		$limitShow = isset($_config['general']['limit_show']) ? (int)$_config['general']['limit_show'] : 11;
		$menuId = 'awa-vertical-menu-list-' . uniqid('', false);
?>
<?php $_menu = $this->getVerticalMenuHtml(); ?>

<nav class="navigation verticalmenu side-verticalmenu"
