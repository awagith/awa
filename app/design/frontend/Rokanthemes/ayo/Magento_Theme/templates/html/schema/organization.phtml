<?php
/**
 * Organization Schema.org Markup
 * Para homepage e páginas institucionais
 * 
 * @var $block \Magento\Framework\View\Element\Template
 */

$objectManager = \Magento\Framework\App\ObjectManager::getInstance();
$storeManager = $objectManager->get(\Magento\Store\Model\StoreManagerInterface::class);
$scopeConfig = $objectManager->get(\Magento\Framework\App\Config\ScopeConfigInterface::class);

$store = $storeManager->getStore();
$baseUrl = $store->getBaseUrl();
$storeName = $scopeConfig->getValue('general/store_information/name', \Magento\Store\Model\ScopeInterface::SCOPE_STORE);
$phone = $scopeConfig->getValue('general/store_information/phone', \Magento\Store\Model\ScopeInterface::SCOPE_STORE);
$email = $scopeConfig->getValue('trans_email/ident_general/email', \Magento\Store\Model\ScopeInterface::SCOPE_STORE);

// Default values se não configurado
$organizationName = !empty($storeName) ? $storeName : 'Grupo Awamotos';
$organizationPhone = !empty($phone) ? $phone : '+55-11-99999-9999';
$organizationEmail = !empty($email) ? $email : 'contato@grupoawamotos.com.br';

$organizationSchema = [
    "@context" => "https://schema.org",
    "@type" => "Organization",
    "name" => $organizationName,
    "url" => $baseUrl,
