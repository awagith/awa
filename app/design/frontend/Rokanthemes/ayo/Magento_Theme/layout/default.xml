<?xml version="1.0"?>
<!--
/**
 * Layout padrão para WhatsApp Float Button e Schema.org
 * Adiciona o botão flutuante e estrutured data em todas as páginas
 */
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <!-- Schema.org Markup (Homepage) -->
        <referenceContainer name="head.additional">
            <block class="Magento\Framework\View\Element\Template"
                   name="schema.organization"
                   template="Magento_Theme::html/schema/organization.phtml"
                   cacheable="true"/>
        </referenceContainer>
    </head>
    
    <body>
        <!-- Schema.org Test - Inline no body -->
        <referenceContainer name="before.body.end">
            <block class="Magento\Framework\View\Element\Template" 
                   name="schema.test" 
                   template="Magento_Theme::html/schema-test.phtml"
                   cacheable="false"/>
        </referenceContainer>
        
        <!-- WhatsApp Float Button -->
        <referenceContainer name="before.body.end">
            <block class="Magento\Framework\View\Element\Template" 
                   name="whatsapp.float" 
                   template="Magento_Theme::whatsapp-float.phtml"
                   cacheable="false"/>
            
            <!-- Mobile Bottom Navigation -->
            <block class="Magento\Framework\View\Element\Template" 
                   name="mobile.bottom.nav" 
                   template="Magento_Theme::mobile-bottom-nav.phtml"
                   cacheable="false"/>
            
            <!-- Newsletter Popup -->
            <block class="Magento\Newsletter\Block\Subscribe" 
                   name="newsletter.popup" 
                   template="Magento_Newsletter::popup.phtml"
                   cacheable="false"/>
        </referenceContainer>
    </body>
</page>
