<?xml version="1.0" encoding="UTF-8"?>
<widgets xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Widget:etc/widget.xsd">
    <widget id="rokanthemes_onsale_list" class="Rokanthemes\Onsaleproduct\Block\Widget\Onsaleproduct">
        <label translate="true">Rokanthemes On Sale Products</label>
        <description translate="true">Displays on-sale products carousel</description>
        <parameters>
            <parameter name="limit" xsi:type="text" visible="true" sort_order="10">
                <label translate="true">Number of Products</label>
                <value>12</value>
            </parameter>
            <parameter name="row" xsi:type="text" visible="true" sort_order="20">
                <label translate="true">Rows</label>
                <value>1</value>
            </parameter>
            <parameter name="navigation" xsi:type="select" visible="true" sort_order="30"
                       source_model="Magento\Config\Model\Config\Source\Yesno">
                <label translate="true">Show Navigation</label>
            </parameter>
            <parameter name="pagination" xsi:type="select" visible="true" sort_order="40"
                       source_model="Magento\Config\Model\Config\Source\Yesno">
                <label translate="true">Show Pagination</label>
            </parameter>
        </parameters>
    </widget>
</widgets>
