<script type="text/javascript">
require(['jquery'], function($) {
    'use strict';

    var statusOrder = ['pending', 'reviewing', 'interview', 'approved', 'rejected'];
    
    function getStatusIndex(status) {
        var idx = statusOrder.indexOf(status);
        return idx >= 0 ? idx : 0;
    }

    function renderTimeline(currentStatus) {
        var currentIdx = getStatusIndex(currentStatus);
        var $timeline = $('<div/>', {class: 'status-timeline'});
        $('<h4/>').text('<?= $block->escapeJs(__('Etapas do Processo')) ?>').appendTo($timeline);

        var $stepsWrap = $('<div/>', {class: 'timeline-steps'}).appendTo($timeline);
        var steps = [
            {status: 'pending', label: '<?= $block->escapeJs(__('Recebido')) ?>'},
            {status: 'reviewing', label: '<?= $block->escapeJs(__('Análise')) ?>'},
            {status: 'interview', label: '<?= $block->escapeJs(__('Entrevista')) ?>'},
            {status: 'approved', label: '<?= $block->escapeJs(__('Aprovado')) ?>'},
            {status: 'rejected', label: '<?= $block->escapeJs(__('Finalizado')) ?>'}
        ];

        steps.forEach(function(step, i) {
            var cls = '';
            if (i < currentIdx) cls = 'active';
            else if (i === currentIdx) cls = 'current';

            var $step = $('<div/>', {class: 'timeline-step ' + cls});
            $('<span/>', {class: 'dot'}).text(i < currentIdx ? '✓' : (i + 1)).appendTo($step);
            $('<span/>', {class: 'label'}).text(step.label).appendTo($step);
            $stepsWrap.append($step);
        });

        return $timeline;
    }

    function getFormKey() {
        var val = $('input[name="form_key"]').first().val();
        return val ? String(val) : '';
    }

    function normalizeStatus(status) {
        var allowed = ['pending', 'reviewing', 'interview', 'approved', 'rejected'];
        status = String(status || '').toLowerCase();
        return allowed.indexOf(status) >= 0 ? status : 'pending';
    }

    $('#check-status-btn').on('click', function() {
        var btn = $(this);
        var code = $('#tracking_code').val().trim().toUpperCase();
        var email = ($('#tracking_email').val() || '').trim();
        var resultDiv = $('#status-result');
        
        if (!code) {
            resultDiv.removeClass('success').addClass('error show');
            resultDiv.empty().append($('<p/>').text('<?= $block->escapeJs(__('Por favor, informe o código de acompanhamento.')) ?>'));
            return;
        }
        
        btn.prop('disabled', true).text('<?= $block->escapeJs(__('Consultando...')) ?>');
        
        $.ajax({
            url: '<?= $block->escapeUrl($block->getUrl('curriculo/index/checkStatus')) ?>',
            type: 'POST',
            data: {
                tracking_code: code,
                tracking_email: email,
                form_key: getFormKey()
            },
            dataType: 'json',
            success: function(response) {
                btn.prop('disabled', false).text('<?= $block->escapeJs(__('Consultar Status')) ?>');
                
                if (!response.success) {
                    resultDiv.removeClass('success').addClass('error show');
                    resultDiv.empty().append($('<p/>').text(String(response.message || '')));
                    return;
                }

                var d = response.data || {};
                var safeStatus = normalizeStatus(d.status);
                var $wrap = $('<div/>');

                var $header = $('<div/>', {class: 'status-result-header'});
                $('<div/>', {class: 'tracking-code'}).text(String(d.tracking_code || '')).appendTo($header);
                if (d.display_hint) {
                    $('<div/>', {class: 'name'}).text(String(d.display_hint)).appendTo($header);
                }
                $wrap.append($header);

                var $body = $('<div/>', {class: 'status-result-body'});
                var $center = $('<div/>', {style: 'text-align:center'});
                $('<span/>', {class: 'status-badge ' + safeStatus}).text(String(d.status_label || '')).appendTo($center);
                $body.append($center);

                var $grid = $('<div/>', {class: 'info-grid'});
                var $cargo = $('<div/>', {class: 'info-item'});
                $('<label/>').text('<?= $block->escapeJs(__('Cargo')) ?>').appendTo($cargo);
                $('<div/>', {class: 'value'}).text(String(d.position || '-')).appendTo($cargo);
                $grid.append($cargo);

                var $dataEnvio = $('<div/>', {class: 'info-item'});
                $('<label/>').text('<?= $block->escapeJs(__('Data de Envio')) ?>').appendTo($dataEnvio);
                $('<div/>', {class: 'value'}).text(String(d.submitted_at || '-')).appendTo($dataEnvio);
                $grid.append($dataEnvio);
                $body.append($grid);

                $body.append(renderTimeline(safeStatus));
                $wrap.append($body);

                resultDiv.removeClass('error').addClass('success show');
                resultDiv.empty().append($wrap);
            },
            error: function() {
                btn.prop('disabled', false).text('<?= $block->escapeJs(__('Consultar Status')) ?>');
                resultDiv.removeClass('success').addClass('error show');
                resultDiv.empty().append($('<p/>').text('<?= $block->escapeJs(__('Erro ao consultar. Tente novamente.')) ?>'));
            }
        });
    });
    
    // Submit on Enter
    $('#tracking_code').on('keypress', function(e) {
        if (e.which === 13) {
            $('#check-status-btn').trigger('click');
        }
    });
});
</script>
