<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Cron:etc/crontab.xsd">
    <group id="default">
        <job name="grupoawamotos_fitment_fallback_delta"
             instance="GrupoAwamotos\Fitment\Cron\FallbackDelta"
             method="execute">
            <schedule>*/10 * * * *</schedule>
        </job>
        <job name="grupoawamotos_fitment_fallback_rebuild"
             instance="GrupoAwamotos\Fitment\Cron\FallbackRebuild"
             method="execute">
            <schedule>15 3 * * *</schedule>
        </job>
    </group>
</config>
