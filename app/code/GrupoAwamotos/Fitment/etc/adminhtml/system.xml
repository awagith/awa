<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <section id="grupoawamotos_fitment" translate="label" type="text" sortOrder="950" showInDefault="1" showInWebsite="1" showInStore="1">
            <label>Grupo Awamotos</label>
            <tab>general</tab>
            <resource>GrupoAwamotos_Fitment::config</resource>
            <group id="fallback" translate="label" type="text" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Busca Fallback</label>
                <field id="sku_weight" translate="label" type="text" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Peso SKU (repetições)</label>
                    <comment>Quantidade de repetições para o SKU dentro de keywords (default 3).</comment>
                    <validate>validate-number</validate>
                </field>
                <field id="meta_keyword_weight" translate="label" type="text" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Peso Meta Keywords (repetições)</label>
                    <comment>Quantidade de repetições para meta_keyword dentro de keywords (default 2).</comment>
                    <validate>validate-number</validate>
                </field>
                <field id="synonyms" translate="label" type="textarea" sortOrder="30" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Grupos de Sinônimos</label>
                    <comment>Cada linha representa um grupo de sinônimos separados por vírgula. Ex: pastilha,freio,brake pad</comment>
                </field>
            </group>
            <group id="search" translate="label" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Busca</label>
                <field id="fallback_enabled" translate="label" type="select" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Ativar busca fallback (sem OpenSearch)</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
            </group>
        </section>
    </system>
</config>
