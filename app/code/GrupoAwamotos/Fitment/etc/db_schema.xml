<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">

    <table name="grupoawamotos_fitment_brand" resource="default" engine="innodb" comment="Fitment - Marcas de Motos">
        <column xsi:type="int" name="brand_id" unsigned="true" nullable="false" identity="true" comment="Brand ID"/>
        <column xsi:type="varchar" name="name" length="100" nullable="false" comment="Nome da Marca"/>
        <column xsi:type="varchar" name="code" length="50" nullable="true" comment="Codigo interno"/>
        <column xsi:type="varchar" name="logo" length="255" nullable="true" comment="Logo da marca"/>
        <column xsi:type="smallint" name="is_active" unsigned="true" nullable="false" default="1" comment="Ativo"/>
        <column xsi:type="int" name="sort_order" unsigned="true" nullable="false" default="0" comment="Ordem"/>
        <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP" comment="Criado em"/>
        <column xsi:type="timestamp" name="updated_at" nullable="false" default="CURRENT_TIMESTAMP" on_update="true" comment="Atualizado em"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="brand_id"/>
        </constraint>
        <constraint xsi:type="unique" referenceId="GRUPOAWAMOTOS_FITMENT_BRAND_CODE_UNIQUE">
            <column name="code"/>
        </constraint>
        <index referenceId="GRUPOAWAMOTOS_FITMENT_BRAND_NAME" indexType="btree">
            <column name="name"/>
        </index>
    </table>

    <table name="grupoawamotos_fitment_model" resource="default" engine="innodb" comment="Fitment - Modelos de Motos">
        <column xsi:type="int" name="model_id" unsigned="true" nullable="false" identity="true" comment="Model ID"/>
        <column xsi:type="int" name="brand_id" unsigned="true" nullable="false" comment="ID da Marca"/>
        <column xsi:type="varchar" name="name" length="150" nullable="false" comment="Nome do Modelo"/>
        <column xsi:type="varchar" name="code" length="50" nullable="true" comment="Codigo interno"/>
        <column xsi:type="smallint" name="year_from" unsigned="true" nullable="true" comment="Ano inicial"/>
        <column xsi:type="smallint" name="year_to" unsigned="true" nullable="true" comment="Ano final"/>
        <column xsi:type="varchar" name="engine_cc" length="20" nullable="true" comment="Cilindrada"/>
        <column xsi:type="varchar" name="category" length="50" nullable="true" comment="Categoria"/>
        <column xsi:type="smallint" name="is_active" unsigned="true" nullable="false" default="1" comment="Ativo"/>
        <column xsi:type="int" name="sort_order" unsigned="true" nullable="false" default="0" comment="Ordem"/>
        <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP" comment="Criado em"/>
        <column xsi:type="timestamp" name="updated_at" nullable="false" default="CURRENT_TIMESTAMP" on_update="true" comment="Atualizado em"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="model_id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="GRUPOAWAMOTOS_FITMENT_MODEL_BRAND_ID"
                    table="grupoawamotos_fitment_model" column="brand_id"
                    referenceTable="grupoawamotos_fitment_brand" referenceColumn="brand_id"
                    onDelete="CASCADE"/>
        <index referenceId="GRUPOAWAMOTOS_FITMENT_MODEL_BRAND_ID" indexType="btree">
            <column name="brand_id"/>
        </index>
    </table>

    <table name="grupoawamotos_fitment_application" resource="default" engine="innodb" comment="Fitment - Aplicacao Peca x Moto">
        <column xsi:type="int" name="application_id" unsigned="true" nullable="false" identity="true" comment="Application ID"/>
        <column xsi:type="int" name="product_id" unsigned="true" nullable="false" comment="ID do Produto"/>
        <column xsi:type="int" name="model_id" unsigned="true" nullable="false" comment="ID do Modelo"/>
        <column xsi:type="varchar" name="oem_code" length="100" nullable="true" comment="Codigo OEM"/>
        <column xsi:type="varchar" name="position" length="50" nullable="true" comment="Posicao"/>
        <column xsi:type="text" name="notes" nullable="true" comment="Observacoes"/>
        <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP" comment="Criado em"/>
        <column xsi:type="timestamp" name="updated_at" nullable="false" default="CURRENT_TIMESTAMP" on_update="true" comment="Atualizado em"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="application_id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="GRUPOAWAMOTOS_FITMENT_APPLICATION_PRODUCT_ID"
                    table="grupoawamotos_fitment_application" column="product_id"
                    referenceTable="catalog_product_entity" referenceColumn="entity_id"
                    onDelete="CASCADE"/>
        <constraint xsi:type="foreign" referenceId="GRUPOAWAMOTOS_FITMENT_APPLICATION_MODEL_ID"
                    table="grupoawamotos_fitment_application" column="model_id"
                    referenceTable="grupoawamotos_fitment_model" referenceColumn="model_id"
                    onDelete="CASCADE"/>
        <constraint xsi:type="unique" referenceId="GRUPOAWAMOTOS_FITMENT_APPLICATION_PRODUCT_MODEL_UNIQUE">
            <column name="product_id"/>
            <column name="model_id"/>
        </constraint>
        <index referenceId="GRUPOAWAMOTOS_FITMENT_APPLICATION_PRODUCT_ID" indexType="btree">
            <column name="product_id"/>
        </index>
        <index referenceId="GRUPOAWAMOTOS_FITMENT_APPLICATION_MODEL_ID" indexType="btree">
            <column name="model_id"/>
        </index>
    </table>

</schema>