<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Acl/etc/acl.xsd">
    <acl>
        <resources>
            <resource id="Magento_Backend::admin">
                <!-- Catalog menu resources -->
                <resource id="Magento_Catalog::catalog">
                    <resource id="GrupoAwamotos_Fitment::fitment" title="Fitment (Aplicação)" sortOrder="50">
                        <resource id="GrupoAwamotos_Fitment::brand" title="Marcas de Motos" sortOrder="10"/>
                        <resource id="GrupoAwamotos_Fitment::model" title="Modelos de Motos" sortOrder="20"/>
                        <resource id="GrupoAwamotos_Fitment::application" title="Aplicações de Peças" sortOrder="30"/>
                    </resource>
                </resource>
                <!-- Store configuration resources -->
                <resource id="Magento_Backend::stores">
                    <resource id="Magento_Backend::stores_settings">
                        <resource id="Magento_Config::config">
                            <resource id="GrupoAwamotos_Fitment::config" title="Grupo Awamotos - Fitment" sortOrder="100"/>
                        </resource>
                    </resource>
                </resource>
            </resource>
        </resources>
    </acl>
</config>
