    return;
}

$applications = $block->getApplications();
?>

<div class="fitment-applications" id="fitment-applications">
    <div class="fitment-header">
        <h2 class="fitment-title">
            <span class="fitment-icon">🏍️</span>
            <?= $block->escapeHtml($block->getSectionTitle()) ?>
        </h2>
    </div>

    <div class="fitment-content">
        <p class="fitment-intro">
            <?= $block->escapeHtml(__('Este produto é compatível com os seguintes modelos:')) ?>
        </p>

        <?php foreach ($applications as $brandGroup): ?>
            <div class="fitment-brand-group">
                <h3 class="fitment-brand-name">
                    <?= $block->escapeHtml($brandGroup['brand_name']) ?>
                </h3>
                <ul class="fitment-model-list">
                    <?php foreach ($brandGroup['models'] as $model): ?>
                        <li class="fitment-model-item">
                            <span class="fitment-model-name">
                                <?= $block->escapeHtml($block->getMotorcycleLabel($model)) ?>
                            </span>
                            <?= /* @noEscape */ $block->getPositionBadge($model) ?>
                            <?= /* @noEscape */ $block->getOemBadge($model) ?>
                            <?= /* @noEscape */ $block->getNotes($model) ?>
                        </li>
                    <?php endforeach; ?>
                </ul>
            </div>
        <?php endforeach; ?>

        <p class="fitment-disclaimer">
            <?= $block->escapeHtml(__('⚠️ Verifique sempre as especificações do seu veículo antes da compra.')) ?>
        </p>
    </div>
</div>

