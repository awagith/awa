<?php
/**
 * Fitment Bar — PLP
 * Permite filtrar produtos por Marca / Modelo / Ano de moto
 *
 * @var \GrupoAwamotos\Fitment\Block\FitmentBar $block
 */
declare(strict_types=1);

$activeMarca  = $block->getActiveMarca();
$activeModelo = $block->getActiveModelo();
$activeAno    = $block->getActiveAno();
$hasActive    = $block->hasFitmentActive();
?>
<div class="awa-fitment-bar"
     id="awa-fitment-bar"
     role="search"
     aria-label="<?= $block->escapeHtmlAttr(__('Filtrar peças por moto')) ?>">

    <div class="awa-fitment-bar__inner">
        <div class="awa-fitment-bar__label">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
                 fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <circle cx="12" cy="12" r="10"></circle>
                <path d="M12 8v4l3 3"></path>
            </svg>
            <span><?= $block->escapeHtml(__('Peças para minha moto:')) ?></span>
        </div>

        <form class="awa-fitment-bar__form"
              id="awa-fitment-form"
              action="<?= $block->escapeUrl($block->getFitmentResultsUrl()) ?>"
              method="get"
              novalidate>

            <div class="awa-fitment-bar__selects">
                <!-- Marca -->
                <div class="awa-fitment-select-wrap">
                    <label class="awa-fitment-select-label" for="fitment-bar-marca">
                        <?= $block->escapeHtml(__('Marca')) ?>
                    </label>
                    <div class="awa-fitment-select-control">
                        <select id="fitment-bar-marca"
                                name="marca_moto"
                                class="awa-fitment-select"
                                data-fitment-role="marca"
                                aria-label="<?= $block->escapeHtmlAttr(__('Selecione a marca da moto')) ?>">
                            <option value=""><?= $block->escapeHtml(__('— Marca —')) ?></option>
                            <?php if ($activeMarca): ?>
                                <option value="<?= $block->escapeHtmlAttr($activeMarca) ?>" selected>
                                    <?= $block->escapeHtml($activeMarca) ?>
                                </option>
                            <?php endif; ?>
                        </select>
                        <span class="awa-fitment-select-loader" aria-hidden="true"></span>
                    </div>
                </div>

                <!-- Modelo -->
                <div class="awa-fitment-select-wrap">
                    <label class="awa-fitment-select-label" for="fitment-bar-modelo">
                        <?= $block->escapeHtml(__('Modelo')) ?>
                    </label>
                    <div class="awa-fitment-select-control">
                        <select id="fitment-bar-modelo"
                                name="modelo_moto"
                                class="awa-fitment-select"
                                data-fitment-role="modelo"
                                <?= !$activeMarca ? 'disabled' : '' ?>
                                aria-label="<?= $block->escapeHtmlAttr(__('Selecione o modelo da moto')) ?>">
                            <option value=""><?= $block->escapeHtml(__('— Modelo —')) ?></option>
                            <?php if ($activeModelo): ?>
                                <option value="<?= $block->escapeHtmlAttr($activeModelo) ?>" selected>
                                    <?= $block->escapeHtml($activeModelo) ?>
                                </option>
                            <?php endif; ?>
                        </select>
                        <span class="awa-fitment-select-loader" aria-hidden="true"></span>
                    </div>
                </div>

                <!-- Ano -->
                <div class="awa-fitment-select-wrap">
                    <label class="awa-fitment-select-label" for="fitment-bar-ano">
                        <?= $block->escapeHtml(__('Ano')) ?>
                    </label>
                    <div class="awa-fitment-select-control">
                        <select id="fitment-bar-ano"
                                name="ano_moto"
                                class="awa-fitment-select"
                                data-fitment-role="ano"
