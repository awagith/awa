                                aria-label="<?= $block->escapeHtmlAttr(__('Selecione o ano da moto')) ?>">
                            <option value=""><?= $block->escapeHtml(__('— Ano —')) ?></option>
                            <?php if ($activeAno): ?>
                                <option value="<?= $block->escapeHtmlAttr($activeAno) ?>" selected>
                                    <?= $block->escapeHtml($activeAno) ?>
                                </option>
                            <?php endif; ?>
                        </select>
                        <span class="awa-fitment-select-loader" aria-hidden="true"></span>
                    </div>
                </div>
