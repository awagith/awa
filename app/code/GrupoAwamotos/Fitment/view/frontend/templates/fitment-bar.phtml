            <div class="awa-fitment-bar__actions">
                <button type="submit"
                        id="fitment-bar-submit"
                        class="awa-fitment-bar__btn awa-fitment-bar__btn--search"
                        <?= !$hasActive ? 'disabled' : '' ?>>
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                         fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <circle cx="11" cy="11" r="8"></circle>
                        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                    </svg>
                    <span><?= $block->escapeHtml(__('Buscar')) ?></span>
                </button>

                <?php if ($hasActive): ?>
                <a href="<?= $block->escapeUrl($block->getCurrentCategoryUrl() ?: '#') ?>"
                   class="awa-fitment-bar__btn awa-fitment-bar__btn--clear"
                   id="fitment-bar-clear"
                   aria-label="<?= $block->escapeHtmlAttr(__('Limpar filtro de moto')) ?>">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
                         fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                    <span><?= $block->escapeHtml(__('Limpar')) ?></span>
                </a>
                <?php endif; ?>
            </div>

        </form>

        <?php if ($hasActive): ?>
        <div class="awa-fitment-bar__active-badge" aria-live="polite">
            <span class="awa-fitment-bar__active-text">
                <?= $block->escapeHtml(__('Mostrando peças para:')) ?>
                <strong>
                    <?= $block->escapeHtml(implode(' › ', array_filter([$activeMarca, $activeModelo, $activeAno]))) ?>
                </strong>
            </span>
        </div>
        <?php endif; ?>
    </div>
</div>

<script type="text/x-magento-init">
{
    "#awa-fitment-bar": {
        "awaFitmentBar": {
            "brandsUrl": "<?= $block->escapeJs($block->getBrandsUrl()) ?>",
            "modelsUrl": "<?= $block->escapeJs($block->getModelsUrl()) ?>",
            "yearsUrl":  "<?= $block->escapeJs($block->getYearsUrl()) ?>",
            "activeMarca":  "<?= $block->escapeJs($activeMarca) ?>",
            "activeModelo": "<?= $block->escapeJs($activeModelo) ?>",
            "activeAno":    "<?= $block->escapeJs($activeAno) ?>"
        }
    }
}
</script>
