<?xml version="1.0"?>
<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">fitment_brand_form.fitment_brand_form_data_source</item>
        </item>
        <item name="label" xsi:type="string" translate="true">Marca</item>
        <item name="template" xsi:type="string">templates/form/collapsible</item>
    </argument>
    <settings>
        <buttons>
            <button name="save" class="GrupoAwamotos\Fitment\Block\Adminhtml\Brand\Edit\SaveButton"/>
            <button name="delete" class="GrupoAwamotos\Fitment\Block\Adminhtml\Brand\Edit\DeleteButton"/>
            <button name="back" class="GrupoAwamotos\Fitment\Block\Adminhtml\Brand\Edit\BackButton"/>
        </buttons>
        <namespace>fitment_brand_form</namespace>
        <dataScope>data</dataScope>
        <deps>
            <dep>fitment_brand_form.fitment_brand_form_data_source</dep>
        </deps>
    </settings>
    <dataSource name="fitment_brand_form_data_source">
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array">
                <item name="component" xsi:type="string">Magento_Ui/js/form/provider</item>
            </item>
        </argument>
        <settings>
            <submitUrl path="fitment/brand/save"/>
        </settings>
        <dataProvider class="GrupoAwamotos\Fitment\Model\Brand\DataProvider" name="fitment_brand_form_data_source">
            <settings>
                <requestFieldName>id</requestFieldName>
                <primaryFieldName>brand_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <fieldset name="general">
        <settings>
            <label translate="true">Informações da Marca</label>
        </settings>
        <field name="brand_id" formElement="hidden">
            <settings>
                <dataType>text</dataType>
            </settings>
        </field>
        <field name="name" sortOrder="10" formElement="input">
            <settings>
                <label translate="true">Nome</label>
                <dataType>text</dataType>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
            </settings>
        </field>
        <field name="code" sortOrder="20" formElement="input">
            <settings>
                <label translate="true">Código Interno</label>
                <dataType>text</dataType>
            </settings>
        </field>
        <field name="is_active" sortOrder="30" formElement="checkbox">
            <settings>
                <label translate="true">Ativo</label>
                <dataType>boolean</dataType>
            </settings>
            <formElements>
                <checkbox>
                    <settings>
                        <valueMap>
                            <map name="false" xsi:type="number">0</map>
                            <map name="true" xsi:type="number">1</map>
                        </valueMap>
                        <prefer>toggle</prefer>
                    </settings>
                </checkbox>
            </formElements>
        </field>
        <field name="sort_order" sortOrder="40" formElement="input">
            <settings>
                <label translate="true">Ordem de Exibição</label>
                <dataType>number</dataType>
            </settings>
        </field>
    </fieldset>
</form>