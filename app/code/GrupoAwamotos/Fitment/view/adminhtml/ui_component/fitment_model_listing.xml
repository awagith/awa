<?xml version="1.0"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">fitment_model_listing.fitment_model_listing_data_source</item>
        </item>
    </argument>
    <settings>
        <buttons>
            <button name="add">
                <url path="*/*/new"/>
                <class>primary</class>
                <label translate="true">Adicionar Novo Modelo</label>
            </button>
        </buttons>
        <spinner>fitment_model_columns</spinner>
        <deps>
            <dep>fitment_model_listing.fitment_model_listing_data_source</dep>
        </deps>
    </settings>
    <dataSource name="fitment_model_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <storageConfig>
                <param name="indexField" xsi:type="string">model_id</param>
            </storageConfig>
            <updateUrl path="mui/index/render"/>
        </settings>
        <aclResource>GrupoAwamotos_Fitment::model</aclResource>
        <dataProvider class="Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider"
                      name="fitment_model_listing_data_source">
            <settings>
                <requestFieldName>id</requestFieldName>
                <primaryFieldName>model_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <listingToolbar name="listing_top">
        <settings>
            <sticky>true</sticky>
        </settings>
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filterSearch name="fulltext"/>
        <filters name="listing_filters"/>
        <massaction name="listing_massaction">
            <action name="delete">
                <settings>
                    <confirm>
                        <message translate="true">Tem certeza que deseja excluir os modelos selecionados?</message>
                        <title translate="true">Excluir Itens</title>
                    </confirm>
                    <url path="fitment/model/massDelete"/>
                    <type>delete</type>
                    <label translate="true">Excluir</label>
                </settings>
            </action>
        </massaction>
        <paging name="listing_paging"/>
    </listingToolbar>
    <columns name="fitment_model_columns">
        <settings>
            <editorConfig>
                <param name="clientConfig" xsi:type="array">
                    <item name="saveUrl" xsi:type="url" path="fitment/model/inlineEdit"/>
                    <item name="validateBeforeSave" xsi:type="boolean">false</item>
                </param>
                <param name="indexField" xsi:type="string">model_id</param>
                <param name="enabled" xsi:type="boolean">true</param>
                <param name="selectProvider" xsi:type="string">fitment_model_listing.fitment_model_listing.fitment_model_columns.ids</param>
            </editorConfig>
            <childDefaults>
                <param name="fieldAction" xsi:type="array">
                    <item name="provider" xsi:type="string">fitment_model_listing.fitment_model_listing.fitment_model_columns_editor</item>
                    <item name="target" xsi:type="string">startEdit</item>
                    <item name="params" xsi:type="array">
                        <item name="0" xsi:type="string">${ $.$data.rowIndex }</item>
                        <item name="1" xsi:type="boolean">true</item>
                    </item>
                </param>
            </childDefaults>
        </settings>
        <selectionsColumn name="ids">
            <settings>
                <indexField>model_id</indexField>
            </settings>
        </selectionsColumn>
        <column name="model_id">
            <settings>
                <filter>textrange</filter>
                <label translate="true">ID</label>
                <sorting>asc</sorting>
            </settings>
        </column>
        <column name="brand_id" component="Magento_Ui/js/grid/columns/select">
            <settings>
                <filter>select</filter>
                <dataType>select</dataType>
                <label translate="true">Marca</label>
                <options class="GrupoAwamotos\Fitment\Model\Source\Brand"/>
            </settings>
        </column>
        <column name="name">
            <settings>
                <filter>text</filter>
                <label translate="true">Nome do Modelo</label>
                <editor>
                    <editorType>text</editorType>
                    <validation>
                        <rule name="required-entry" xsi:type="boolean">true</rule>
                    </validation>
                </editor>
            </settings>
        </column>
        <column name="year_from">
            <settings>
                <filter>textrange</filter>
                <label translate="true">Ano Inicial</label>
                <editor>
                    <editorType>text</editorType>
                    <validation>
                        <rule name="validate-digits" xsi:type="boolean">true</rule>
                    </validation>
                </editor>
            </settings>
        </column>
        <column name="year_to">
            <settings>
                <filter>textrange</filter>
                <label translate="true">Ano Final</label>
                <editor>
                    <editorType>text</editorType>
                    <validation>
                        <rule name="validate-digits" xsi:type="boolean">true</rule>
                    </validation>
                </editor>
            </settings>
        </column>
        <column name="engine_cc">
            <settings>
                <filter>text</filter>
                <label translate="true">Cilindrada</label>
                <editor>
                    <editorType>text</editorType>
                </editor>
            </settings>
        </column>
        <column name="category">
            <settings>
                <filter>text</filter>
                <label translate="true">Categoria</label>
                <editor>
                    <editorType>text</editorType>
                </editor>
            </settings>
        </column>
        <column name="is_active" component="Magento_Ui/js/grid/columns/select">
            <settings>
                <filter>select</filter>
                <dataType>select</dataType>
                <label translate="true">Ativo</label>
                <options class="Magento\Config\Model\Config\Source\Yesno"/>
                <editor>
                    <editorType>select</editorType>
                </editor>
            </settings>
        </column>
        <column name="created_at" class="Magento\Ui\Component\Listing\Columns\Date"
                component="Magento_Ui/js/grid/columns/date">
            <settings>
                <filter>daterange</filter>
                <dataType>date</dataType>
                <label translate="true">Criado em</label>
            </settings>
        </column>
        <actionsColumn name="actions" class="Magento\Backend\Ui\Component\Listing\Column\EditAction">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="editUrlPath" xsi:type="string">fitment/model/edit</item>
                </item>
            </argument>
            <settings>
                <indexField>model_id</indexField>
            </settings>
        </actionsColumn>
    </columns>
</listing>