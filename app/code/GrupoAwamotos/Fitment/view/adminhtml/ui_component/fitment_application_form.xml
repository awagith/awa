<?xml version="1.0"?>
<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">fitment_application_form.fitment_application_form_data_source</item>
        </item>
        <item name="label" xsi:type="string" translate="true">Aplicação (Peça x Moto)</item>
        <item name="template" xsi:type="string">templates/form/collapsible</item>
    </argument>
    <settings>
        <buttons>
            <button name="save" class="GrupoAwamotos\Fitment\Block\Adminhtml\Application\Edit\SaveButton"/>
            <button name="delete" class="GrupoAwamotos\Fitment\Block\Adminhtml\Application\Edit\DeleteButton"/>
            <button name="back" class="GrupoAwamotos\Fitment\Block\Adminhtml\Application\Edit\BackButton"/>
        </buttons>
        <namespace>fitment_application_form</namespace>
        <dataScope>data</dataScope>
        <deps>
            <dep>fitment_application_form.fitment_application_form_data_source</dep>
        </deps>
    </settings>
    <dataSource name="fitment_application_form_data_source">
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array">
                <item name="component" xsi:type="string">Magento_Ui/js/form/provider</item>
            </item>
        </argument>
        <settings>
            <submitUrl path="fitment/application/save"/>
        </settings>
        <dataProvider class="GrupoAwamotos\Fitment\Model\Application\DataProvider" name="fitment_application_form_data_source">
            <settings>
                <requestFieldName>id</requestFieldName>
                <primaryFieldName>application_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <fieldset name="general">
        <settings>
            <label translate="true">Dados da Aplicação</label>
        </settings>
        <field name="application_id" formElement="hidden">
            <settings>
                <dataType>text</dataType>
            </settings>
        </field>
        <field name="product_id" sortOrder="10" formElement="input">
            <settings>
                <label translate="true">ID do Produto (catalog_product_entity.entity_id)</label>
                <dataType>number</dataType>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                    <rule name="validate-digits" xsi:type="boolean">true</rule>
                </validation>
            </settings>
        </field>
        <field name="model_id" sortOrder="20" formElement="select">
            <settings>
                <label translate="true">Modelo de Moto</label>
                <dataType>number</dataType>
                <validation>
                    <rule name="required-entry" xsi:type="boolean">true</rule>
                </validation>
            </settings>
            <formElements>
                <select>
                    <settings>
                        <options class="GrupoAwamotos\Fitment\Model\Source\MotorcycleModel"/>
                    </settings>
                </select>
            </formElements>
        </field>
        <field name="oem_code" sortOrder="30" formElement="input">
            <settings>
                <label translate="true">Código OEM</label>
                <dataType>text</dataType>
            </settings>
        </field>
        <field name="position" sortOrder="40" formElement="input">
            <settings>
                <label translate="true">Posição (ex: esquerda, direita)</label>
                <dataType>text</dataType>
            </settings>
        </field>
        <field name="notes" sortOrder="50" formElement="textarea">
            <settings>
                <label translate="true">Observações</label>
                <dataType>text</dataType>
            </settings>
        </field>
    </fieldset>
</form>