<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

    <!-- RFM Calculator -->
    <preference for="GrupoAwamotos\SmartSuggestions\Api\RfmCalculatorInterface"
                type="GrupoAwamotos\SmartSuggestions\Model\Rfm\Calculator"/>

    <!-- Forecast Service -->
    <preference for="GrupoAwamotos\SmartSuggestions\Api\ForecastServiceInterface"
                type="GrupoAwamotos\SmartSuggestions\Model\Forecast\SalesProjection"/>

    <!-- Suggestion Engine -->
    <preference for="GrupoAwamotos\SmartSuggestions\Api\SuggestionEngineInterface"
                type="GrupoAwamotos\SmartSuggestions\Model\Suggestion\Engine"/>

    <!-- WhatsApp Sender -->
    <preference for="GrupoAwamotos\SmartSuggestions\Api\WhatsappSenderInterface"
                type="GrupoAwamotos\SmartSuggestions\Model\Whatsapp\Sender"/>

    <!-- Virtual Type for Logger -->
    <virtualType name="GrupoAwamotos\SmartSuggestions\Logger\Handler" type="Magento\Framework\Logger\Handler\Base">
        <arguments>
            <argument name="fileName" xsi:type="string">/var/log/smart_suggestions.log</argument>
        </arguments>
    </virtualType>

    <virtualType name="GrupoAwamotos\SmartSuggestions\Logger\Logger" type="Magento\Framework\Logger\Monolog">
        <arguments>
            <argument name="handlers" xsi:type="array">
                <item name="debug" xsi:type="object">GrupoAwamotos\SmartSuggestions\Logger\Handler</item>
            </argument>
        </arguments>
    </virtualType>

</config>
