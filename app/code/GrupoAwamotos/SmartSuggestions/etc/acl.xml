<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Acl/etc/acl.xsd">
    <acl>
        <resources>
            <resource id="Magento_Backend::admin" title="Admin" translate="title" sortOrder="10">
                <resource id="Magento_Backend::marketing" title="Marketing" translate="title" sortOrder="60">
                    <resource id="GrupoAwamotos_SmartSuggestions::smart_suggestions" title="Sugestões Inteligentes" sortOrder="100">
                        <resource id="GrupoAwamotos_SmartSuggestions::dashboard" title="Dashboard" sortOrder="10"/>
                        <resource id="GrupoAwamotos_SmartSuggestions::rfm" title="Análise RFM" sortOrder="20"/>
                        <resource id="GrupoAwamotos_SmartSuggestions::suggestions" title="Sugestões de Carrinho" sortOrder="30"/>
                        <resource id="GrupoAwamotos_SmartSuggestions::forecast" title="Projeções" sortOrder="40"/>
                        <resource id="GrupoAwamotos_SmartSuggestions::history" title="Histórico" sortOrder="50"/>
                        <resource id="GrupoAwamotos_SmartSuggestions::export" title="Exportar Dados" sortOrder="60"/>
                    </resource>
                </resource>
                <resource id="Magento_Backend::stores" title="Stores" translate="title" sortOrder="80">
                    <resource id="Magento_Backend::stores_settings" title="Settings" translate="title" sortOrder="10">
                        <resource id="Magento_Config::config" title="Configuration" translate="title" sortOrder="20">
                            <resource id="GrupoAwamotos_SmartSuggestions::config" title="Sugestões Inteligentes" sortOrder="100"/>
                        </resource>
                    </resource>
                </resource>
            </resource>
        </resources>
    </acl>
</config>
