<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <!-- Tabela de transportadoras -->
    <table name="grupoawamotos_carriers" resource="default" engine="innodb" comment="Transportadoras Disponíveis">
        <column xsi:type="int" name="carrier_id" unsigned="true" nullable="false" identity="true" comment="ID"/>
        <column xsi:type="varchar" name="name" nullable="false" length="255" comment="Nome da Transportadora"/>
        <column xsi:type="varchar" name="code" nullable="false" length="100" comment="Código Único"/>
        <column xsi:type="varchar" name="contact_phone" nullable="true" length="50" comment="Telefone de Contato"/>
        <column xsi:type="varchar" name="contact_email" nullable="true" length="255" comment="Email de Contato"/>
        <column xsi:type="varchar" name="website" nullable="true" length="255" comment="Site"/>
        <column xsi:type="text" name="regions" nullable="true" comment="Regiões Atendidas (JSON)"/>
        <column xsi:type="text" name="notes" nullable="true" comment="Observações"/>
        <column xsi:type="boolean" name="is_active" nullable="false" default="true" comment="Ativo"/>
        <column xsi:type="int" name="sort_order" unsigned="true" nullable="false" default="0" comment="Ordem"/>
        <column xsi:type="timestamp" name="created_at" on_update="false" nullable="false" default="CURRENT_TIMESTAMP" comment="Data de Criação"/>
        <column xsi:type="timestamp" name="updated_at" on_update="true" nullable="false" default="CURRENT_TIMESTAMP" comment="Data de Atualização"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="carrier_id"/>
        </constraint>
        <constraint xsi:type="unique" referenceId="GRUPOAWAMOTOS_CARRIERS_CODE">
            <column name="code"/>
        </constraint>
        <index referenceId="GRUPOAWAMOTOS_CARRIERS_IS_ACTIVE" indexType="btree">
            <column name="is_active"/>
        </index>
    </table>
</schema>
