<?xml version="1.0"?>
<!--
/**
 * LayoutFix additions for admin login.
 *
 * Removes wrappers created only for compatibility with backend default.xml and
 * admin module layout references. This keeps login rendering identical while
 * avoiding broken-reference warnings from core/theme move instructions.
 */
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceContainer name="notices.wrapper" remove="true"/>
        <referenceContainer name="page.formkey" remove="true"/>
        <referenceContainer name="page.main.container" remove="true"/>
        <referenceContainer name="page.main.actions" remove="true"/>
        <referenceContainer name="menu.wrapper" remove="true"/>
    </body>
</page>
