<?php
/**
 * Social Proof Badge para Listagem de Produtos
 * Badge compacto para grid/list view
 * 
 * @var \Magento\Catalog\Block\Product\ProductList\Item\Block $block
 * @var \Magento\Framework\Escaper $escaper
 */

$_product = $block->getProduct();
$isBestSeller = (bool)$_product->getData('is_best_seller');

// Verificar estoque baixo
$stockItem = $_product->getExtensionAttributes()->getStockItem();
$qty = $stockItem ? (int)$stockItem->getQty() : 0;
$isLowStock = ($qty > 0 && $qty < 10);
?>

<?php if ($isBestSeller || $isLowStock): ?>
<!-- Social Proof Badge Container -->
<div class="product-badge-container social-proof-badge">
    <?php if ($isBestSeller): ?>
    <span class="product-badge bestseller">
        <i class="fa fa-star"></i> <?= $escaper->escapeHtml(__('Mais Vendido')) ?>
    </span>
    <?php endif; ?>
    
    <?php if ($isLowStock): ?>
    <span class="product-badge low-stock">
        <i class="fa fa-exclamation-circle"></i> <?= $escaper->escapeHtml(__('Últimas unidades')) ?>
    </span>
    <?php endif; ?>
</div>
<?php endif; ?>
