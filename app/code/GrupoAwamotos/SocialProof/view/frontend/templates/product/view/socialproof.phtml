<?php
/**
 * Template de Social Proof para página de produto
 * 
 * @var $block \GrupoAwamotos\SocialProof\Block\ProductInfo
 */
$viewsToday = $block->getViewsToday();
$isBestSeller = $block->isBestSeller();
$isLowStock = $block->isLowStock();
$stockQty = $block->getStockQty();
?>

<?php if ($viewsToday > 0 || $isBestSeller || $isLowStock): ?>
<div class="product-social-proof">
    
    <?php if ($isBestSeller): ?>
    <div class="social-proof-badge badge-bestseller">
        <i class="fa fa-fire"></i>
        <strong>MAIS VENDIDO</strong>
    </div>
    <?php endif; ?>
    
    <?php if ($viewsToday > 0): ?>
    <div class="social-proof-item views-counter">
        <i class="fa fa-eye"></i>
        <span class="social-proof-text">
            <strong><?= (int)$viewsToday ?></strong> pessoas visualizaram este produto hoje
        </span>
    </div>
    <?php endif; ?>
    
    <?php if ($isLowStock && $stockQty > 0): ?>
    <div class="social-proof-item stock-urgency">
        <i class="fa fa-exclamation-triangle"></i>
        <span class="social-proof-text urgency-text">
            <strong>Últimas <?= (int)$stockQty ?> unidades</strong> em estoque
        </span>
    </div>
    <?php endif; ?>
    
</div>
<?php endif; ?>
