<?php
/**
 * Social Proof Badges
 * Exibe contador de visualizações, badge "Últimas unidades" e "Mais Vendido"
 * 
 * @var \Magento\Catalog\Block\Product\View $block
 * @var \Magento\Framework\Escaper $escaper
 */

$_product = $block->getProduct();
$viewsToday = (int)$_product->getData('views_today');
$isBestSeller = (bool)$_product->getData('is_best_seller');

// Verificar estoque
$stockItem = $_product->getExtensionAttributes()->getStockItem();
$qty = $stockItem ? (int)$stockItem->getQty() : 0;
$isLowStock = ($qty > 0 && $qty < 10);
?>

<div class="social-proof-container">
    
    <?php if ($viewsToday > 0): ?>
    <!-- Contador de Visualizações -->
    <div class="social-proof-badge views-badge">
        <i class="fa fa-eye"></i>
        <span class="badge-text">
            <strong><?= $escaper->escapeHtml($viewsToday) ?></strong>
            <?= $escaper->escapeHtml(__('pessoas visualizaram este produto hoje')) ?>
        </span>
    </div>
    <?php endif; ?>
    
    <?php if ($isLowStock): ?>
    <!-- Badge Últimas Unidades -->
    <div class="social-proof-badge low-stock-badge urgency">
        <i class="fa fa-exclamation-triangle"></i>
        <span class="badge-text">
            <strong><?= $escaper->escapeHtml(__('Últimas %1 unidades!', $qty)) ?></strong>
            <?= $escaper->escapeHtml(__('Aproveite enquanto há estoque')) ?>
        </span>
    </div>
    <?php endif; ?>
    
    <?php if ($isBestSeller): ?>
    <!-- Badge Mais Vendido -->
    <div class="social-proof-badge bestseller-badge">
        <i class="fa fa-star"></i>
        <span class="badge-text">
            <strong><?= $escaper->escapeHtml(__('MAIS VENDIDO')) ?></strong>
        </span>
    </div>
    <?php endif; ?>
    
</div>

<style>
.social-proof-container {
    margin: 20px 0;
}

