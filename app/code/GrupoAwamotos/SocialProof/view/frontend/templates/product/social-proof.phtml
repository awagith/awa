.bestseller-badge {
    background: linear-gradient(135deg, #b73337 0%, #d63a3f 100%);
    border: 1px solid #9a2b2f;
    color: #fff;
    font-weight: 600;
}

.bestseller-badge i {
    color: #ffd700;
    animation: sparkle 2s infinite;
}

