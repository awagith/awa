<script>
require(['apexcharts'], function(ApexCharts) {

    // ---- 1. TIPO PIE (Donut) ----
    (function() {
        var data = <?= $block->getChartDataJson('tipo_pie') ?>;
        if (!data.series || !data.series.length) return;
        var opts = {
            series: data.series,
            chart: { type: 'donut', height: 300, background: 'transparent' },
            labels: data.labels,
            colors: ['#ef4444', '#10b981', '#f59e0b', '#6366f1', '#64748b'],
            legend: { position: 'bottom', labels: { colors: '#94a3b8' } },
            stroke: { colors: ['#1e293b'] },
            dataLabels: {
                enabled: true,
                style: { fontSize: '13px' },
                formatter: function(val) { return val.toFixed(1) + '%'; }
            },
            plotOptions: {
                pie: {
                    donut: {
                        size: '65%',
                        labels: {
                            show: true,
                            total: {
                                show: true,
                                label: 'Total',
                                color: '#94a3b8',
                                formatter: function(w) {
                                    return w.globals.seriesTotals.reduce(function(a,b){return a+b},0).toLocaleString('pt-BR');
                                }
                            },
                            value: { color: '#f8fafc', fontSize: '22px', fontWeight: 700 }
                        }
                    }
                }
            },
            theme: { mode: 'dark' }
        };
        new ApexCharts(document.querySelector('#chart-tipo'), opts).render();
    })();

    // ---- 2. MONTHLY EVOLUTION (Mixed: Bar + Line) ----
    (function() {
        var data = <?= $block->getChartDataJson('monthly_line') ?>;
        if (!data.months || !data.months.length) {
            document.querySelector('#chart-monthly').innerHTML = '<div style="text-align:center;padding:80px 20px;color:#64748b;font-style:italic">Dados de conversao aparecerao aqui apos pedidos de clientes recomendados serem processados</div>';
            return;
        }
        var opts = {
            series: [
                { name: 'Recomendados', type: 'column', data: data.recomendados },
                { name: 'Convertidos', type: 'column', data: data.convertidos },
                { name: 'Taxa Conv. %', type: 'line', data: data.taxaConversao }
            ],
            chart: { height: 300, type: 'line', background: 'transparent', foreColor: '#94a3b8',
                toolbar: { show: false }
            },
            colors: ['#6366f1', '#10b981', '#f59e0b'],
            stroke: { width: [0, 0, 3], curve: 'smooth' },
            plotOptions: { bar: { borderRadius: 4, columnWidth: '50%' } },
            xaxis: { categories: data.months },
            yaxis: [
                { title: { text: 'Clientes', style: { color: '#94a3b8' } }, labels: { style: { colors: '#94a3b8' } } },
                { opposite: true, title: { text: 'Conversao %', style: { color: '#94a3b8' } }, labels: { style: { colors: '#94a3b8' } } }
            ],
            grid: { borderColor: '#334155' },
            legend: { labels: { colors: '#94a3b8' } },
            tooltip: { theme: 'dark' }
        };
        new ApexCharts(document.querySelector('#chart-monthly'), opts).render();
    })();

    // ---- 3. RFM BAR (Horizontal) ----
    (function() {
        var data = <?= $block->getChartDataJson('rfm_bar') ?>;
        if (!data.clientes || !data.clientes.length) return;
        var rfmColors = {
            'Champions': '#10b981', 'Loyal': '#3b82f6', 'Novos Clientes': '#8b5cf6',
            'Potencial': '#06b6d4', 'Em Risco': '#f59e0b',
            'Hibernando': '#64748b', 'Perdido': '#6b7280'
        };
        var defaultColor = '#64748b';
        var colors = data.categories.map(function(c) {
            for (var key in rfmColors) {
                if (c.indexOf(key) !== -1) return rfmColors[key];
            }
            return defaultColor;
        });
        var opts = {
            series: [{ name: 'Clientes', data: data.clientes }],
            chart: { type: 'bar', height: 320, background: 'transparent', foreColor: '#94a3b8',
                toolbar: { show: false }
            },
            plotOptions: { bar: { borderRadius: 6, horizontal: true, distributed: true, barHeight: '70%' } },
            colors: colors,
            dataLabels: { enabled: true, style: { colors: ['#f8fafc'], fontSize: '12px' } },
            xaxis: { categories: data.categories },
            grid: { borderColor: '#334155' },
            legend: { show: false },
            tooltip: {
                theme: 'dark',
                y: {
                    formatter: function(val, opts) {
                        var idx = opts.dataPointIndex;
                        var valor = data.valores[idx];
                        return val + ' clientes (R$ ' + valor.toLocaleString('pt-BR', {minimumFractionDigits:2}) + ' medio)';
                    }
                }
            }
        };
        new ApexCharts(document.querySelector('#chart-rfm'), opts).render();
    })();

    // ---- 4. SCORE HISTOGRAM ----
    (function() {
        var data = <?= $block->getChartDataJson('score_histogram') ?>;
        if (!data.values || !data.values.length) return;
        var colors = data.categories.map(function(c) {
            var pct = parseInt(c);
            if (pct >= 70) return '#10b981';
            if (pct >= 40) return '#f59e0b';
            if (pct >= 20) return '#f97316';
            return '#ef4444';
        });
        var opts = {
            series: [{ name: 'Recomendacoes', data: data.values }],
            chart: { type: 'bar', height: 320, background: 'transparent', foreColor: '#94a3b8',
                toolbar: { show: false }
            },
            plotOptions: { bar: { borderRadius: 4, columnWidth: '80%', distributed: true } },
            colors: colors,
            dataLabels: { enabled: true, style: { colors: ['#f8fafc'], fontSize: '11px' } },
            xaxis: { categories: data.categories, labels: { rotate: -45 } },
            yaxis: { title: { text: 'Qtd Recomendacoes', style: { color: '#94a3b8' } } },
            grid: { borderColor: '#334155' },
            legend: { show: false },
            tooltip: { theme: 'dark' }
        };
        new ApexCharts(document.querySelector('#chart-scores'), opts).render();
    })();

    // ---- 5. TOP PRODUCTS (Horizontal Bar) ----
    (function() {
        var data = <?= $block->getChartDataJson('top_products') ?>;
        if (!data.values || !data.values.length) return;
        var opts = {
            series: [{ name: 'Recomendacoes', data: data.values }],
            chart: { type: 'bar', height: 420, background: 'transparent', foreColor: '#94a3b8',
                toolbar: { show: false }
            },
            plotOptions: { bar: { borderRadius: 4, horizontal: true, distributed: true, barHeight: '70%' } },
            colors: data.colors,
            dataLabels: { enabled: true, style: { colors: ['#f8fafc'], fontSize: '11px' } },
            xaxis: { categories: data.products },
            grid: { borderColor: '#334155' },
            legend: { show: false },
            tooltip: {
                theme: 'dark',
                y: {
                    formatter: function(val, opts) {
                        var idx = opts.dataPointIndex;
                        var pot = data.potentials[idx];
                        return val + ' recs (R$ ' + pot.toLocaleString('pt-BR', {minimumFractionDigits:2}) + ' potencial)';
                    }
                }
            }
        };
        new ApexCharts(document.querySelector('#chart-products'), opts).render();
    })();

});
</script>
