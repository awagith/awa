<script>
require(['jquery', 'Magento_Catalog/js/catalog-add-to-cart'], function($) {
    $('.rexis-item-cart').on('click', function(e) {
        e.preventDefault();
        var form = $(this).data('post');
        if (form && form.data && form.data.product) {
            catalogAddToCart.submitForm(form);
        }
    });
});
</script>
