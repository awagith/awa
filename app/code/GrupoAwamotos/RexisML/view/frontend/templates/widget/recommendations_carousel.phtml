<?php
/**
 * Widget Template - Recomendações (Carrossel)
 *
 * @var $block \GrupoAwamotos\RexisML\Block\Widget\Recommendations
 */
$recommendations = $block->getRecommendedProducts();

if (empty($recommendations) && !$block->getShowForGuest()) {
    return;
}

$customClass = $block->getCustomClass();
$uniqueId = 'rexis-carousel-' . uniqid();
?>

<div class="rexis-widget-carousel <?= $block->escapeHtmlAttr($customClass) ?>" id="<?= $uniqueId ?>">
    <?php if (empty($recommendations)): ?>
        <div class="rexis-login-prompt">
            <div class="rexis-login-content">
                <span class="rexis-lock-icon">🔒</span>
                <h3><?= __('Recomendações Personalizadas') ?></h3>
                <p><?= __('Faça login para ver produtos selecionados especialmente para você.') ?></p>
                <a href="<?= $block->escapeUrl($block->getUrl('customer/account/login')) ?>" class="rexis-login-button">
                    <?= __('Fazer Login') ?>
                </a>
            </div>
        </div>
    <?php else: ?>
        <div class="rexis-carousel-header">
            <h2 class="rexis-carousel-title">
                🎯 <?= $block->escapeHtml($block->getWidgetTitle()) ?>
                <span class="rexis-badge">IA</span>
            </h2>
            <div class="rexis-carousel-nav">
                <button type="button" class="rexis-nav-btn rexis-prev" aria-label="<?= __('Anterior') ?>">‹</button>
                <button type="button" class="rexis-nav-btn rexis-next" aria-label="<?= __('Próximo') ?>">›</button>
            </div>
        </div>

        <div class="rexis-carousel-track-wrapper">
            <div class="rexis-carousel-track">
                <?php foreach ($recommendations as $item): ?>
                    <?php
                    $product = $item['product'];
                    $score = $item['score'] * 100;
                    $classificacao = $item['classificacao'];
                    ?>
                    <div class="rexis-carousel-slide">
                        <div class="rexis-carousel-card">
                            <?php if ($classificacao === 'Oportunidade Churn'): ?>
                                <span class="rexis-item-badge badge-churn">⭐ Você Amava</span>
                            <?php elseif ($classificacao === 'Oportunidade Cross-sell' || $classificacao === 'crosssell'): ?>
                                <span class="rexis-item-badge badge-crosssell">💡 Sugerido</span>
                            <?php elseif ($classificacao === 'Oportunidade Irregular'): ?>
                                <span class="rexis-item-badge badge-irregular">🔄 Recorrente</span>
                            <?php endif; ?>

                            <?php if ($score >= 85): ?>
                                <span class="rexis-card-score"><?= round($score) ?>%</span>
                            <?php endif; ?>

                            <a href="<?= $block->escapeUrl($product->getProductUrl()) ?>">
                                <img src="<?= $block->escapeUrl($block->getProductImageUrl($product)) ?>"
                                     alt="<?= $block->escapeHtml($product->getName()) ?>"
                                     class="rexis-card-img" loading="lazy" />
                            </a>
                            <div class="rexis-card-details">
                                <h3 class="rexis-card-name">
                                    <a href="<?= $block->escapeUrl($product->getProductUrl()) ?>">
                                        <?= $block->escapeHtml($product->getName()) ?>
                                    </a>
                                </h3>
                                <div class="rexis-card-price">
                                    <?= $block->getLayout()->createBlock('Magento\Catalog\Pricing\Render')->render(
                                        'final_price', $product, ['zone' => 'item_list']
                                    ) ?>
                                </div>
                                <button type="button"
                                        class="action tocart primary rexis-card-cart"
                                        data-post='<?= $block->escapeHtml(json_encode($block->getAddToCartPostParams($product))) ?>'>
                                    <span><?= __('Adicionar') ?></span>
                                </button>
                            </div>
                        </div>
                    </div>
                <?php endforeach; ?>
            </div>
        </div>
    <?php endif; ?>
</div>

