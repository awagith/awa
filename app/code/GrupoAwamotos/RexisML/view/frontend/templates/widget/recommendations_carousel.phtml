<script>
require(['jquery'], function($) {
    var $wrapper = $('#<?= $uniqueId ?>');
    var $track = $wrapper.find('.rexis-carousel-track');
    var $slides = $track.children();
    var pos = 0;

    function getVisible() {
        var w = $wrapper.width();
        if (w <= 480) return 1;
        if (w <= 768) return 2;
        if (w <= 992) return 3;
        return 4;
    }

    function move(dir) {
        var visible = getVisible();
        var max = Math.max(0, $slides.length - visible);
        pos = Math.max(0, Math.min(max, pos + dir));
        var slideW = $slides.first().outerWidth(true);
        $track.css('transform', 'translateX(-' + (pos * slideW) + 'px)');
    }

    $wrapper.find('.rexis-prev').on('click', function() { move(-1); });
    $wrapper.find('.rexis-next').on('click', function() { move(1); });
});
</script>
