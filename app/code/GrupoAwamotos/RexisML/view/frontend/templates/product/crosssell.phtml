<?php
/** @var \GrupoAwamotos\RexisML\Block\Product\CrossSell $block */
$items = $block->getCrossSellProducts();
if (empty($items)) { return; }
$formKey = $block->getFormKey();
?>

<div class="rx-pdp-crosssell">
    <div class="rx-pdp-header">
        <h3 class="rx-pdp-title">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            <?= $block->escapeHtml(__('Clientes que compraram este produto tambem compraram')) ?>
        </h3>
        <span class="rx-pdp-powered">REXIS ML</span>
    </div>

    <div class="rx-pdp-grid">
        <?php foreach ($items as $item):
            $product = $item['product'];
            $imageUrl = $block->getProductImageUrl($product);
            $badge = $item['badge'];
            $price = $product->getFinalPrice();
        ?>
        <div class="rx-pdp-card">
            <?php if ($badge): ?>
            <span class="rx-pdp-badge <?= $block->escapeHtmlAttr($badge['class']) ?>"
                  style="background-color: <?= $block->escapeHtmlAttr($badge['color']) ?>">
                <?= $block->escapeHtml($badge['label']) ?>
            </span>
            <?php endif; ?>

            <a href="<?= $block->escapeUrl($product->getProductUrl()) ?>" class="rx-pdp-img-link">
                <?php if ($imageUrl): ?>
                    <img src="<?= $block->escapeUrl($imageUrl) ?>"
                         alt="<?= $block->escapeHtmlAttr($product->getName()) ?>"
                         loading="lazy" width="180" height="180" />
                <?php endif; ?>
            </a>

            <div class="rx-pdp-info">
                <a href="<?= $block->escapeUrl($product->getProductUrl()) ?>" class="rx-pdp-name">
                    <?= $block->escapeHtml($product->getName()) ?>
                </a>
                <?php if ($price > 0): ?>
                <div class="rx-pdp-price">
                    R$ <?= number_format((float)$price, 2, ',', '.') ?>
                </div>
                <?php endif; ?>
            </div>

            <?php if ($product->isSaleable()): ?>
            <form action="<?= $block->escapeUrl($block->getUrl('checkout/cart/add')) ?>" method="post" class="rx-pdp-form">
                <input type="hidden" name="product" value="<?= (int)$product->getId() ?>">
                <input type="hidden" name="form_key" value="<?= $block->escapeHtmlAttr($formKey) ?>">
                <input type="hidden" name="qty" value="1">
                <button type="submit" class="rx-pdp-addtocart" title="<?= $block->escapeHtmlAttr(__('Adicionar ao Carrinho')) ?>">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
                    <?= $block->escapeHtml(__('Comprar')) ?>
                </button>
            </form>
            <?php endif; ?>
        </div>
        <?php endforeach; ?>
    </div>
</div>

