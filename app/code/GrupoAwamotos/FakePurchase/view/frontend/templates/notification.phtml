<?php
$viewModel = $block->getData('view_model');
if (!$viewModel->isEnabled()) return;
?>
<div id="fake-purchase-notification" class="fake-purchase-popup <?= $block->escapeHtmlAttr($viewModel->getPosition()) ?>" style="display: none;">
    <button type="button" class="fake-purchase-close">&times;</button>
    <div class="fake-purchase-content">
        <div class="fake-purchase-image">
            <a href="#" class="product-link"><img src="" alt="" width="80" height="80"></a>
        </div>
        <div class="fake-purchase-info">
            <div class="fake-purchase-message"><span class="buyer-name"></span> de <span class="buyer-city"></span></div>
            <div class="fake-purchase-action">comprou</div>
            <a href="#" class="product-link product-name"></a>
            <div class="fake-purchase-time">há poucos minutos</div>
        </div>
    </div>
</div>
<style>
.fake-purchase-popup{position:fixed;z-index:9999;background:#fff;border-radius:8px;box-shadow:0 4px 20px rgba(0,0,0,.15);padding:15px;max-width:340px;width:calc(100% - 30px);animation:fadeInUp .4s ease;border-left:4px solid #28a745}
.fake-purchase-popup.bottom-left{bottom:20px;left:20px}.fake-purchase-popup.bottom-right{bottom:20px;right:20px}
.fake-purchase-popup.top-left{top:20px;left:20px}.fake-purchase-popup.top-right{top:20px;right:20px}
.fake-purchase-popup.hiding{animation:fadeOutDown .4s ease forwards}
@keyframes fadeInUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
@keyframes fadeOutDown{from{opacity:1;transform:translateY(0)}to{opacity:0;transform:translateY(20px)}}
.fake-purchase-close{position:absolute;top:5px;right:10px;background:0 0;border:none;font-size:20px;cursor:pointer;color:#999;padding:0}
.fake-purchase-close:hover{color:#333}
.fake-purchase-content{display:flex;align-items:flex-start;gap:12px}
.fake-purchase-image img{width:80px;height:80px;object-fit:contain;border-radius:4px;background:#f5f5f5}
.fake-purchase-info{flex:1;min-width:0}
.fake-purchase-message{font-size:13px;color:#666;margin-bottom:4px}
.fake-purchase-message .buyer-name{font-weight:600;color:#333}
.fake-purchase-action{font-size:12px;color:#28a745;font-weight:500;margin-bottom:4px}
.fake-purchase-info .product-name{font-size:14px;font-weight:600;color:#333;text-decoration:none;display:block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;margin-bottom:4px}
.fake-purchase-info .product-name:hover{color:#e74c3c}
.fake-purchase-time{font-size:11px;color:#999}
@media(max-width:480px){.fake-purchase-popup{max-width:none;left:10px!important;right:10px!important;bottom:10px!important;top:auto!important}}
</style>
<script>
(function(){
var config=<?= /* @noEscape */ $viewModel->getConfigJson() ?>;
var products=<?= /* @noEscape */ $viewModel->getProductsJson() ?>;
var cities=<?= /* @noEscape */ $viewModel->getCitiesJson() ?>;
var names=<?= /* @noEscape */ $viewModel->getNamesJson() ?>;
var popup=document.getElementById('fake-purchase-notification');
var notificationCount=0,isVisible=false,timeoutId=null;
function getRandomItem(arr){return arr[Math.floor(Math.random()*arr.length)]}
function getRandomTime(){return getRandomItem(['há poucos minutos','há 2 minutos','há 5 minutos','agora mesmo'])}
function showNotification(){
if(notificationCount>=config.maxNotifications||!products.length)return;
var product=getRandomItem(products),name=getRandomItem(names),city=getRandomItem(cities);
popup.querySelector('.buyer-name').textContent=name;
popup.querySelector('.buyer-city').textContent=city;
popup.querySelector('.product-name').textContent=product.name;
popup.querySelector('.product-name').href=product.url;
popup.querySelector('.fake-purchase-image .product-link').href=product.url;
popup.querySelector('.fake-purchase-image img').src=product.image;
popup.querySelector('.fake-purchase-time').textContent=getRandomTime();
popup.classList.remove('hiding');popup.style.display='block';isVisible=true;notificationCount++;
timeoutId=setTimeout(hideNotification,config.displayTime);
}
function hideNotification(){
if(!isVisible)return;popup.classList.add('hiding');
setTimeout(function(){popup.style.display='none';popup.classList.remove('hiding');isVisible=false;
if(notificationCount<config.maxNotifications)setTimeout(showNotification,config.delayTime);},400);
}
popup.querySelector('.fake-purchase-close').addEventListener('click',function(){clearTimeout(timeoutId);hideNotification()});
if(products.length&&names.length&&cities.length)setTimeout(showNotification,config.delayTime);
})();
</script>
