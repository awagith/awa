<?xml version="1.0"?>
<!--
/**
 * Shopping List Index Layout
 */
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <update handle="customer_account"/>
    <update handle="b2b_shared_styles"/>
    <body>
        <referenceContainer name="content">
            <block class="GrupoAwamotos\B2B\Block\Customer\ShoppingList\ListBlock" 
                   name="b2b.shopping.list.index"
                   template="GrupoAwamotos_B2B::customer/shoppinglist/index.phtml">
                <arguments>
                    <argument name="view_model" xsi:type="object">GrupoAwamotos\B2B\ViewModel\ShoppingListViewModel</argument>
                </arguments>
            </block>
        </referenceContainer>
    </body>
</page>
