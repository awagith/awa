<?php
/**
 * B2B Credit Success Badge — exibido após pedido com pagamento via crédito B2B
 *
 * @var \GrupoAwamotos\B2B\Block\Checkout\SuccessBadge $block
 */
declare(strict_types=1);
?>
<?php if ($block->shouldDisplay()): ?>
<div class="alert alert-success b2b-success-badge" role="status" aria-label="<?= $block->escapeHtmlAttr(__('Pedido via Crédito B2B')) ?>">
    <div class="media">
        <div class="media-left">
            <span class="glyphicon glyphicon-ok-circle media-object"
                  style="font-size:32px;color:#5cb85c" aria-hidden="true"></span>
        </div>
        <div class="media-body">
            <strong class="media-heading"><?= $block->escapeHtml(__('Pedido faturado via Crédito B2B')) ?></strong>
            <p class="b2b-success-badge__detail" style="margin:4px 0 0">
                <?= $block->escapeHtml(__(
                    'Pedido #%1 — Condição: %2',
                    $block->getOrderIncrementId(),
                    $block->getPaymentTermTitle()
                )) ?>
            </p>
            <p class="b2b-success-badge__note text-muted" style="font-size:12px;margin:2px 0 0">
                <?= $block->escapeHtml(__('O valor será debitado do seu limite de crédito. Acompanhe em seu Painel B2B.')) ?>
            </p>
        </div>
    </div>
</div>
