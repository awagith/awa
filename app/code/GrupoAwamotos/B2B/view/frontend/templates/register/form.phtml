<script>
require(['jquery', 'mage/url', 'domReady!'], function($, urlBuilder) {
    var cnpjValidateUrl = '<?= /* @noEscape */ $validateCnpjUrl ?>';
    var cnpjTimer = null;
    var lastCnpj = '';
    var cnpjValidated = false;
    var rateLimitTimer = null;
    var erpEmailFull = null;
    var erpEmailMasked = null;

    // CNPJ mask
    $('#cnpj').on('input', function() {
        var value = $(this).val().replace(/\D/g, '');
        if (value.length <= 14) {
            value = value.replace(/^(\d{2})(\d)/, '$1.$2');
            value = value.replace(/^(\d{2})\.(\d{3})(\d)/, '$1.$2.$3');
            value = value.replace(/\.(\d{3})(\d)/, '.$1/$2');
            value = value.replace(/(\d{4})(\d)/, '$1-$2');
            $(this).val(value);
        }

        var digits = $(this).val().replace(/\D/g, '');

        if (digits.length === 14 && digits !== lastCnpj) {
            lastCnpj = digits;
            clearTimeout(cnpjTimer);
            cnpjTimer = setTimeout(function() {
                consultarCnpj(digits);
            }, 500);
        } else if (digits.length < 14) {
            lastCnpj = '';
            resetCnpjStatus();
        }
    });

    // Phone mask
    $('#phone').on('input', function() {
        var value = $(this).val().replace(/\D/g, '');
        if (value.length <= 11) {
            if (value.length > 2) {
                value = '(' + value.substring(0, 2) + ') ' + value.substring(2);
            }
            if (value.length > 10) {
                value = value.substring(0, 10) + '-' + value.substring(10);
            }
            $(this).val(value);
        }
    });

    // CEP mask
    $('#cep').on('input', function() {
        var value = $(this).val().replace(/\D/g, '');
        if (value.length > 5) {
            value = value.substring(0, 5) + '-' + value.substring(5, 8);
        }
        $(this).val(value);
    });

    function setCnpjStatus(type, message) {
        var $status = $('#cnpj-status');
        var $feedback = $('#cnpj-feedback');
        $status.removeClass('status-loading status-success status-error').addClass('status-' + type);

        if (type === 'loading') {
            $status.html('<span class="cnpj-spinner"></span>');
            $feedback.html('<span class="feedback-loading">Consultando Receita Federal...</span>').show();
        } else if (type === 'success') {
            $status.html('<span class="cnpj-check">&#10003;</span>');
            $feedback.html('<span class="feedback-success">' + message + '</span>').show();
        } else if (type === 'error') {
            $status.html('<span class="cnpj-x">&#10007;</span>');
            $feedback.html('<span class="feedback-error">' + message + '</span>').show();
        }
    }

    function resetCnpjStatus() {
        $('#cnpj-status').removeClass('status-loading status-success status-error').html('');
        $('#cnpj-feedback').html('').hide();
        $('#cnpj-company-data').slideUp(200);
        $('#erp-email-alert').hide();
        erpEmailFull = null;
        erpEmailMasked = null;
        cnpjValidated = false;
        updateSubmitState();
    }

    function consultarCnpj(cnpj, forceRefresh) {
        setCnpjStatus('loading', '');
        cnpjValidated = false;
        updateSubmitState();

        $.ajax({
            url: cnpjValidateUrl,
            type: 'POST',
            dataType: 'json',
            data: {
                cnpj: cnpj,
                force_refresh: forceRefresh ? 1 : 0,
                form_key: $('input[name="form_key"]').val()
            },
            success: function(response) {
                // Rate-limit: show countdown timer
                if (response.rate_limited) {
                    startRateLimitCountdown(response.retry_after || 60);
                    return;
                }

                // Duplicate CNPJ: show specific message with link to login
                if (response.cnpj_duplicate) {
                    setCnpjStatus('error', response.message
                        + ' <a href="<?= $block->escapeUrl($block->getLoginUrl()) ?>" class="cnpj-login-link">Fazer login</a>');
                    $('#cnpj-company-data').slideUp(200);
                    cnpjValidated = false;
                    updateSubmitState();
                    return;
                }

                if (response.success) {
                    if (response.api_unavailable) {
                        setCnpjStatus('success', 'CNPJ válido (API indisponível, preencha manualmente).');
                        $('#cnpj-company-data').slideUp(200);
                        cnpjValidated = true;
                        updateSubmitState();
                        return;
                    }

                    setCnpjStatus('success', 'CNPJ válido - Empresa ativa');
                    cnpjValidated = true;
                    updateSubmitState();

                    // Auto-preencher campos
                    if (response.razao_social) {
                        $('#razao_social').val(response.razao_social).addClass('autofilled');
                    }
                    if (response.nome_fantasia) {
                        $('#nome_fantasia').val(response.nome_fantasia).addClass('autofilled');
                    }
                    // Telefone e email da RF: mostrar apenas como referência no card, NÃO auto-preencher
                    // Esses dados podem ser do contador/escritório, não do cliente
                    if (response.telefone) {
                        $('#cnpj-rf-telefone').text(response.telefone);
                        $('#cnpj-rf-telefone-row').show();
                    } else {
                        $('#cnpj-rf-telefone').text('Não informado na RF');
                        $('#cnpj-rf-telefone-row').show();
                    }
                    if (response.email) {
                        $('#cnpj-rf-email').text(response.email);
                        $('#cnpj-rf-email-row').show();
                    } else {
                        $('#cnpj-rf-email').text('Não informado na RF');
                        $('#cnpj-rf-email-row').show();
                    }
                    // Sempre mostrar o alerta — mesmo sem dados da RF, o cliente precisa ser lembrado
                    $('#cnpj-rf-contact-note').show();
                    if (response.cep) {
                        var cepClean = response.cep.replace(/\D/g, '');
                        if (cepClean.length > 5) {
                            cepClean = cepClean.substring(0, 5) + '-' + cepClean.substring(5, 8);
                        }
                        $('#cep').val(cepClean).addClass('autofilled');
                    }
                    if (response.logradouro) {
                        $('#logradouro').val(response.logradouro).addClass('autofilled');
                    }
                    if (response.numero) {
                        $('#numero').val(response.numero).addClass('autofilled');
                    }
                    if (response.complemento) {
                        $('#complemento').val(response.complemento).addClass('autofilled');
                    }
                    if (response.bairro) {
                        $('#bairro').val(response.bairro).addClass('autofilled');
                    }
                    if (response.municipio) {
                        $('#municipio').val(response.municipio).addClass('autofilled');
                    }
                    if (response.uf) {
                        $('#uf').val(response.uf).addClass('autofilled');
                    }

                    // Show data source indicator
                    var sourceLabel = 'Dados da Receita Federal';
                    if (response.source === 'cache') {
                        sourceLabel = 'Dados da Receita Federal (cache)';
                    }
                    $('#cnpj-source-badge').text(sourceLabel);

                    // Mostrar card de dados da empresa
                    if (response.situacao) {
                        $('#cnpj-situacao').text(response.situacao).attr('class', 'cnpj-situacao situacao-' + response.situacao.toLowerCase());
                    }
                    if (response.atividade_principal) {
                        $('#cnpj-atividade').text(response.atividade_principal);
                    }
                    // CNAE profile badge (only show for direct and adjacent)
                    if (response.cnae_profile && response.cnae_profile_label && response.cnae_profile !== 'off_profile') {
                        var $badge = $('#cnae-profile-badge');
                        $badge.text(response.cnae_profile_label)
                              .removeClass('cnae-direct cnae-adjacent')
                              .addClass('cnae-' + response.cnae_profile)
                              .show();
                    } else {
                        $('#cnae-profile-badge').hide();
                    }

                    $('#cnpj-company-data').slideDown(300);

                    // ERP email verification
                    erpEmailFull = null;
                    erpEmailMasked = null;
                    if (response.erp_found && response.erp_email) {
                        erpEmailMasked = response.erp_email;
                        erpEmailFull = response.erp_email_full || null;
                        showErpEmailAlert();
                    } else {
                        $('#erp-email-alert').hide();
                    }

                } else {
                    var errorMsg = response.message || 'CNPJ inválido';
                    // If status came from cache or shows BAIXADA, offer force-refresh
                    if (response.situacao && response.situacao.toUpperCase() !== 'ATIVA') {
                        errorMsg += ' <button type="button" class="cnpj-retry-btn" id="cnpj-force-refresh">'
                            + 'Consultar novamente (dados podem estar desatualizados)</button>';
                    }
                    setCnpjStatus('error', errorMsg);
                    $('#cnpj-company-data').slideUp(200);
                    cnpjValidated = false;
                    updateSubmitState();
                }
            },
            error: function() {
                setCnpjStatus('error', 'Erro ao consultar. Tente novamente.');
                cnpjValidated = false;
                updateSubmitState();
            }
        });
    }

    // === ERP Email Verification ===
    function showErpEmailAlert() {
        var $alert = $('#erp-email-alert');
        var currentEmail = $('#email').val().trim().toLowerCase();

        if (!erpEmailMasked) {
            $alert.hide();
            return;
        }

        if (!currentEmail) {
            $alert.html(
                '<div class="erp-alert erp-alert-info">' +
                    '<span class="erp-alert-icon">&#128269;</span>' +
                    '<div class="erp-alert-content">' +
                        '<strong>Cliente encontrado no sistema!</strong><br>' +
                        'E-mail cadastrado: <strong>' + erpEmailMasked + '</strong><br>' +
                        '<small>Informe o mesmo e-mail para vincular sua conta automaticamente.</small>' +
                    '</div>' +
                '</div>'
            ).slideDown(300);
            return;
        }

        if (erpEmailFull && currentEmail === erpEmailFull) {
            $alert.html(
                '<div class="erp-alert erp-alert-success">' +
                    '<span class="erp-alert-icon">&#10004;</span>' +
                    '<div class="erp-alert-content">' +
                        '<strong>E-mail confirmado!</strong> Sua conta sera vinculada automaticamente.' +
                    '</div>' +
                '</div>'
            ).slideDown(200);
        } else {
            $alert.html(
                '<div class="erp-alert erp-alert-warning">' +
                    '<span class="erp-alert-icon">&#9888;</span>' +
                    '<div class="erp-alert-content">' +
                        '<strong>Atencao:</strong> O e-mail cadastrado no sistema e <strong>' + erpEmailMasked + '</strong>.<br>' +
                        'O e-mail informado e diferente. Deseja continuar com <strong>' + currentEmail + '</strong>?<br>' +
                        '<small>Se possivel, use o mesmo e-mail para vincular seu historico de compras.</small>' +
                    '</div>' +
                '</div>'
            ).slideDown(200);
        }
    }

    function isValidEmail(email) {
        return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
    }

    function updateEmailCheckAlert() {
        var email = $('#email').val().trim();
        var password = $('#password').val();
        var passwordConfirmation = $('#password_confirmation').val();
        var $alert = $('#email-check-alert');

        if (passwordConfirmation.length >= 6 && password === passwordConfirmation && isValidEmail(email)) {
            $alert.html(
                '<div class="email-check-alert-box">' +
                    '<span class="email-check-alert-icon">&#9888;</span>' +
                    '<div class="email-check-alert-content">' +
                        '<strong>Confirme seu e-mail antes de criar a conta:</strong><br>' +
                        'A aprovação e a recuperação de senha serão enviadas para <strong>' + email + '</strong>.' +
                    '</div>' +
                '</div>'
            ).stop(true, true).slideDown(180);
            return;
        }

        $alert.stop(true, true).slideUp(120).empty();
    }

    $('#email').on('input blur', function() {
        if (erpEmailMasked) {
            showErpEmailAlert();
        }

        updateEmailCheckAlert();
    });

    $('#password, #password_confirmation').on('input blur', updateEmailCheckAlert);

    function startRateLimitCountdown(seconds) {
        var remaining = seconds;
        setCnpjStatus('error', 'Muitas consultas. Aguarde <strong>' + remaining + 's</strong>...');
        $('#cnpj').prop('disabled', true);

        if (rateLimitTimer) clearInterval(rateLimitTimer);
        rateLimitTimer = setInterval(function() {
            remaining--;
            if (remaining <= 0) {
                clearInterval(rateLimitTimer);
                rateLimitTimer = null;
                $('#cnpj').prop('disabled', false);
                setCnpjStatus('error', 'Você pode consultar novamente agora.');
                // Auto-retry
                var digits = $('#cnpj').val().replace(/\D/g, '');
                if (digits.length === 14) {
                    consultarCnpj(digits);
                }
            } else {
                setCnpjStatus('error', 'Muitas consultas. Aguarde <strong>' + remaining + 's</strong>...');
            }
        }, 1000);
    }

    function updateSubmitState() {
        var $submit = $('#b2b-register-form .actions-toolbar .action.submit.primary');
        var digits = $('#cnpj').val().replace(/\D/g, '');
        // Only block submit when CNPJ has 14 digits but hasn't been validated yet
        if (digits.length === 14 && !cnpjValidated) {
            $submit.prop('disabled', true).addClass('cnpj-pending');
        } else {
            $submit.prop('disabled', false).removeClass('cnpj-pending');
        }
    }

    // Force refresh: bypass cache when user clicks retry
    $(document).on('click', '#cnpj-force-refresh', function(e) {
        e.preventDefault();
        var digits = $('#cnpj').val().replace(/\D/g, '');
        if (digits.length === 14) {
            consultarCnpj(digits, true);
        }
    });

    // Remover classe autofilled ao editar campo manualmente
    $('.b2b-register-form input').on('focus', function() {
        $(this).removeClass('autofilled');
    });

    // Evitar envio duplo e sinalizar processamento
    $('#b2b-register-form').on('submit', function(e) {
        var $form = $(this);
        if ($form.data('isSubmitting')) {
            e.preventDefault();
            return false;
        }

        if (!$form.validation('isValid')) {
            return true;
        }

        $form.data('isSubmitting', true).addClass('is-submitting');
        var $submitButton = $form.find('.actions-toolbar .action.submit.primary');
        $submitButton.addClass('is-loading').prop('disabled', true);
        $submitButton.find('span').text('<?= $block->escapeJs(__('Enviando cadastro...')) ?>');
    });

    // Animate benefit items
    setTimeout(function() {
        $('.benefit-item').each(function() {
            $(this).addClass('benefit-animate');
        });
    }, 100);

    updateEmailCheckAlert();
});
</script>
