<?php
/**
 * Customer-specific ERP price comparison + tier pricing on PDP
 * @var \GrupoAwamotos\B2B\Block\Product\CustomerPriceInfo $block
 */
$priceData = $block->getCustomerPriceData();
$tierData = $block->getTierPricingData();

if (!$priceData && !$tierData) {
    return;
}
?>
<?php if ($priceData):
    $listName = $priceData['price_list_name'];
?>
<?php if ($listName): ?>
<div class="b2b-customer-price-info">
    <div class="alert alert-info alert-sm b2b-price-list-info">
        <span class="glyphicon glyphicon-info-sign" aria-hidden="true" style="margin-right:6px"></span>
        <span class="b2b-list-label"><?= $block->escapeHtml(__('Tabela: %1', $listName)) ?></span>
    </div>
</div>
<?php endif; ?>
<?php endif; ?>
<?php if ($tierData):
    $maxSavings = 0.0;
    foreach ($tierData as $_t) {
        if ((float)$_t['savings_pct'] > $maxSavings) {
            $maxSavings = (float)$_t['savings_pct'];
        }
    }
?>
<div class="b2b-tier-pricing panel panel-default">
    <div class="panel-heading">
        <h3 class="panel-title">
            <span class="glyphicon glyphicon-tags" aria-hidden="true" style="margin-right:6px"></span>
            <?= $block->escapeHtml(__('Preços por Volume')) ?>
        </h3>
    </div>
    <table class="b2b-tier-table table table-bordered table-hover table-condensed">
        <thead>
            <tr>
                <th><?= $block->escapeHtml(__('Quantidade')) ?></th>
                <th><?= $block->escapeHtml(__('Preço Unitário')) ?></th>
                <th><?= $block->escapeHtml(__('Economia')) ?></th>
            </tr>
        </thead>
        <tbody>
            <?php foreach ($tierData as $tier): ?>
            <tr<?= ((float)$tier['savings_pct'] === $maxSavings) ? ' class="success"' : '' ?>>
                <td class="b2b-tier-qty"><?= $block->escapeHtml(__('%1+ unidades', $tier['qty'])) ?></td>
                <td class="b2b-tier-price"><?= /* @noEscape */ $block->formatPrice($tier['price']) ?></td>
                <td class="b2b-tier-savings">
                    <span class="label label-success">-<?= $block->escapeHtml((string) $tier['savings_pct']) ?>%</span>
                </td>
            </tr>
            <?php endforeach; ?>
        </tbody>
    </table>
</div>
<?php endif; ?>
