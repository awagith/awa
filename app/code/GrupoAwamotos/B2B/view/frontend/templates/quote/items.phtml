<?php
/**
 * Quote Request - Cart Items List
 *
 * @var \Magento\Checkout\Block\Cart\Sidebar $block
 */
$parentBlock = $block->getLayout()->getBlock('b2b.quote.form');
$items = $parentBlock ? $parentBlock->getCartItems() : [];
$quote = $parentBlock ? $parentBlock->getQuote() : null;
?>
<?php if (!empty($items)): ?>
    <div class="panel panel-default b2b-quote-items">
        <div class="panel-heading">
            <span class="glyphicon glyphicon-shopping-cart" aria-hidden="true"></span>
            <span> <?= $block->escapeHtml(__('Itens do Carrinho')) ?></span>
        </div>
        <div class="panel-body" style="padding:0">
            <div class="table-responsive">
                <table class="table table-bordered table-hover table-condensed b2b-quote-items-table" style="margin-bottom:0">
                    <thead>
                        <tr>
                            <th class="col product"><?= $block->escapeHtml(__('Produto')) ?></th>
                            <th class="col sku"><?= $block->escapeHtml(__('SKU')) ?></th>
                            <th class="col qty"><?= $block->escapeHtml(__('Qtd')) ?></th>
                            <th class="col price"><?= $block->escapeHtml(__('Preço')) ?></th>
                            <th class="col subtotal"><?= $block->escapeHtml(__('Subtotal')) ?></th>
                        </tr>
                    </thead>
                    <tbody>
                        <?php foreach ($items as $item): ?>
                            <tr>
                                <td class="col product" data-th="<?= $block->escapeHtmlAttr(__('Produto')) ?>">
                                    <?= $block->escapeHtml($item->getName()) ?>
                                </td>
                                <td class="col sku" data-th="<?= $block->escapeHtmlAttr(__('SKU')) ?>">
                                    <?= $block->escapeHtml($item->getSku()) ?>
                                </td>
                                <td class="col qty" data-th="<?= $block->escapeHtmlAttr(__('Qtd')) ?>">
                                    <?= (int) $item->getQty() ?>
                                </td>
                                <td class="col price" data-th="<?= $block->escapeHtmlAttr(__('Preço')) ?>">
                                    R$ <?= number_format((float) $item->getPrice(), 2, ',', '.') ?>
                                </td>
                                <td class="col subtotal" data-th="<?= $block->escapeHtmlAttr(__('Subtotal')) ?>">
                                    R$ <?= number_format((float) $item->getRowTotal(), 2, ',', '.') ?>
                                </td>
                            </tr>
                        <?php endforeach; ?>
                    </tbody>
                    <?php if ($quote): ?>
                        <tfoot>
                            <tr class="active">
                                <td colspan="4" class="col total-label text-right">
                                    <strong><?= $block->escapeHtml(__('Total')) ?></strong>
                                </td>
                                <td class="col total-value text-right">
                                    <strong>R$ <?= number_format((float) $quote->getGrandTotal(), 2, ',', '.') ?></strong>
                                </td>
                            </tr>
                        </tfoot>
                    <?php endif; ?>
                </table>
            </div>
        </div>
    </div>
<?php else: ?>
    <div class="alert alert-info">
        <span><?= $block->escapeHtml(__('Seu carrinho está vazio. Adicione produtos antes de solicitar uma cotação.')) ?></span>
    </div>
<?php endif; ?>
