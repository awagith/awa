<?php
/**
 * Quote View Template
 *
 * @var \GrupoAwamotos\B2B\Block\Quote\View $block
 */
$quote = $block->getQuoteRequest();
if (!$quote) {
    return;
}
$items = $block->getItems();
$status = $quote->getStatus();
$quoteViewConfig = [
    'messages' => [
        'rejectConfirm' => (string) __('Tem certeza que deseja recusar esta cotação?'),
    ],
];
?>
<div class="b2b-quote-view b2b-page-shell"
     data-mage-init='<?= /* @noEscape */ json_encode(['GrupoAwamotos_B2B/js/quote/view' => $quoteViewConfig]) ?>'>
    <div class="quote-view-header">
        <div class="quote-view-title">
            <h1><?= $block->escapeHtml(__('Cotação #%1', $quote->getRequestId())) ?></h1>
            <span class="quote-status <?= $block->escapeHtmlAttr($block->getStatusClass($status)) ?>">
                <?= $block->escapeHtml($quote->getStatusLabel()) ?>
            </span>
        </div>
        <a href="<?= $block->escapeUrl($block->getBackUrl()) ?>" class="action back">
            <span><?= $block->escapeHtml(__('Voltar para Cotações')) ?></span>
        </a>
    </div>

    <!-- Info da Cotação -->
    <div class="quote-view-info">
        <div class="info-grid">
            <div class="info-item">
                <span class="info-label"><?= $block->escapeHtml(__('Data da Solicitação')) ?></span>
                <span class="info-value"><?= $block->escapeHtml($block->formatQuoteDate($quote->getCreatedAt())) ?></span>
            </div>
            <?php if ($quote->getExpiresAt()): ?>
                <div class="info-item">
                    <span class="info-label"><?= $block->escapeHtml(__('Válida até')) ?></span>
                    <span class="info-value <?= $quote->isExpired() ? 'expired' : '' ?>">
                        <?= $block->escapeHtml($block->formatQuoteDate($quote->getExpiresAt())) ?>
                        <?php if ($quote->isExpired()): ?>
                            <span class="expired-badge"><?= $block->escapeHtml(__('Expirada')) ?></span>
                        <?php endif; ?>
                    </span>
                </div>
            <?php endif; ?>
            <?php if ($quote->getCompanyName()): ?>
                <div class="info-item">
                    <span class="info-label"><?= $block->escapeHtml(__('Empresa')) ?></span>
                    <span class="info-value"><?= $block->escapeHtml($quote->getCompanyName()) ?></span>
                </div>
            <?php endif; ?>
            <?php if ($quote->getCnpj()): ?>
                <div class="info-item">
                    <span class="info-label"><?= $block->escapeHtml(__('CNPJ')) ?></span>
                    <span class="info-value"><?= $block->escapeHtml($quote->getCnpj()) ?></span>
                </div>
            <?php endif; ?>
            <?php if ($quote->getQuotedTotal()): ?>
                <div class="info-item highlighted">
                    <span class="info-label"><?= $block->escapeHtml(__('Valor Cotado')) ?></span>
                    <span class="info-value price"><?= /* @noEscape */ $block->formatPrice($quote->getQuotedTotal()) ?></span>
                </div>
            <?php endif; ?>
        </div>
    </div>

    <!-- Mensagem do Cliente -->
    <?php if ($quote->getMessage()): ?>
        <div class="quote-view-section">
            <h3><?= $block->escapeHtml(__('Sua Mensagem')) ?></h3>
            <div class="quote-message">
                <?= $block->escapeHtml($quote->getMessage()) ?>
            </div>
        </div>
    <?php endif; ?>

    <!-- Notas do Administrador -->
    <?php if ($quote->getAdminNotes()): ?>
        <div class="quote-view-section">
            <h3><?= $block->escapeHtml(__('Resposta do Vendedor')) ?></h3>
            <div class="quote-admin-notes">
                <?= $block->escapeHtml($quote->getAdminNotes()) ?>
            </div>
        </div>
    <?php endif; ?>

    <!-- Itens da Cotação -->
    <?php if (!empty($items)): ?>
        <div class="quote-view-section">
            <h3><?= $block->escapeHtml(__('Itens Solicitados')) ?></h3>
            <div class="table-wrapper">
                <table class="data table table-quote-items">
                    <thead>
                        <tr>
                            <th class="col product"><?= $block->escapeHtml(__('Produto')) ?></th>
                            <th class="col sku"><?= $block->escapeHtml(__('SKU')) ?></th>
                            <th class="col qty"><?= $block->escapeHtml(__('Qtd')) ?></th>
                            <th class="col price"><?= $block->escapeHtml(__('Preço Unit.')) ?></th>
                            <th class="col subtotal"><?= $block->escapeHtml(__('Subtotal')) ?></th>
                        </tr>
                    </thead>
                    <tbody>
                        <?php $total = 0; $quotedTotal = 0; $hasQuotedPrices = false; ?>
                        <?php foreach ($items as $item): ?>
                            <?php
                            $qty = (float) ($item['qty'] ?? 1);
                            $originalPrice = (float) ($item['price'] ?? $item['original_price'] ?? 0);
                            $quotedPrice = !empty($item['quoted_price']) ? (float) $item['quoted_price'] : null;
                            $displayPrice = $quotedPrice ?? $originalPrice;
                            $subtotal = $qty * $displayPrice;
                            $total += $qty * $originalPrice;
                            $quotedTotal += $subtotal;
                            if ($quotedPrice !== null) { $hasQuotedPrices = true; }
                            ?>
                            <tr>
                                <td class="col product" data-th="<?= $block->escapeHtmlAttr(__('Produto')) ?>">
                                    <?= $block->escapeHtml($item['name'] ?? '-') ?>
                                </td>
                                <td class="col sku" data-th="<?= $block->escapeHtmlAttr(__('SKU')) ?>">
                                    <?= $block->escapeHtml($item['sku'] ?? '-') ?>
                                </td>
                                <td class="col qty" data-th="<?= $block->escapeHtmlAttr(__('Qtd')) ?>">
                                    <?= (int) $qty ?>
                                </td>
                                <td class="col price" data-th="<?= $block->escapeHtmlAttr(__('Preço Unit.')) ?>">
                                    <?php if ($quotedPrice !== null && $quotedPrice !== $originalPrice): ?>
                                        <span class="original-price">R$ <?= number_format($originalPrice, 2, ',', '.') ?></span>
                                        <span class="quoted-price">R$ <?= number_format($quotedPrice, 2, ',', '.') ?></span>
                                    <?php else: ?>
                                        R$ <?= number_format($displayPrice, 2, ',', '.') ?>
                                    <?php endif; ?>
                                </td>
                                <td class="col subtotal" data-th="<?= $block->escapeHtmlAttr(__('Subtotal')) ?>">
                                    R$ <?= number_format($subtotal, 2, ',', '.') ?>
                                </td>
                            </tr>
                        <?php endforeach; ?>
                    </tbody>
                    <tfoot>
                        <tr>
                            <td colspan="4" class="col total-label">
                                <strong><?= $block->escapeHtml(__('Total Solicitado')) ?></strong>
                            </td>
                            <td class="col total-value">
                                <strong>R$ <?= number_format($total, 2, ',', '.') ?></strong>
                            </td>
                        </tr>
                        <?php if ($quote->getQuotedTotal()): ?>
                            <tr class="quoted-total">
                                <td colspan="4" class="col total-label">
                                    <strong><?= $block->escapeHtml(__('Total Cotado')) ?></strong>
                                </td>
                                <td class="col total-value">
                                    <strong class="price"><?= /* @noEscape */ $block->formatPrice($quote->getQuotedTotal()) ?></strong>
                                </td>
                            </tr>
                        <?php endif; ?>
                    </tfoot>
                </table>
            </div>
        </div>
    <?php endif; ?>

    <!-- Ações de Aceitar/Rejeitar (quando status = quoted e não expirado) -->
    <?php if ($block->canAcceptOrReject()): ?>
        <div class="quote-view-section quote-decision-section">
            <h3><?= $block->escapeHtml(__('Responder Cotação')) ?></h3>
            <p class="decision-info"><?= $block->escapeHtml(__('Analise os valores acima e escolha uma opção:')) ?></p>
            <div class="quote-decision-actions">
                <form method="post" action="<?= $block->escapeUrl($block->getAcceptUrl()) ?>" class="quote-accept-form">
                    <?= /* @noEscape */ $block->getBlockHtml('formkey') ?>
                    <button type="submit" class="action primary accept-quote-btn">
                        <span><?= $block->escapeHtml(__('Aceitar e Ir para Pagamento')) ?></span>
                    </button>
                </form>
                <form method="post" action="<?= $block->escapeUrl($block->getRejectUrl()) ?>" class="quote-reject-form"
                      data-confirm="<?= $block->escapeHtmlAttr(__('Tem certeza que deseja recusar esta cotação?')) ?>">
                    <?= /* @noEscape */ $block->getBlockHtml('formkey') ?>
                    <button type="submit" class="action secondary reject-quote-btn">
                        <span><?= $block->escapeHtml(__('Recusar Cotação')) ?></span>
                    </button>
                </form>
            </div>
        </div>
    <?php endif; ?>

    <!-- Ações gerais -->
    <div class="quote-view-actions">
        <a href="<?= $block->escapeUrl($block->getBackUrl()) ?>" class="action back">
            <span><?= $block->escapeHtml(__('Voltar')) ?></span>
        </a>
        <a href="<?= $block->escapeUrl($block->getNewQuoteUrl()) ?>" class="action primary">
            <span><?= $block->escapeHtml(__('Nova Cotação')) ?></span>
        </a>
    </div>
</div>
