<?php
/**
 * Shopping List Index Template
 *
 * @var \GrupoAwamotos\B2B\Block\Customer\ShoppingList\ListBlock $block
 * @var \GrupoAwamotos\B2B\ViewModel\ShoppingListViewModel $viewModel
 */
$viewModel = $block->getData('view_model');
$lists = $viewModel->getCustomerLists();
?>
<div class="b2b-shoppinglist-index b2b-page-shell"
     data-mage-init='<?= /* @noEscape */ json_encode(['GrupoAwamotos_B2B/js/shoppinglist/index' => new \stdClass()]) ?>'>
    <div class="block-title">
        <strong><?= $block->escapeHtml(__('Minhas Listas de Compras')) ?></strong>
    </div>

    <div class="shoppinglist-actions-top">
        <button type="button" id="btn-create-list" class="action primary" title="<?= $block->escapeHtmlAttr(__('Nova Lista')) ?>">
            <span><?= $block->escapeHtml(__('Criar Nova Lista')) ?></span>
        </button>
    </div>

    <!-- Create List Form (hidden by default) -->
    <div class="shoppinglist-create-form" id="create-list-form" style="display:none;">
        <form action="<?= $block->escapeUrl($block->getCreateUrl()) ?>" method="post"
              data-mage-init='{"validation":{}}'>
            <?= $block->getBlockHtml('formkey') ?>
            <div class="field required">
                <label for="list-name" class="label">
                    <span><?= $block->escapeHtml(__('Nome da Lista')) ?></span>
                </label>
                <div class="control">
                    <input type="text" id="list-name" name="name" required
                           data-validate="{required:true}"
                           placeholder="<?= $block->escapeHtmlAttr(__('Ex: Peças para revisão')) ?>" />
                </div>
            </div>
            <div class="field">
                <label for="list-description" class="label">
                    <span><?= $block->escapeHtml(__('Descrição (opcional)')) ?></span>
                </label>
                <div class="control">
                    <textarea id="list-description" name="description" rows="2"
                              placeholder="<?= $block->escapeHtmlAttr(__('Descrição da lista...')) ?>"></textarea>
                </div>
            </div>
            <div class="actions">
                <button type="submit" class="action primary">
                    <span><?= $block->escapeHtml(__('Criar')) ?></span>
                </button>
                <button type="button" class="action secondary" id="btn-cancel-create">
                    <span><?= $block->escapeHtml(__('Cancelar')) ?></span>
                </button>
            </div>
        </form>
    </div>

    <?php if ($lists->getSize() === 0): ?>
        <div class="message info empty">
            <span><?= $block->escapeHtml(__('Você ainda não possui listas de compras. Crie sua primeira lista para organizar seus pedidos recorrentes.')) ?></span>
        </div>
    <?php else: ?>
        <div class="shoppinglist-grid">
            <?php foreach ($lists as $list): ?>
                <?php $itemCount = $viewModel->getItemsCount((int) $list->getId()); ?>
                <div class="shoppinglist-card">
                    <div class="card-header">
                        <h3 class="list-name">
                            <a href="<?= $block->escapeUrl($block->getViewUrl((int) $list->getId())) ?>">
                                <?= $block->escapeHtml($list->getName()) ?>
                            </a>
                        </h3>
                        <?php if ($list->getData('is_default')): ?>
                            <span class="default-badge"><?= $block->escapeHtml(__('Padrão')) ?></span>
                        <?php endif; ?>
                    </div>
                    <?php if ($list->getData('description')): ?>
                        <p class="list-description"><?= $block->escapeHtml($list->getData('description')) ?></p>
                    <?php endif; ?>
                    <div class="card-meta">
                        <span class="item-count"><?= (int) $itemCount ?> <?= $block->escapeHtml(__('itens')) ?></span>
                        <span class="list-total"><?= /* @noEscape */ $viewModel->getListTotal((int) $list->getId()) ?></span>
                    </div>
                    <div class="card-actions">
                        <a href="<?= $block->escapeUrl($block->getViewUrl((int) $list->getId())) ?>" class="action view">
                            <span><?= $block->escapeHtml(__('Ver Itens')) ?></span>
                        </a>
                        <a href="<?= $block->escapeUrl($block->getAddToCartUrl((int) $list->getId())) ?>" class="action primary add-to-cart">
                            <span><?= $block->escapeHtml(__('Adicionar ao Carrinho')) ?></span>
                        </a>
                        <a href="<?= $block->escapeUrl($block->getDeleteUrl((int) $list->getId())) ?>"
                           class="action delete"
                           data-confirm="<?= $block->escapeHtmlAttr(__('Tem certeza que deseja excluir esta lista?')) ?>">
                            <span><?= $block->escapeHtml(__('Excluir')) ?></span>
                        </a>
                    </div>
                </div>
            <?php endforeach; ?>
        </div>
    <?php endif; ?>
</div>
