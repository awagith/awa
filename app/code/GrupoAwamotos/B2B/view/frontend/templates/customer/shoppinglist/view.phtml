    <script>
    require(['jquery'], function($) {
        'use strict';
        var debounceTimer;
        $('.shoppinglist-items-table').on('change', '.qty-input', function() {
            var $input = $(this);
            var itemId = $input.data('item-id');
            var updateUrl = $input.data('update-url');
            var newQty = parseInt($input.val()) || 1;
            if (newQty < 1) { newQty = 1; $input.val(1); }

            clearTimeout(debounceTimer);
            debounceTimer = setTimeout(function() {
                $.ajax({
                    url: updateUrl,
                    type: 'POST',
                    data: {
                        item_id: itemId,
                        qty: newQty,
                        form_key: $.mage.cookies.get('form_key')
                    },
                    showLoader: true,
                    success: function() {
                        location.reload();
                    },
                    error: function() {
                        alert('Erro ao atualizar quantidade.');
                    }
                });
            }, 500);
        });
    });
    </script>
