<script>
require(['jquery', 'domReady!'], function($) {
    var modal = $('#b2b-pj-suggestion-modal');
    var shown = sessionStorage.getItem('b2b_pj_modal_shown');
    
    // Show modal when PJ is selected (only once per session)
    $('#person_type').on('change', function() {
        if ($(this).val() === 'pj' && !shown) {
            modal.addClass('active');
            sessionStorage.setItem('b2b_pj_modal_shown', '1');
        }
    });
    
    // Close modal
    modal.find('.b2b-suggestion-close, .b2b-continue-btn').on('click', function() {
        modal.removeClass('active');
    });
    
    // Close on backdrop click
    modal.on('click', function(e) {
        if (e.target === this) {
            modal.removeClass('active');
        }
    });
    
    // Close on ESC
    $(document).on('keyup', function(e) {
        if (e.key === 'Escape') {
            modal.removeClass('active');
        }
    });
});
</script>
