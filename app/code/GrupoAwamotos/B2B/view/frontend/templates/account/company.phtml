<?php
/** @var \GrupoAwamotos\B2B\Block\Account\CompanyBlock $block */
$company = $block->getCompany();
$users = $block->getCompanyUsers();
$isAdmin = $block->isCompanyAdmin();
$roles = $block->getRoles();
?>
<div class="b2b-company-page">
    <div class="b2b-section-header">
        <h1><?= __('Minha Empresa') ?></h1>
        <?php if ($isAdmin): ?>
            <span class="badge badge--admin"><?= __('Administrador') ?></span>
        <?php endif; ?>
    </div>

    <?php if ($company): ?>
    <!-- Dados da Empresa -->
    <div class="company-info-grid">
        <div class="company-info-card">
            <h3><?= __('Dados Cadastrais') ?></h3>
            <dl class="company-details">
                <dt><?= __('Razão Social') ?></dt>
                <dd><?= $block->escapeHtml($company->getData('razao_social')) ?></dd>

                <?php if ($company->getData('nome_fantasia')): ?>
                <dt><?= __('Nome Fantasia') ?></dt>
                <dd><?= $block->escapeHtml($company->getData('nome_fantasia')) ?></dd>
                <?php endif; ?>

                <dt><?= __('CNPJ') ?></dt>
                <dd><?= $block->escapeHtml($company->getData('cnpj')) ?></dd>

                <?php if ($company->getData('inscricao_estadual')): ?>
                <dt><?= __('Inscrição Estadual') ?></dt>
                <dd><?= $block->escapeHtml($company->getData('inscricao_estadual')) ?></dd>
                <?php endif; ?>

                <dt><?= __('E-mail') ?></dt>
                <dd><?= $block->escapeHtml($company->getData('email')) ?></dd>

                <?php if ($company->getData('phone')): ?>
                <dt><?= __('Telefone') ?></dt>
                <dd><?= $block->escapeHtml($company->getData('phone')) ?></dd>
                <?php endif; ?>
            </dl>
        </div>
    </div>

    <!-- Usuários da Empresa -->
    <div class="company-users-section">
        <div class="company-users-header">
            <h2><?= __('Usuários da Empresa') ?> <span class="count">(<?= count($users) ?>)</span></h2>
            <?php if ($isAdmin): ?>
                <button type="button" class="btn-add-user" onclick="document.getElementById('add-user-form').classList.toggle('hidden')">
                    <?= __('+ Adicionar Usuário') ?>
                </button>
            <?php endif; ?>
        </div>

        <?php if ($isAdmin): ?>
        <div id="add-user-form" class="add-user-form hidden">
            <div class="form-row">
                <input type="email" id="new-user-email" placeholder="<?= __('E-mail do cliente Magento') ?>" class="input-text" />
                <select id="new-user-role" class="select">
                    <?php foreach ($roles as $roleCode => $roleLabel): ?>
                        <option value="<?= $block->escapeHtmlAttr($roleCode) ?>"><?= $block->escapeHtml($roleLabel) ?></option>
                    <?php endforeach; ?>
                </select>
                <button type="button" class="btn-save" onclick="addCompanyUser()">
                    <?= __('Adicionar') ?>
                </button>
            </div>
            <p class="form-note"><?= __('O e-mail precisa estar cadastrado na loja.') ?></p>
        </div>
        <?php endif; ?>

        <table class="data table table-company-users">
            <thead>
                <tr>
                    <th><?= __('Nome') ?></th>
                    <th><?= __('E-mail') ?></th>
                    <th><?= __('Papel') ?></th>
                    <th><?= __('Status') ?></th>
                    <?php if ($isAdmin): ?>
                        <th><?= __('Ações') ?></th>
                    <?php endif; ?>
                </tr>
            </thead>
            <tbody>
                <?php foreach ($users as $user): ?>
                <tr>
                    <td data-th="<?= __('Nome') ?>"><?= $block->escapeHtml($user['name']) ?></td>
                    <td data-th="<?= __('E-mail') ?>"><?= $block->escapeHtml($user['email']) ?></td>
                    <td data-th="<?= __('Papel') ?>">
                        <span class="role-badge role-badge--<?= $block->escapeHtmlAttr($user['role']) ?>">
                            <?= $block->escapeHtml($user['role_label']) ?>
                        </span>
                    </td>
                    <td data-th="<?= __('Status') ?>">
                        <span class="status-dot <?= $user['is_active'] ? 'status-dot--active' : 'status-dot--inactive' ?>"></span>
                        <?= $user['is_active'] ? __('Ativo') : __('Inativo') ?>
                    </td>
                    <?php if ($isAdmin): ?>
                    <td data-th="<?= __('Ações') ?>" class="user-actions">
                        <select onchange="updateUserRole(<?= (int)$user['customer_id'] ?>, this.value)" class="select select-sm">
                            <?php foreach ($roles as $roleCode => $roleLabel): ?>
                                <option value="<?= $block->escapeHtmlAttr($roleCode) ?>" <?= $user['role'] === $roleCode ? 'selected' : '' ?>>
                                    <?= $block->escapeHtml($roleLabel) ?>
                                </option>
                            <?php endforeach; ?>
                        </select>
                        <button type="button" class="btn-remove"
                                onclick="removeCompanyUser(<?= (int)$user['customer_id'] ?>)">
                            <?= __('Remover') ?>
                        </button>
                    </td>
                    <?php endif; ?>
                </tr>
                <?php endforeach; ?>
            </tbody>
        </table>
    </div>
    <?php else: ?>
        <p class="empty-message"><?= __('Nenhuma empresa vinculada à sua conta. Entre em contato com o suporte.') ?></p>
    <?php endif; ?>
</div>

<script>
var manageUrl = '<?= $block->escapeJs($block->getManageUserUrl()) ?>';

function addCompanyUser() {
    var email = document.getElementById('new-user-email').value;
    var role = document.getElementById('new-user-role').value;
    if (!email) { alert('<?= __('Informe o e-mail.') ?>'); return; }

    manageUserAction('add', 0, role, { email: email });
}

function updateUserRole(customerId, role) {
    manageUserAction('update_role', customerId, role);
}

function removeCompanyUser(customerId) {
    if (!confirm('<?= __('Remover este usuário da empresa?') ?>')) return;
    manageUserAction('remove', customerId);
}

function manageUserAction(action, customerId, role, extra) {
    var params = {
        action: action,
        customer_id: customerId,
        role: role || '',
        form_key: window.FORM_KEY || ''
    };
    if (extra) Object.assign(params, extra);

    fetch(manageUrl, {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-Requested-With': 'XMLHttpRequest' },
        body: new URLSearchParams(params)
    })
    .then(r => r.json())
    .then(data => { alert(data.message); if (data.success) location.reload(); })
    .catch(() => alert('<?= __('Erro. Tente novamente.') ?>'));
}
</script>

