.reorder-card__info { display: flex; align-items: center; gap: 12px; }
.reorder-card__info strong { font-size: 15px; }
.reorder-card__date { color: #999; font-size: 13px; }
.reorder-card__total { font-size: 18px; font-weight: 700; color: #1976d2; }
.reorder-items { width: 100%; border-collapse: collapse; }
.reorder-items th { text-align: left; padding: 8px 20px; font-size: 12px; text-transform: uppercase; color: #999; border-bottom: 1px solid #eee; }
.reorder-items td { padding: 10px 20px; border-bottom: 1px solid #f5f5f5; font-size: 14px; }
.col-select { width: 40px; text-align: center; }
