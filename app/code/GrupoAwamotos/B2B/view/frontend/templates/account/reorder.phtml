<?php
/** @var \GrupoAwamotos\B2B\Block\Account\Reorder $block */
$orders = $block->getRecentOrders(10);

/**
 * Mapeia status Magento → sufixo da classe b2b-label-*
 */
$orderStatusMap = [
    'complete'   => 'converted',
    'processing' => 'pending',
    'pending'    => 'pending',
    'canceled'   => 'rejected',
    'closed'     => 'rejected',
];
?>
<div class="b2b-reorder-page b2b-page-shell"
     data-mage-init='<?= /* @noEscape */ json_encode(['GrupoAwamotos_B2B/js/account/reorder' => new \stdClass()]) ?>'>

    <!-- ── Header ──────────────────────────────────────────────────────── -->
    <div class="page-title-wrapper">
        <h1 class="page-title">
            <span class="base"><?= $block->escapeHtml(__('Repetir Pedido')) ?></span>
        </h1>
    </div>
    <p class="lead text-muted">
        <?= $block->escapeHtml(__('Selecione um pedido anterior para adicionar os produtos ao carrinho com preços atualizados do seu grupo.')) ?>
    </p>

    <?php if ($orders->getSize() > 0): ?>

        <?php foreach ($orders as $order): ?>
            <?php
            $rawStatus      = $order->getStatus();
            $labelSuffix    = $orderStatusMap[$rawStatus] ?? 'draft';
            ?>

            <!-- ── Painel por pedido ─────────────────────────────────────── -->
            <div class="panel panel-default">

                <!-- cabeçalho do painel -->
                <div class="panel-heading">
                    <h3 class="panel-title">
                        <?= $block->escapeHtml(__('Pedido #%1', $order->getIncrementId())) ?>
                        <span class="reorder-card__date text-muted">
                            &mdash; <?= $block->escapeHtml(date('d/m/Y', strtotime($order->getCreatedAt()))) ?>
                        </span>
                        <span class="label b2b-status b2b-label-<?= $block->escapeHtmlAttr($labelSuffix) ?>">
                            <?= $block->escapeHtml($order->getStatusLabel()) ?>
                        </span>
                        <span class="pull-right" style="font-weight:bold;">
                            <?= /* @noEscape */ $block->formatPrice((float) $order->getGrandTotal()) ?>
                        </span>
                    </h3>
                </div>

                <!-- o <form> envolve body + footer para que os checkboxes sejam enviados -->
                <form method="post" action="<?= $block->escapeUrl($block->getReorderUrl()) ?>">
                    <?= /* @noEscape */ $block->getBlockHtml('formkey') ?>
                    <input type="hidden" name="order_id" value="<?= (int) $order->getId() ?>" />

                    <!-- itens do pedido -->
                    <div class="panel-body" style="padding-bottom:0;">
                        <div class="table-responsive">
                            <table class="table table-striped table-hover b2b-responsive-table">
                                <thead>
                                    <tr>
                                        <th class="col-xs-1 text-center">
                                            <input type="checkbox"
                                                   checked
                                                   class="js-reorder-toggle-all"
                                                   data-order-id="<?= (int) $order->getId() ?>" />
                                        </th>
                                        <th><?= $block->escapeHtml(__('Produto')) ?></th>
                                        <th><?= $block->escapeHtml(__('SKU')) ?></th>
                                        <th><?= $block->escapeHtml(__('Qtd')) ?></th>
                                        <th><?= $block->escapeHtml(__('Preço Original')) ?></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <?php foreach ($order->getAllVisibleItems() as $item): ?>
                                        <tr>
                                            <td class="text-center">
                                                <input type="checkbox"
                                                       name="items[]"
                                                       value="<?= (int) $item->getItemId() ?>"
                                                       checked
                                                       class="js-reorder-item-check"
                                                       data-order-id="<?= (int) $order->getId() ?>" />
                                            </td>
                                            <td data-th="<?= $block->escapeHtmlAttr(__('Produto')) ?>">
                                                <?= $block->escapeHtml($item->getName()) ?>
                                            </td>
                                            <td data-th="<?= $block->escapeHtmlAttr(__('SKU')) ?>">
                                                <?= $block->escapeHtml($item->getSku()) ?>
                                            </td>
                                            <td data-th="<?= $block->escapeHtmlAttr(__('Qtd')) ?>">
                                                <?= (int) $item->getQtyOrdered() ?>
                                            </td>
                                            <td data-th="<?= $block->escapeHtmlAttr(__('Preço')) ?>">
                                                <?= /* @noEscape */ $block->formatPrice((float) $item->getPrice()) ?>
                                            </td>
                                        </tr>
                                    <?php endforeach; ?>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- rodapé com ação -->
                    <div class="panel-footer">
                        <div class="b2b-reorder-footer-row">
                            <button type="submit" class="btn btn-primary">
                                <span class="glyphicon glyphicon-shopping-cart"></span>
                                <?= $block->escapeHtml(__('Adicionar ao Carrinho')) ?>
                            </button>
                            <span class="text-muted small" style="margin-left:12px;">
                                <?= $block->escapeHtml(__('Preços atualizados conforme grupo B2B')) ?>
                            </span>
                        </div>
                    </div>

                </form>
            </div><!-- /.panel -->

        <?php endforeach; ?>

    <?php else: ?>

        <!-- ── Estado vazio ─────────────────────────────────────────────── -->
        <div class="alert alert-info">
            <span class="glyphicon glyphicon-info-sign"></span>
            <?= $block->escapeHtml(__('Nenhum pedido encontrado para reordenar.')) ?>
        </div>

    <?php endif; ?>
</div>
