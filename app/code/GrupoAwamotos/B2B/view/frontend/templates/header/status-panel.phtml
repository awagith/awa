<?php
/**
 * B2B Unified Header Status Panel
 * Replaces separate badge + welcome message with a single integrated component.
 *
 * B2B logged-in: Trigger (name + company + tier) + Dropdown (stats, actions, logout)
 * Guest: Registration CTA + top.links kept visible for Login
 *
 * @var \GrupoAwamotos\B2B\Block\Header\StatusPanel $block
 */
?>

<?php if ($block->shouldDisplay()): ?>
<?php $data = $block->getCustomerData(); ?>
<?php
    $company = trim((string) ($data['company'] ?? ''));
    $firstName = $block->escapeHtml($data['first_name']);
    $badgeColor = $block->escapeHtmlAttr($data['group_badge']['color']);
    $badgeIcon = $block->escapeHtmlAttr($data['group_badge']['icon']);
    $groupName = $block->escapeHtml($data['group_name']);
    $discount = (int) $data['discount'];
    $logoutUrl = $block->getUrl('customer/account/logout');
?>
<div class="b2b-status-panel"
     data-mage-init='{"GrupoAwamotos_B2B/js/header-status-panel": {}}'
     role="region"
     aria-label="<?= $block->escapeHtmlAttr(__('Painel B2B')) ?>">

    <!-- Trigger Button -->
    <button type="button"
            class="b2b-status-trigger"
            aria-expanded="false"
            aria-controls="b2b-status-dropdown"
            aria-haspopup="true">
        <span class="status-badge" style="--badge-color: <?= $badgeColor ?>">
            <i class="fa fa-<?= $badgeIcon ?>" aria-hidden="true"></i>
        </span>
        <span class="status-info">
            <span class="status-greeting"><?= $block->escapeHtml(__('Ol&aacute;, %1', $firstName)) ?></span>
            <?php if ($company): ?>
            <span class="status-company"><?= $block->escapeHtml($company) ?></span>
            <?php endif; ?>
            <span class="status-group">
                <?= $groupName ?>
                <?php if ($discount > 0): ?>
                <span class="status-discount">-<?= $discount ?>%</span>
                <?php endif; ?>
            </span>
        </span>
        <i class="fa fa-chevron-down status-arrow" aria-hidden="true"></i>
    </button>

    <!-- Dropdown Panel -->
    <div id="b2b-status-dropdown" class="b2b-status-dropdown" role="menu" aria-hidden="true">
        <div class="dropdown-inner">

            <!-- User Info Section -->
            <div class="dropdown-section user-section">
                <div class="user-avatar" style="--avatar-color: <?= $badgeColor ?>">
                    <?= $block->escapeHtml(mb_strtoupper(mb_substr($data['first_name'], 0, 1))) ?>
                </div>
                <div class="user-details">
                    <span class="user-name"><?= $block->escapeHtml($data['full_name']) ?></span>
                    <?php if ($company): ?>
                    <span class="user-company">
                        <i class="fa fa-building-o" aria-hidden="true"></i>
                        <?= $block->escapeHtml($company) ?>
                    </span>
                    <?php endif; ?>
                    <span class="user-tier" style="--tier-color: <?= $badgeColor ?>">
                        <i class="fa fa-<?= $badgeIcon ?>" aria-hidden="true"></i>
                        <?= $groupName ?>
                        <?php if ($discount > 0): ?>
                        <span class="badge" style="background-color:#b73337;margin-left:4px">-<?= $discount ?>%</span>
                        <?php endif; ?>
                    </span>
                </div>
            </div>

            <!-- Stats Section -->
            <?php if ($discount > 0 || $data['credit_limit'] > 0): ?>
            <hr style="margin:8px 0">
            <div class="dropdown-section stats-section">
                <div class="list-group" style="margin-bottom:0">
                    <?php if ($discount > 0): ?>
                    <div class="list-group-item">
                        <i class="fa fa-percent" aria-hidden="true"></i>
                        <?= $block->escapeHtml(__('Desconto Exclusivo')) ?>
                        <span class="badge pull-right" style="background-color:#b73337">-<?= $discount ?>%</span>
                    </div>
                    <?php endif; ?>
                    <?php if ($data['credit_limit'] > 0): ?>
                    <div class="list-group-item">
                        <i class="fa fa-credit-card" aria-hidden="true"></i>
                        <?= $block->escapeHtml(__('Cr&eacute;dito Dispon&iacute;vel')) ?>
                        <span class="badge pull-right"><?= /* @noEscape */ $block->formatPrice($data['credit_available']) ?></span>
                        <div class="credit-bar" style="margin-top:6px">
                            <?php $creditPercent = $data['credit_limit'] > 0 ? ($data['credit_available'] / $data['credit_limit']) * 100 : 0; ?>
                            <div class="progress" style="margin-bottom:0;height:6px">
                                <div class="progress-bar progress-bar-success"
                                     style="width:<?= min(100, (int) $creditPercent) ?>%"
                                     role="progressbar"
                                     aria-valuenow="<?= min(100, (int) $creditPercent) ?>"
                                     aria-valuemin="0"
                                     aria-valuemax="100"></div>
                            </div>
                        </div>
                    </div>
                    <?php endif; ?>
                </div>
            </div>
            <?php endif; ?>

            <!-- Quick Actions -->
            <hr style="margin:8px 0">
            <div class="dropdown-section actions-section">
                <span class="section-title"><?= $block->escapeHtml(__('Acesso R&aacute;pido')) ?></span>
                <nav class="quick-actions" aria-label="<?= $block->escapeHtmlAttr(__('A&ccedil;&otilde;es r&aacute;pidas B2B')) ?>">
                    <?php foreach ($block->getQuickActions() as $action): ?>
                    <a href="<?= $block->escapeUrl($action['url']) ?>"
                       class="btn btn-default btn-xs btn-block quick-action-link"
                       style="text-align:left;margin-bottom:4px">
                        <i class="fa fa-<?= $block->escapeHtmlAttr($action['icon']) ?>" aria-hidden="true"></i>
                        <span><?= $block->escapeHtml($action['label']) ?></span>
                    </a>
                    <?php endforeach; ?>
                </nav>
            </div>

            <!-- Footer -->
            <hr style="margin:8px 0">
            <div class="dropdown-footer">
                <a href="<?= $block->escapeUrl($block->getUrl('b2b/account/dashboard')) ?>"
                   class="btn btn-default btn-xs btn-block"
                   style="margin-bottom:6px">
                    <i class="fa fa-user-circle-o" aria-hidden="true"></i>
                    <?= $block->escapeHtml(__('Minha Conta')) ?>
                </a>
                <a href="<?= $block->escapeUrl($logoutUrl) ?>"
                   class="btn btn-danger btn-xs btn-block"
                   data-post='<?= $block->escapeHtmlAttr(json_encode([
                       'action' => $logoutUrl,
                       'data' => ['uenc' => '']
                   ])) ?>'>
                    <i class="fa fa-sign-out" aria-hidden="true"></i>
                    <?= $block->escapeHtml(__('Sair')) ?>
                </a>
            </div>
        </div>
    </div>
</div>

<?php elseif ($block->shouldShowRegistrationCTA()): ?>
<!-- B2B Registration CTA for Guests -->
<div class="b2b-register-cta">
    <a href="<?= $block->escapeUrl($block->getRegistrationUrl()) ?>"
       class="b2b-register-btn"
       title="<?= $block->escapeHtmlAttr(__('Cadastre-se como cliente B2B e tenha acesso a descontos exclusivos')) ?>">
        <i class="fa fa-building" aria-hidden="true"></i>
        <span class="btn-text">
            <span class="btn-label"><?= $block->escapeHtml(__('Atacado')) ?></span>
            <span class="btn-sublabel"><?= $block->escapeHtml(__('Cadastre-se')) ?></span>
        </span>
    </a>
</div>
<?php endif; ?>
