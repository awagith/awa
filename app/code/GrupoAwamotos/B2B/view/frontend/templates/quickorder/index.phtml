<?php
/**
 * Quick Order Template
 * Allows B2B customers to add multiple products by SKU
 *
 * @var \Magento\Framework\View\Element\Template $block
 */
$addUrl = $block->getUrl('b2b/quickorder/add');
$quickOrderConfig = [
    'addUrl' => $addUrl,
    'initialRows' => 5,
    'messages' => [
        'addToCart' => (string) __('Adicionar ao Carrinho'),
        'processing' => (string) __('Processando...'),
        'skuRequired' => (string) __('Informe pelo menos um SKU.'),
        'requestError' => (string) __('Erro ao processar pedido. Tente novamente.'),
        'removeRow' => (string) __('Remover'),
        'skuPlaceholder' => (string) __('Ex: SKU-001'),
    ],
];
?>
<div class="b2b-quickorder b2b-page-shell"
     data-mage-init='<?= /* @noEscape */ json_encode(['GrupoAwamotos_B2B/js/quickorder' => $quickOrderConfig]) ?>'>
    <div class="block-title">
        <strong><?= $block->escapeHtml(__('Pedido Rápido')) ?></strong>
        <p class="quickorder-description">
            <?= $block->escapeHtml(__('Adicione produtos rapidamente informando o SKU e a quantidade desejada.')) ?>
        </p>
    </div>

    <div class="quickorder-form-container" id="quickorder-container">
        <div class="quickorder-rows" id="quickorder-rows">
            <div class="quickorder-header-row">
                <span class="col-sku"><?= $block->escapeHtml(__('SKU')) ?></span>
                <span class="col-qty"><?= $block->escapeHtml(__('Qtd')) ?></span>
                <span class="col-action"></span>
            </div>
            <!-- Rows will be populated by JS -->
        </div>

        <div class="quickorder-add-row">
            <button type="button" id="quickorder-add-row" class="action secondary">
                <span>+ <?= $block->escapeHtml(__('Adicionar Linha')) ?></span>
            </button>
        </div>

        <div class="quickorder-results" id="quickorder-results" style="display:none;">
            <div class="results-success" id="quickorder-success"></div>
            <div class="results-errors" id="quickorder-errors"></div>
        </div>

        <div class="quickorder-actions">
            <button type="button" id="quickorder-submit" class="action primary">
                <span><?= $block->escapeHtml(__('Adicionar ao Carrinho')) ?></span>
            </button>
            <a href="<?= $block->escapeUrl($block->getUrl('checkout/cart')) ?>" class="action secondary">
                <span><?= $block->escapeHtml(__('Ver Carrinho')) ?></span>
            </a>
        </div>
    </div>
</div>
