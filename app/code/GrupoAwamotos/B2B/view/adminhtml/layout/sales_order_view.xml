<?xml version="1.0"?>
<!--
/**
 * Admin Order View Layout - B2B PO Number Display
 * P0-1: Shows Purchase Order Number in order info section
 */
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceContainer name="order_info">
            <block class="GrupoAwamotos\B2B\Block\Adminhtml\Order\View\PoNumber"
                   name="b2b.order.po.number"
                   template="GrupoAwamotos_B2B::order/view/po-number.phtml"
                   after="order_info"/>
        </referenceContainer>
    </body>
</page>
