<?php
/**
 * @var \GrupoAwamotos\B2B\Block\Adminhtml\Quote\View $block
 */
$quote = $block->getQuoteRequest();
if (!$quote) {
    return;
}
$items = $block->getItems();
$status = $quote->getStatus();
?>
<div class="admin__page-section">
    <div class="admin__page-section-title">
        <span class="title"><?= $block->escapeHtml(__('Cotação #%1', $quote->getRequestId())) ?></span>
        <div class="actions">
            <?php if (in_array($status, ['pending', 'processing'])): ?>
            <a href="<?= $block->escapeUrl($block->getRespondUrl()) ?>" class="action-default scalable action-secondary">
                <span><?= $block->escapeHtml(__('Responder Cotação')) ?></span>
            </a>
            <?php endif; ?>
            <a href="<?= $block->escapeUrl($block->getBackUrl()) ?>" class="action-default scalable back">
                <span><?= $block->escapeHtml(__('Voltar')) ?></span>
            </a>
        </div>
    </div>

    <div class="admin__page-section-content">
        <div class="admin__page-section-item-content">
            <table class="admin__table-secondary">
                <tr>
                    <th><?= $block->escapeHtml(__('Cliente')) ?></th>
                    <td><?= $block->escapeHtml($block->getCustomerName()) ?></td>
                </tr>
                <tr>
                    <th><?= $block->escapeHtml(__('Status')) ?></th>
                    <td>
                        <span class="<?= $block->escapeHtmlAttr($block->getStatusCssClass($status)) ?>">
                            <span><?= $block->escapeHtml($block->getStatusLabel($status)) ?></span>
                        </span>
                    </td>
                </tr>
                <tr>
                    <th><?= $block->escapeHtml(__('Data da Solicitação')) ?></th>
                    <td><?= $block->escapeHtml($quote->getCreatedAt()) ?></td>
                </tr>
                <?php if ($quote->getMessage()): ?>
                <tr>
                    <th><?= $block->escapeHtml(__('Mensagem do Cliente')) ?></th>
                    <td><?= $block->escapeHtml($quote->getMessage()) ?></td>
                </tr>
                <?php endif; ?>
            </table>
        </div>
    </div>
</div>

<?php if (!empty($items)): ?>
<div class="admin__page-section" style="margin-top: 20px;">
    <div class="admin__page-section-title">
        <span class="title"><?= $block->escapeHtml(__('Itens da Cotação')) ?></span>
    </div>
    <div class="admin__page-section-content">
        <table class="data-grid">
            <thead>
                <tr>
                    <th class="data-grid-th"><?= $block->escapeHtml(__('SKU')) ?></th>
                    <th class="data-grid-th"><?= $block->escapeHtml(__('Produto')) ?></th>
                    <th class="data-grid-th"><?= $block->escapeHtml(__('Qtd')) ?></th>
                    <th class="data-grid-th"><?= $block->escapeHtml(__('Preço Unit.')) ?></th>
                    <th class="data-grid-th"><?= $block->escapeHtml(__('Subtotal')) ?></th>
                </tr>
            </thead>
            <tbody>
                <?php foreach ($items as $item): ?>
                <tr>
                    <td><?= $block->escapeHtml($item['sku'] ?? '-') ?></td>
                    <td><?= $block->escapeHtml($item['name'] ?? '-') ?></td>
                    <td><?= $block->escapeHtml($item['qty'] ?? '1') ?></td>
                    <td><?= $block->escapeHtml($block->formatPrice((float)($item['price'] ?? 0))) ?></td>
                    <td><?= $block->escapeHtml($block->formatPrice((float)($item['price'] ?? 0) * (float)($item['qty'] ?? 1))) ?></td>
                </tr>
                <?php endforeach; ?>
            </tbody>
        </table>
    </div>
</div>
<?php endif; ?>
