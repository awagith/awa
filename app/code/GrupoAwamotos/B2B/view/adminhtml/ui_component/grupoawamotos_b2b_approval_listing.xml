<?xml version="1.0"?>
<!--
/**
 * B2B Order Approval Listing Grid
 */
-->
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">grupoawamotos_b2b_approval_listing.grupoawamotos_b2b_approval_listing_data_source</item>
        </item>
    </argument>

    <settings>
        <spinner>grupoawamotos_b2b_approval_columns</spinner>
        <deps>
            <dep>grupoawamotos_b2b_approval_listing.grupoawamotos_b2b_approval_listing_data_source</dep>
        </deps>
    </settings>

    <dataSource name="grupoawamotos_b2b_approval_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <storageConfig>
                <param name="indexField" xsi:type="string">approval_id</param>
            </storageConfig>
            <updateUrl path="mui/index/render"/>
        </settings>
        <aclResource>GrupoAwamotos_B2B::order_approval</aclResource>
        <dataProvider class="Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider"
                      name="grupoawamotos_b2b_approval_listing_data_source">
            <settings>
                <requestFieldName>id</requestFieldName>
                <primaryFieldName>approval_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>

    <listingToolbar name="listing_top">
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filterSearch name="fulltext"/>
        <filters name="listing_filters"/>
        <paging name="listing_paging"/>
    </listingToolbar>

    <columns name="grupoawamotos_b2b_approval_columns">
        <selectionsColumn name="ids">
            <settings>
                <indexField>approval_id</indexField>
            </settings>
        </selectionsColumn>

        <column name="approval_id">
            <settings>
                <filter>textRange</filter>
                <label translate="true">ID</label>
                <sorting>desc</sorting>
            </settings>
        </column>

        <column name="order_id">
            <settings>
                <filter>textRange</filter>
                <label translate="true">ID do Pedido</label>
            </settings>
        </column>

        <column name="customer_id">
            <settings>
                <filter>textRange</filter>
                <label translate="true">ID do Cliente</label>
            </settings>
        </column>

        <column name="required_level" component="Magento_Ui/js/grid/columns/select">
            <settings>
                <options class="GrupoAwamotos\B2B\Model\Config\Source\ApprovalLevel"/>
                <filter>select</filter>
                <dataType>select</dataType>
                <label translate="true">Nível Requerido</label>
            </settings>
        </column>

        <column name="current_level" component="Magento_Ui/js/grid/columns/select">
            <settings>
                <options class="GrupoAwamotos\B2B\Model\Config\Source\ApprovalLevel"/>
                <filter>select</filter>
                <dataType>select</dataType>
                <label translate="true">Nível Atual</label>
            </settings>
        </column>

        <column name="status" component="Magento_Ui/js/grid/columns/select">
            <settings>
                <options class="GrupoAwamotos\B2B\Model\Config\Source\ApprovalStatus"/>
                <filter>select</filter>
                <dataType>select</dataType>
                <label translate="true">Status</label>
            </settings>
        </column>

        <column name="order_total" class="Magento\Sales\Ui\Component\Listing\Column\Price">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Valor do Pedido</label>
            </settings>
        </column>

        <column name="created_at" class="Magento\Ui\Component\Listing\Columns\Date" component="Magento_Ui/js/grid/columns/date">
            <settings>
                <filter>dateRange</filter>
                <dataType>date</dataType>
                <label translate="true">Data da Solicitação</label>
            </settings>
        </column>

        <column name="updated_at" class="Magento\Ui\Component\Listing\Columns\Date" component="Magento_Ui/js/grid/columns/date">
            <settings>
                <filter>dateRange</filter>
                <dataType>date</dataType>
                <label translate="true">Última Atualização</label>
            </settings>
        </column>

        <actionsColumn name="actions" class="GrupoAwamotos\B2B\Ui\Component\Listing\Column\ApprovalActions">
            <settings>
                <indexField>approval_id</indexField>
            </settings>
        </actionsColumn>
    </columns>
</listing>
