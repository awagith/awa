<?xml version="1.0"?>
<!--
/**
 * B2B Quote Request Listing Grid
 */
-->
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">grupoawamotos_b2b_quote_listing.grupoawamotos_b2b_quote_listing_data_source</item>
        </item>
    </argument>
    
    <settings>
        <spinner>grupoawamotos_b2b_quote_columns</spinner>
        <deps>
            <dep>grupoawamotos_b2b_quote_listing.grupoawamotos_b2b_quote_listing_data_source</dep>
        </deps>
    </settings>
    
    <dataSource name="grupoawamotos_b2b_quote_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <storageConfig>
                <param name="indexField" xsi:type="string">request_id</param>
            </storageConfig>
            <updateUrl path="mui/index/render"/>
        </settings>
        <aclResource>GrupoAwamotos_B2B::quotes</aclResource>
        <dataProvider class="GrupoAwamotos\B2B\Ui\DataProvider\QuoteRequestDataProvider" name="grupoawamotos_b2b_quote_listing_data_source">
            <settings>
                <requestFieldName>id</requestFieldName>
                <primaryFieldName>request_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    
    <listingToolbar name="listing_top">
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filterSearch name="fulltext"/>
        <filters name="listing_filters"/>
        <paging name="listing_paging"/>
    </listingToolbar>
    
    <columns name="grupoawamotos_b2b_quote_columns">
        <selectionsColumn name="ids">
            <settings>
                <indexField>request_id</indexField>
            </settings>
        </selectionsColumn>
        
        <column name="request_id">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Nº</label>
                <sorting>desc</sorting>
            </settings>
        </column>
        
        <column name="customer_name">
            <settings>
                <filter>text</filter>
                <label translate="true">Cliente</label>
            </settings>
        </column>
        
        <column name="customer_email">
            <settings>
                <filter>text</filter>
                <label translate="true">E-mail</label>
            </settings>
        </column>
        
        <column name="company_name">
            <settings>
                <filter>text</filter>
                <label translate="true">Empresa</label>
            </settings>
        </column>
        
        <column name="status" component="Magento_Ui/js/grid/columns/select">
            <settings>
                <options class="GrupoAwamotos\B2B\Model\Config\Source\QuoteStatus"/>
                <filter>select</filter>
                <dataType>select</dataType>
                <label translate="true">Status</label>
            </settings>
        </column>
        
        <column name="quoted_total" class="Magento\Sales\Ui\Component\Listing\Column\Price">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Valor</label>
            </settings>
        </column>
        
        <column name="created_at" class="Magento\Ui\Component\Listing\Columns\Date" component="Magento_Ui/js/grid/columns/date">
            <settings>
                <filter>dateRange</filter>
                <dataType>date</dataType>
                <label translate="true">Criado em</label>
            </settings>
        </column>
        
        <column name="expires_at" class="Magento\Ui\Component\Listing\Columns\Date" component="Magento_Ui/js/grid/columns/date">
            <settings>
                <filter>dateRange</filter>
                <dataType>date</dataType>
                <label translate="true">Validade</label>
            </settings>
        </column>
        
        <actionsColumn name="actions" class="GrupoAwamotos\B2B\Ui\Component\Listing\Column\QuoteActions">
            <settings>
                <indexField>request_id</indexField>
            </settings>
        </actionsColumn>
    </columns>
</listing>
