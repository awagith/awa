<?xml version="1.0"?>
<!--
/**
 * B2B Customer Listing Grid
 */
-->
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">grupoawamotos_b2b_customer_listing.grupoawamotos_b2b_customer_listing_data_source</item>
        </item>
    </argument>
    
    <settings>
        <spinner>grupoawamotos_b2b_customer_columns</spinner>
        <deps>
            <dep>grupoawamotos_b2b_customer_listing.grupoawamotos_b2b_customer_listing_data_source</dep>
        </deps>
    </settings>
    
    <dataSource name="grupoawamotos_b2b_customer_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <storageConfig>
                <param name="indexField" xsi:type="string">entity_id</param>
            </storageConfig>
            <updateUrl path="mui/index/render"/>
        </settings>
        <aclResource>GrupoAwamotos_B2B::customer_approval</aclResource>
        <dataProvider class="Magento\Customer\Ui\Component\DataProvider" name="grupoawamotos_b2b_customer_listing_data_source">
            <settings>
                <requestFieldName>id</requestFieldName>
                <primaryFieldName>entity_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    
    <listingToolbar name="listing_top">
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filterSearch name="fulltext"/>
        <filters name="listing_filters">
            <filterSelect name="b2b_approval_status">
                <settings>
                    <options class="GrupoAwamotos\B2B\Model\Customer\Attribute\Source\ApprovalStatus"/>
                    <caption translate="true">Todos</caption>
                    <label translate="true">Status B2B</label>
                    <dataScope>b2b_approval_status</dataScope>
                </settings>
            </filterSelect>
            <filterSelect name="b2b_cnae_profile">
                <settings>
                    <options class="GrupoAwamotos\B2B\Model\Customer\Attribute\Source\CnaeProfile"/>
                    <caption translate="true">Todos</caption>
                    <label translate="true">Perfil CNAE</label>
                    <dataScope>b2b_cnae_profile</dataScope>
                </settings>
            </filterSelect>
        </filters>
        <paging name="listing_paging"/>
    </listingToolbar>
    
    <columns name="grupoawamotos_b2b_customer_columns">
        <selectionsColumn name="ids">
            <settings>
                <indexField>entity_id</indexField>
            </settings>
        </selectionsColumn>
        
        <column name="entity_id">
            <settings>
                <filter>textRange</filter>
                <label translate="true">ID</label>
                <sorting>asc</sorting>
            </settings>
        </column>
        
        <column name="name">
            <settings>
                <filter>text</filter>
                <label translate="true">Nome</label>
            </settings>
        </column>
        
        <column name="email">
            <settings>
                <filter>text</filter>
                <label translate="true">E-mail</label>
            </settings>
        </column>
        
        <column name="b2b_cnpj">
            <settings>
                <filter>text</filter>
                <label translate="true">CNPJ</label>
            </settings>
        </column>
        
        <column name="b2b_razao_social">
            <settings>
                <filter>text</filter>
                <label translate="true">Razão Social</label>
            </settings>
        </column>
        
        <column name="b2b_approval_status" component="Magento_Ui/js/grid/columns/select">
            <settings>
                <options class="GrupoAwamotos\B2B\Model\Customer\Attribute\Source\ApprovalStatus"/>
                <filter>select</filter>
                <dataType>select</dataType>
                <label translate="true">Status B2B</label>
            </settings>
        </column>
        
        <column name="b2b_person_type" component="Magento_Ui/js/grid/columns/select">
            <settings>
                <options class="GrupoAwamotos\B2B\Model\Customer\Attribute\Source\PersonType"/>
                <filter>select</filter>
                <dataType>select</dataType>
                <label translate="true">Tipo Pessoa</label>
            </settings>
        </column>

        <column name="b2b_cnae_code">
            <settings>
                <filter>text</filter>
                <label translate="true">CNAE</label>
                <visible>false</visible>
            </settings>
        </column>

        <column name="b2b_cnae_description">
            <settings>
                <filter>text</filter>
                <label translate="true">Atividade Principal</label>
                <visible>false</visible>
            </settings>
        </column>

        <column name="b2b_cnae_profile" component="Magento_Ui/js/grid/columns/select">
            <settings>
                <options class="GrupoAwamotos\B2B\Model\Customer\Attribute\Source\CnaeProfile"/>
                <filter>select</filter>
                <dataType>select</dataType>
                <label translate="true">Perfil CNAE</label>
            </settings>
        </column>
        
        <column name="created_at" class="Magento\Ui\Component\Listing\Columns\Date" component="Magento_Ui/js/grid/columns/date">
            <settings>
                <filter>dateRange</filter>
                <dataType>date</dataType>
                <label translate="true">Criado em</label>
            </settings>
        </column>
        
        <actionsColumn name="actions" class="GrupoAwamotos\B2B\Ui\Component\Listing\Column\CustomerActions">
            <settings>
                <indexField>entity_id</indexField>
            </settings>
        </actionsColumn>
    </columns>
</listing>
