<?xml version="1.0"?>
<!--
/**
 * B2B Notification Log Listing Grid
 */
-->
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">grupoawamotos_b2b_notification_listing.grupoawamotos_b2b_notification_listing_data_source</item>
        </item>
    </argument>

    <settings>
        <spinner>grupoawamotos_b2b_notification_columns</spinner>
        <deps>
            <dep>grupoawamotos_b2b_notification_listing.grupoawamotos_b2b_notification_listing_data_source</dep>
        </deps>
    </settings>

    <dataSource name="grupoawamotos_b2b_notification_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <storageConfig>
                <param name="indexField" xsi:type="string">notification_id</param>
            </storageConfig>
            <updateUrl path="mui/index/render"/>
        </settings>
        <aclResource>GrupoAwamotos_B2B::notifications</aclResource>
        <dataProvider class="Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider"
                      name="grupoawamotos_b2b_notification_listing_data_source">
            <settings>
                <requestFieldName>id</requestFieldName>
                <primaryFieldName>notification_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>

    <listingToolbar name="listing_top">
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filterSearch name="fulltext"/>
        <filters name="listing_filters"/>
        <paging name="listing_paging"/>
    </listingToolbar>

    <columns name="grupoawamotos_b2b_notification_columns">
        <selectionsColumn name="ids">
            <settings>
                <indexField>notification_id</indexField>
            </settings>
        </selectionsColumn>

        <column name="notification_id">
            <settings>
                <filter>textRange</filter>
                <label translate="true">ID</label>
                <sorting>desc</sorting>
            </settings>
        </column>

        <column name="type">
            <settings>
                <filter>text</filter>
                <label translate="true">Canal</label>
            </settings>
        </column>

        <column name="event">
            <settings>
                <filter>text</filter>
                <label translate="true">Tipo de Evento</label>
            </settings>
        </column>

        <column name="recipient">
            <settings>
                <filter>text</filter>
                <label translate="true">Destinatário</label>
            </settings>
        </column>

        <column name="status">
            <settings>
                <filter>text</filter>
                <label translate="true">Status</label>
            </settings>
        </column>

        <column name="message" class="Magento\Ui\Component\Listing\Columns\Column">
            <settings>
                <filter>text</filter>
                <label translate="true">Mensagem</label>
                <bodyTmpl>ui/grid/cells/html</bodyTmpl>
            </settings>
        </column>

        <column name="created_at" class="Magento\Ui\Component\Listing\Columns\Date" component="Magento_Ui/js/grid/columns/date">
            <settings>
                <filter>dateRange</filter>
                <dataType>date</dataType>
                <label translate="true">Data</label>
            </settings>
        </column>
    </columns>
</listing>
