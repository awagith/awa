<?xml version="1.0"?>
<!--
/**
 * Frontend DI Configuration
 */
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    
    <!-- Plugin para bloquear add to cart para não logados -->
    <type name="Magento\Checkout\Controller\Cart\Add">
        <plugin name="grupoawamotos_b2b_block_cart_add"
                type="GrupoAwamotos\B2B\Plugin\BlockCartAddPlugin"
                sortOrder="10"/>
    </type>
    
    <!-- Plugin para bloquear checkout para clientes não aprovados -->
    <type name="Magento\Checkout\Controller\Index\Index">
        <plugin name="grupoawamotos_b2b_block_checkout"
                type="GrupoAwamotos\B2B\Plugin\BlockCheckoutPlugin"
                sortOrder="10"/>
    </type>
    
    <!-- Plugin para bloquear Express Checkout (Rokanthemes OnePageCheckout) -->
    <type name="Rokanthemes\OnePageCheckout\Controller\Index\Index">
        <plugin name="grupoawamotos_b2b_block_express_checkout"
                type="GrupoAwamotos\B2B\Plugin\BlockExpressCheckoutPlugin"
                sortOrder="10"/>
    </type>

    <type name="GrupoAwamotos\B2B\Plugin\BlockExpressCheckoutPlugin">
        <arguments>
            <argument name="customerSession" xsi:type="object">Magento\Customer\Model\Session\Proxy</argument>
            <argument name="checkoutSession" xsi:type="object">Magento\Checkout\Model\Session\Proxy</argument>
        </arguments>
    </type>

    <!-- Plugin para redirecionar dashboard padrão para B2B dashboard -->
    <type name="Magento\Customer\Controller\Account\Index">
        <plugin name="grupoawamotos_b2b_redirect_dashboard"
                type="GrupoAwamotos\B2B\Plugin\Customer\Account\DashboardRedirectPlugin"
                sortOrder="10"/>
    </type>
    
    <!-- Plugin para redirecionar login padrão para B2B (strict mode) -->
    <type name="Magento\Customer\Controller\Account\Login">
        <plugin name="grupoawamotos_b2b_redirect_login"
                type="GrupoAwamotos\B2B\Plugin\Customer\Account\LoginRedirectPlugin"
                sortOrder="10"/>
    </type>

    <!-- Plugin para redirecionar esqueci senha para B2B (strict mode) -->
    <type name="Magento\Customer\Controller\Account\ForgotPassword">
        <plugin name="grupoawamotos_b2b_redirect_forgot_password"
                type="GrupoAwamotos\B2B\Plugin\Customer\Account\ForgotPasswordRedirectPlugin"
                sortOrder="10"/>
    </type>

    <!-- Plugin para redirecionar registro padrão para B2B (strict mode) -->
    <type name="Magento\Customer\Controller\Account\Create">
        <plugin name="grupoawamotos_b2b_redirect_create"
                type="GrupoAwamotos\B2B\Plugin\Customer\Account\CreateRedirect"
                sortOrder="10"/>
    </type>
    
    <!-- Plugin para bloquear criação de conta padrão (strict mode) -->
    <type name="Magento\Customer\Controller\Account\CreatePost">
        <plugin name="grupoawamotos_b2b_redirect_create_post"
                type="GrupoAwamotos\B2B\Plugin\Customer\Account\CreatePostRedirect"
                sortOrder="10"/>
    </type>
    
    <!-- Plugin para redirecionar links de registro para B2B -->
    <type name="Magento\Customer\Block\Account\Customer">
        <plugin name="grupoawamotos_b2b_customer_link"
                type="GrupoAwamotos\B2B\Plugin\Customer\Block\Account\CustomerLink"
                sortOrder="10"/>
    </type>

    <!-- Session Proxy para BlockCheckoutPlugin (evitar instanciar sessions em contexto errado) -->
    <type name="GrupoAwamotos\B2B\Plugin\BlockCheckoutPlugin">
        <arguments>
            <argument name="customerSession" xsi:type="object">Magento\Customer\Model\Session\Proxy</argument>
            <argument name="checkoutSession" xsi:type="object">Magento\Checkout\Model\Session\Proxy</argument>
        </arguments>
    </type>

    <!-- Session Proxy para RestrictedProductViewPlugin -->
    <type name="GrupoAwamotos\B2B\Plugin\Catalog\RestrictedProductViewPlugin">
        <arguments>
            <argument name="customerSession" xsi:type="object">Magento\Customer\Model\Session\Proxy</argument>
        </arguments>
    </type>

    <!-- Session Proxy para Login/Claim controllers -->
    <type name="GrupoAwamotos\B2B\Controller\Account\Login">
        <arguments>
            <argument name="customerSession" xsi:type="object">Magento\Customer\Model\Session\Proxy</argument>
        </arguments>
    </type>

    <type name="GrupoAwamotos\B2B\Controller\Account\Claim">
        <arguments>
            <argument name="customerSession" xsi:type="object">Magento\Customer\Model\Session\Proxy</argument>
        </arguments>
    </type>

    <type name="GrupoAwamotos\B2B\Controller\Account\ForgotPassword">
        <arguments>
            <argument name="customerSession" xsi:type="object">Magento\Customer\Model\Session\Proxy</argument>
        </arguments>
    </type>

    <!-- Session Proxy + ERP dependencies for GroupPricePlugin -->
    <type name="GrupoAwamotos\B2B\Plugin\GroupPricePlugin">
        <arguments>
            <argument name="customerSession" xsi:type="object">Magento\Customer\Model\Session\Proxy</argument>
        </arguments>
    </type>

    <!-- Session Proxy para BlockCartAddPlugin -->
    <type name="GrupoAwamotos\B2B\Plugin\BlockCartAddPlugin">
        <arguments>
            <argument name="customerSession" xsi:type="object">Magento\Customer\Model\Session\Proxy</argument>
        </arguments>
    </type>

    <!-- Session Proxy para LoginToCart block -->
    <type name="GrupoAwamotos\B2B\Block\LoginToCart">
        <arguments>
            <argument name="customerSession" xsi:type="object">Magento\Customer\Model\Session\Proxy</argument>
        </arguments>
    </type>

    <!-- Plugin para permitir login com CNPJ (resolve CNPJ → email) -->
    <type name="Magento\Customer\Api\AccountManagementInterface">
        <plugin name="grupoawamotos_b2b_resolve_cnpj_login"
                type="GrupoAwamotos\B2B\Plugin\Customer\ResolveCnpjLoginPlugin"
                sortOrder="5"/>
    </type>

    <!-- Plugin para ocultar preços no mini-cart (sidebar) -->
    <type name="Magento\Checkout\CustomerData\Cart">
        <plugin name="grupoawamotos_b2b_hide_minicart_price"
                type="GrupoAwamotos\B2B\Plugin\Checkout\HideMiniCartPricePlugin"
                sortOrder="10"/>
    </type>

    <!-- Plugin para ocultar preços nos itens da página do carrinho -->
    <type name="Magento\Checkout\Block\Cart\Item\Renderer">
        <plugin name="grupoawamotos_b2b_hide_cart_item_price"
                type="GrupoAwamotos\B2B\Plugin\Checkout\HideCartItemPricePlugin"
                sortOrder="10"/>
    </type>

    <!-- Plugin para ocultar preços na config do checkout (KnockoutJS) -->
    <type name="Magento\Checkout\Model\DefaultConfigProvider">
        <plugin name="grupoawamotos_b2b_hide_checkout_price"
                type="GrupoAwamotos\B2B\Plugin\Checkout\HideCheckoutPricePlugin"
                sortOrder="100"/>
    </type>

    <!-- Plugin para ocultar totais do carrinho via API -->
    <type name="Magento\Quote\Model\Cart\CartTotalRepository">
        <plugin name="grupoawamotos_b2b_hide_cart_totals"
                type="GrupoAwamotos\B2B\Plugin\Checkout\HideCartTotalsPlugin"
                sortOrder="10"/>
    </type>

    <!-- Session Proxy para Quote Accept/Reject controllers -->
    <type name="GrupoAwamotos\B2B\Controller\Quote\Accept">
        <arguments>
            <argument name="customerSession" xsi:type="object">Magento\Customer\Model\Session\Proxy</argument>
        </arguments>
    </type>

    <type name="GrupoAwamotos\B2B\Controller\Quote\Reject">
        <arguments>
            <argument name="customerSession" xsi:type="object">Magento\Customer\Model\Session\Proxy</argument>
        </arguments>
    </type>

    <!-- Session Proxy para ShoppingList SetRecurring controller -->
    <type name="GrupoAwamotos\B2B\Controller\ShoppingList\SetRecurring">
        <arguments>
            <argument name="customerSession" xsi:type="object">Magento\Customer\Model\Session\Proxy</argument>
        </arguments>
    </type>

    <!-- HTTP Context: vary FPC by customer's ERP price list -->
    <type name="Magento\Framework\App\Http\Context">
        <plugin name="grupoawamotos_b2b_price_list_context"
                type="GrupoAwamotos\B2B\Plugin\CustomerPriceListContextPlugin"
                sortOrder="20"/>
    </type>

    <type name="GrupoAwamotos\B2B\Plugin\CustomerPriceListContextPlugin">
        <arguments>
            <argument name="customerSession" xsi:type="object">Magento\Customer\Model\Session\Proxy</argument>
        </arguments>
    </type>

    <!-- B2B Credit Payment Config Provider -->
    <type name="Magento\Checkout\Model\CompositeConfigProvider">
        <arguments>
            <argument name="configProviders" xsi:type="array">
                <item name="b2b_credit_config_provider" xsi:type="object">GrupoAwamotos\B2B\Model\Payment\CreditConfigProvider</item>
            </argument>
        </arguments>
    </type>

    <type name="GrupoAwamotos\B2B\Model\Payment\CreditConfigProvider">
        <arguments>
            <argument name="customerSession" xsi:type="object">Magento\Customer\Model\Session\Proxy</argument>
        </arguments>
    </type>

</config>
