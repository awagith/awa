<?xml version="1.0"?>
<!--
/**
 * DI Configuration for B2B Module
 */
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" Carrinho: ocultar preços e totais via plugins -->
    <type name="Magento\Quote\Api\CartTotalRepositoryInterface">
        <plugin name="grupoawamotos_b2b_hide_cart_totals"
                type="GrupoAwamotos\B2B\Plugin\Checkout\HideCartTotalsPlugin"
                sortorder="10"/>
    </type>

    <type name="Magento\Checkout\Block\Cart\Item\Renderer">
        <plugin name="grupoawamotos_b2b_hide_cart_item_price"
                type="GrupoAwamotos\B2B\Plugin\Checkout\HideCartItemPricePlugin"
                sortorder="10"/>
    </type>

    <type name="Magento\Checkout\CustomerData\Cart">
        <plugin name="grupoawamotos_b2b_hide_minicart_price"
                type="GrupoAwamotos\B2B\Plugin\Checkout\HideMiniCartPricePlugin"
                sortorder="10"/>
    </type>

    <type name="Magento\Checkout\Model\DefaultConfigProvider">
        <plugin name="grupoawamotos_b2b_hide_checkout_price"
                type="GrupoAwamotos\B2B\Plugin\Checkout\HideCheckoutPricePlugin"
                sortorder="10"/>
    </type>

    <!-- customer session proxy para performance -->
    <type name="GrupoAwamotos\B2B\Model\PriceVisibility">
        <arguments>
            <argument name="customerSession"; B2B: bloquear placeorder para usuários não autorizados (global scope para cobrir rest api) -->
    <type name="Magento\Checkout\Api\PaymentInformationManagementInterface">
        <plugin name="grupoawamotos_b2b_block_place_order"
                type="GrupoAwamotos\B2B\Plugin\Checkout\BlockPlaceOrderPlugin"
                sortorder="10"/>
    </type>

    <type name="Magento\Checkout\Api\GuestPaymentInformationManagementInterface">
        <plugin name="grupoawamotos_b2b_block_guest_place_order"
                type="GrupoAwamotos\B2B\Plugin\Checkout\BlockGuestPlaceOrderPlugin"
                sortorder="10"/>
    </type>

    <!-- plugin para validar cnpj ao salvar customer -->
    <type name="Magento\Customer\Api\CustomerRepositoryInterface">
        <plugin name="grupoawamotos_b2b_validate_cnpj_on_save"
                type="GrupoAwamotos\B2B\Plugin\Customer\ValidateCnpjOnSavePlugin"
                sortorder="10"/>
    </type>

    <!-- b2b checkout configproviders -->
    <type name="Magento\Checkout\Model\CompositeConfigProvider">
        <arguments>
            <argument name="configProviders" xsi:type="object">magento\customer\model\session\proxy</argument>
        </arguments>
    </type>

</config>
