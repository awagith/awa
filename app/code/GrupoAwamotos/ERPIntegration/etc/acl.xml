                    </resource>
                </resource>
                <resource id="GrupoAwamotos_ERPIntegration::erp" title="ERP Integration" sortOrder="100">
                    <resource id="GrupoAwamotos_ERPIntegration::dashboard" title="ERP Dashboard" sortOrder="1"/>
                    <resource id="GrupoAwamotos_ERPIntegration::customers" title="ERP Customers" sortOrder="5"/>
                    <resource id="GrupoAwamotos_ERPIntegration::sync" title="Sync Operations" sortOrder="10"/>
                    <resource id="GrupoAwamotos_ERPIntegration::log" title="Sync Logs" sortOrder="20"/>
                    <resource id="GrupoAwamotos_ERPIntegration::suggestions" title="Product Suggestions" sortOrder="30"/>
                    <resource id="GrupoAwamotos_ERPIntegration::rfm" title="RFM Analysis" sortOrder="40"/>
                    <resource id="GrupoAwamotos_ERPIntegration::forecast" title="Sales Forecast" sortOrder="50"/>
                    <resource id="GrupoAwamotos_ERPIntegration::goals" title="Sales Goals" sortOrder="55"/>
                    <resource id="GrupoAwamotos_ERPIntegration::image_sync" title="Image Sync API" sortOrder="60"/>
                </resource>
            </resource>
        </resources>
    </acl>
</config>
