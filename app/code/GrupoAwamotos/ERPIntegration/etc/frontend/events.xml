<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Event/etc/events.xsd">

    <!-- Pre-load customer ERP prices in batch when product collections load -->
    <event name="catalog_product_collection_load_after">
        <observer name="erp_preload_customer_prices"
                  instance="GrupoAwamotos\ERPIntegration\Observer\PreloadCustomerPrices"/>
    </event>
</config>
