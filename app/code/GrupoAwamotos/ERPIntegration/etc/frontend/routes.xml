<?xml version="1.0"?>
<!--
/**
 * Frontend Routes Configuration
 *
 * Enables routes for customer-facing ERP integration pages
 */
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:App/etc/routes.xsd">
    <router id="standard">
        <route id="erpintegration" frontName="erpintegration">
            <module name="GrupoAwamotos_ERPIntegration" />
        </route>
    </router>
</config>
