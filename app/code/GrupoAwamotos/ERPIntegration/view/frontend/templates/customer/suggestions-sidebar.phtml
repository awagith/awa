<?php
/**
 * Minimal Suggestions Widget for Cart Sidebar
 *
 * @var \GrupoAwamotos\ERPIntegration\Block\Customer\Suggestions $block
 */

if (!$block->isEnabled() || !$block->isLoggedIn()) {
    return;
}

$customerCode = $block->getErpCustomerCode();
if (!$customerCode) {
    return;
}

$suggestedCart = $block->getSuggestedCart();

if (empty($suggestedCart['sections']) || isset($suggestedCart['error'])) {
    return;
}

// Get just reorder items (most relevant)
$reorderItems = $suggestedCart['sections']['reorder']['items'] ?? [];
$items = array_slice($reorderItems, 0, 3);

if (empty($items)) {
    return;
}
?>

<div class="erp-sidebar-suggestions" id="erp-sidebar-suggestions">
    <div class="erp-sidebar-title">
        <span>🔄</span> Hora de Repor
    </div>
    <ul class="erp-sidebar-list">
        <?php foreach ($items as $item): ?>
        <li class="erp-sidebar-item">
            <a href="<?= $block->escapeUrl($item['url'] ?? '#') ?>" class="erp-sidebar-link">
                <?= $block->escapeHtml(mb_strimwidth($item['name'], 0, 35, '...')) ?>
            </a>
            <button type="button"
                    class="erp-sidebar-add"
                    data-sku="<?= $block->escapeHtmlAttr($item['sku']) ?>"
                    data-qty="<?= (int)$item['suggested_quantity'] ?>"
                    title="Adicionar">+</button>
        </li>
        <?php endforeach; ?>
    </ul>
    <a href="<?= $block->escapeUrl($block->getUrl('erpintegration/customer/suggestedcart')) ?>" class="erp-sidebar-more">
        Ver todas as sugestões →
    </a>
</div>

<script>
require(['jquery'], function($) {
    $('#erp-sidebar-suggestions').on('click', '.erp-sidebar-add', function() {
        var $btn = $(this);
        $btn.prop('disabled', true).text('...');

        $.post('<?= $block->escapeJs($block->getUrl('erpintegration/cart/addBySku')) ?>', {
            sku: $btn.data('sku'),
            qty: $btn.data('qty') || 1,
            form_key: $.mage.cookies.get('form_key')
        }).done(function(res) {
            if (res.success) {
                $btn.text('✓').addClass('added');
                setTimeout(function() { location.reload(); }, 1000);
            } else {
                $btn.prop('disabled', false).text('+');
            }
        }).fail(function() {
            $btn.prop('disabled', false).text('+');
        });
    });
});
</script>

