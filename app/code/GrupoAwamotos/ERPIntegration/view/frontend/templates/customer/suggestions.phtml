<script>
require(['jquery'], function($) {
    'use strict';

    var $container = $('#erp-suggestions-container');

    // Update line totals when quantity changes
    $container.on('change input', '.erp-qty-input', function() {
        var $input = $(this);
        var $item = $input.closest('.erp-cart-item');
        var qty = parseInt($input.val()) || 1;
        var price = parseFloat($item.find('.erp-item-select').data('price')) || 0;
        var lineTotal = qty * price;

        $item.find('.erp-line-total').text(formatPrice(lineTotal));
        $item.find('.erp-item-select').data('qty', qty);

        updateTotals();
    });

    // Update totals when items are selected/deselected
    $container.on('change', '.erp-item-select', function() {
        updateTotals();
    });

    // Select/Deselect all
    $('#erp-select-all').on('click', function() {
        var $checkboxes = $container.find('.erp-item-select');
        var allChecked = $checkboxes.filter(':checked').length === $checkboxes.length;

        $checkboxes.prop('checked', !allChecked);
        $(this).text(allChecked ? '✓ Selecionar Todos' : '✗ Desmarcar Todos');
        updateTotals();
    });

    // Add selected items to cart
    $('#erp-add-all-to-cart').on('click', function() {
        var $btn = $(this);
        var items = [];

        $container.find('.erp-item-select:checked').each(function() {
            var $item = $(this).closest('.erp-cart-item');
            items.push({
                sku: $(this).val(),
                qty: parseInt($item.find('.erp-qty-input').val()) || 1
            });
        });

        if (items.length === 0) {
            alert('Selecione pelo menos um produto para adicionar ao carrinho.');
            return;
        }

        $btn.prop('disabled', true).text('Adicionando...');

        // Add items one by one (can be optimized with custom endpoint)
        var promises = items.map(function(item) {
            return addToCart(item.sku, item.qty);
        });

        Promise.all(promises)
            .then(function() {
                $btn.text('✓ Adicionado!');
                setTimeout(function() {
                    window.location.href = '<?= $block->escapeJs($block->getUrl('checkout/cart')) ?>';
                }, 1000);
            })
            .catch(function(error) {
                alert('Erro ao adicionar produtos. Tente novamente.');
                $btn.prop('disabled', false).text('🛒 Adicionar Selecionados ao Carrinho');
            });
    });

    function addToCart(sku, qty) {
        return new Promise(function(resolve, reject) {
            $.ajax({
                url: '<?= $block->escapeJs($block->getUrl('erpintegration/cart/addBySku')) ?>',
                type: 'POST',
                data: {
                    sku: sku,
                    qty: qty,
                    form_key: $.mage.cookies.get('form_key')
                },
                success: function(response) {
                    if (response.success) {
                        resolve(response);
                    } else {
                        reject(response.message || 'Error');
                    }
                },
                error: function() {
                    reject('Network error');
                }
            });
        });
    }

    function updateTotals() {
        var subtotal = 0;
        var itemCount = 0;

        $container.find('.erp-item-select:checked').each(function() {
            var $item = $(this).closest('.erp-cart-item');
            var qty = parseInt($item.find('.erp-qty-input').val()) || 1;
            var price = parseFloat($(this).data('price')) || 0;
            subtotal += qty * price;
            itemCount++;
        });

        $container.find('.erp-subtotal-value').text(formatPrice(subtotal));
        $container.find('.erp-cart-items').text(itemCount + ' produtos');
        $container.find('.erp-cart-total').text(formatPrice(subtotal));

        // Update shipping info
        var freeShippingThreshold = 1500;
        var remaining = freeShippingThreshold - subtotal;

        if (remaining <= 0) {
            $container.find('.erp-shipping-info').hide();
            $container.find('.erp-free-shipping').show();
            $container.find('.erp-total-value').text(formatPrice(subtotal));
        } else {
            $container.find('.erp-free-shipping').hide();
            $container.find('.erp-shipping-info').show().find('span').text('Falta ' + formatPrice(remaining) + ' para frete grátis');
            $container.find('.erp-total-value').text(formatPrice(subtotal + 50)); // Estimated shipping
        }
    }

    function formatPrice(value) {
        return 'R$ ' + value.toLocaleString('pt-BR', {
            minimumFractionDigits: 2,
            maximumFractionDigits: 2
        });
    }

    // ========== Filtered History (only on Suggested Cart page) ==========
    <?php if ($block->isSuggestedCartPage()): ?>
    var filterUrl = '<?= $block->escapeJs($block->getUrl('erpintegration/customer/filteredHistory')) ?>';
    var opportunityUrl = '<?= $block->escapeJs($block->getOpportunityClassifierUrl()) ?>';
    var addBySkuUrl = '<?= $block->escapeJs($block->getUrl('erpintegration/cart/addBySku')) ?>';
    var currentFilterPage = 1;

    var oppLabels = {
        'monthly': 'Mensal',
        'quarterly_not_bought': 'Trim. Não Comprou',
        'quarterly_bought': 'Trim. Comprou',
        'expansion_monthly': 'Expansão Mensal',
        'expansion_quarterly': 'Expansão Trim.',
        'irregular': 'Irregular',
        'churn': 'Churn',
        'cross_sell': 'Cross-sell'
    };

    // Toggle filter panel
    $('#erp-filter-toggle').on('click', function() {
        var $body = $('#erp-filter-body');
        var $icon = $('#erp-toggle-icon');
        $body.slideToggle(200);
        $icon.text($body.is(':visible') ? '▶' : '▼');
    });

    // Filter button
    $('#erp-btn-filter').on('click', function() {
        currentFilterPage = 1;
        loadFilteredHistory();
    });

    // Clear filters
    $('#erp-btn-clear-filter').on('click', function() {
        $('#erp-filter-opportunity').val('');
        $('#erp-filter-period').val('365');
        $('#erp-filter-freq').val('0-0');
        $('#erp-filter-min-price').val('');
        $('#erp-filter-max-price').val('');
        $('#erp-filter-sort').val('days_since_last');
        $('#erp-filter-sort-dir').val('ASC');
        currentFilterPage = 1;
        $('#erp-filter-results').hide();
        $('#erp-filter-empty').hide();
    });

    // Add filtered items to cart
    $('#erp-add-filtered-to-cart').on('click', function() {
        var $btn = $(this);
        var items = [];

        $('#erp-filter-results-list .erp-fh-item-select:checked').each(function() {
            var $row = $(this).closest('.erp-fh-item');
            items.push({
                sku: $(this).val(),
                qty: parseInt($row.find('.erp-fh-qty-input').val()) || 1
            });
        });

        if (items.length === 0) {
            alert('Selecione pelo menos um produto.');
            return;
        }

        $btn.prop('disabled', true).text('Adicionando...');

        var promises = items.map(function(item) {
            return addToCart(item.sku, item.qty);
        });

        Promise.all(promises)
            .then(function() {
                $btn.text('✓ Adicionado!');
                setTimeout(function() {
                    $btn.prop('disabled', false).text('🛒 Adicionar Selecionados');
                }, 2000);
            })
            .catch(function() {
                alert('Erro ao adicionar produtos. Tente novamente.');
                $btn.prop('disabled', false).text('🛒 Adicionar Selecionados');
            });
    });

    function loadFilteredHistory() {
        var freqVal = $('#erp-filter-freq').val().split('-');
        var oppType = $('#erp-filter-opportunity').val();

        var params = {
            period_days: $('#erp-filter-period').val(),
            min_freq: freqVal[0],
            max_freq: freqVal[1],
            min_price: $('#erp-filter-min-price').val() || 0,
            max_price: $('#erp-filter-max-price').val() || 0,
            sort_by: $('#erp-filter-sort').val(),
            sort_dir: $('#erp-filter-sort-dir').val(),
            page: currentFilterPage,
            limit: 20
        };

        // Use opportunity classifier endpoint when a type is selected
        var requestUrl = filterUrl;
        if (oppType) {
            requestUrl = opportunityUrl;
            params.opportunity_type = oppType;
        }

        $('#erp-filter-loading').show();
        $('#erp-filter-results').show();
        $('#erp-filter-empty').hide();
        $('#erp-filter-results-list').empty();
        $('#erp-filter-pagination').empty();

        $.ajax({
            url: requestUrl,
            type: 'GET',
            data: params,
            dataType: 'json',
            success: function(response) {
                $('#erp-filter-loading').hide();

                if (!response.success) {
                    $('#erp-filter-empty').show().text(response.message || 'Erro ao consultar.');
                    $('#erp-filter-results').hide();
                    return;
                }

                if (!response.items || response.items.length === 0) {
                    $('#erp-filter-empty').show();
                    $('#erp-filter-results').hide();
                    return;
                }

                $('#erp-results-count').text(response.total_count + ' produtos encontrados');
                $('#erp-add-filtered-to-cart').toggle(response.items.length > 0);

                renderFilteredItems(response.items);
                renderPagination(response.page, response.total_pages, response.total_count);
            },
            error: function() {
                $('#erp-filter-loading').hide();
                $('#erp-filter-empty').show().text('Erro de conexão. Tente novamente.');
            }
        });
    }

    function renderFilteredItems(items) {
        var $list = $('#erp-filter-results-list');
        $list.empty();

        items.forEach(function(item) {
            var sku = item.codigo_material || item.sku || '';
            var name = (item.magento && item.magento.name) ? item.magento.name : (item.descricao || item.name || sku);
            var price = item.avg_price || (item.magento && item.magento.final_price) || 0;
            var orderCount = item.order_count || item.vezes_comprado || 0;
            var totalQty = item.total_qty || item.quantidade_total || 0;
            var daysSince = item.days_since_last || '';
            var lastDate = item.last_order_date || item.ultima_compra || '';
            var hasUrl = item.magento && item.magento.url_key;
            var url = hasUrl ? '/' + item.magento.url_key + '.html' : '#';
            var inStore = item.available_in_store;

            var html = '<div class="erp-fh-item' + (!inStore ? ' erp-fh-item-unavailable' : '') + '">';
            html += '<div class="erp-fh-item-check">';
            if (inStore) {
                html += '<input type="checkbox" class="erp-fh-item-select" value="' + escapeHtml(sku) + '">';
            }
            html += '</div>';
            html += '<div class="erp-fh-item-info">';
            html += '<div class="erp-fh-item-main">';
            html += '<span class="erp-item-sku">' + escapeHtml(sku) + '</span>';
            if (item.opportunity_type && oppLabels[item.opportunity_type]) {
                html += '<span class="erp-opp-badge erp-opp-' + item.opportunity_type.replace(/_/g, '-') + '">'
                      + escapeHtml(oppLabels[item.opportunity_type]) + '</span>';
            }
            html += '<a href="' + escapeHtml(url) + '" class="erp-item-name">' + escapeHtml(name) + '</a>';
            if (!inStore) {
                html += '<span class="erp-fh-unavailable-badge">Indisponível na loja</span>';
            }
            html += '</div>';
            html += '<div class="erp-fh-item-meta">';
            html += '<span class="erp-meta-item"><strong>' + orderCount + '</strong> pedidos</span>';
            html += '<span class="erp-meta-item"><strong>' + totalQty + '</strong> unidades</span>';
            if (daysSince) {
                html += '<span class="erp-meta-item">Há <strong>' + daysSince + '</strong> dias</span>';
            }
            if (lastDate) {
                html += '<span class="erp-meta-item">Última: ' + formatDate(lastDate) + '</span>';
            }
            html += '</div>';
            html += '</div>';
            html += '<div class="erp-fh-item-price">' + formatPrice(parseFloat(price)) + '</div>';
            if (inStore) {
                html += '<div class="erp-fh-item-qty">';
                html += '<input type="number" class="erp-fh-qty-input" value="1" min="1" max="999">';
                html += '</div>';
                html += '<div class="erp-fh-item-action">';
                html += '<button type="button" class="erp-btn erp-btn-outline erp-btn-small erp-fh-add-one" data-sku="' + escapeHtml(sku) + '">🛒</button>';
                html += '</div>';
            } else {
                html += '<div class="erp-fh-item-qty"></div>';
                html += '<div class="erp-fh-item-action"></div>';
            }
            html += '</div>';

            $list.append(html);
        });

        // Individual add to cart
        $list.find('.erp-fh-add-one').on('click', function() {
            var $btn = $(this);
            var sku = $btn.data('sku');
            var qty = parseInt($btn.closest('.erp-fh-item').find('.erp-fh-qty-input').val()) || 1;

            $btn.prop('disabled', true).text('...');
            addToCart(sku, qty)
                .then(function() {
                    $btn.text('✓');
                    setTimeout(function() { $btn.prop('disabled', false).text('🛒'); }, 2000);
                })
                .catch(function() {
                    $btn.prop('disabled', false).text('🛒');
                    alert('Erro ao adicionar.');
                });
        });

        // Toggle bulk button visibility
        $list.on('change', '.erp-fh-item-select', function() {
            var hasChecked = $list.find('.erp-fh-item-select:checked').length > 0;
            $('#erp-add-filtered-to-cart').toggle(hasChecked);
        });
    }

    function renderPagination(currentPage, totalPages, totalCount) {
        if (totalPages <= 1) return;

        var $pag = $('#erp-filter-pagination');
        var html = '';

        if (currentPage > 1) {
            html += '<button class="erp-btn erp-btn-secondary erp-btn-small erp-pag-btn" data-page="' + (currentPage - 1) + '">◀ Anterior</button>';
        }

        html += '<span class="erp-pag-info">Página ' + currentPage + ' de ' + totalPages + '</span>';

        if (currentPage < totalPages) {
            html += '<button class="erp-btn erp-btn-secondary erp-btn-small erp-pag-btn" data-page="' + (currentPage + 1) + '">Próxima ▶</button>';
        }

        $pag.html(html);

        $pag.find('.erp-pag-btn').on('click', function() {
            currentFilterPage = parseInt($(this).data('page'));
            loadFilteredHistory();
        });
    }

    function formatDate(dateStr) {
        if (!dateStr) return '-';
        try {
            var d = new Date(dateStr);
            if (isNaN(d.getTime())) return dateStr.substring(0, 10);
            return d.toLocaleDateString('pt-BR');
        } catch(e) {
            return dateStr.substring(0, 10);
        }
    }

    function escapeHtml(str) {
        if (!str) return '';
        var div = document.createElement('div');
        div.appendChild(document.createTextNode(str));
        return div.innerHTML;
    }
    <?php endif; ?>
});
</script>

