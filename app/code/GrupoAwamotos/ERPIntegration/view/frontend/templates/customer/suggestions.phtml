 * @var \GrupoAwamotos\ERPIntegration\Block\Customer\Suggestions $block
 */

if (!$block->isEnabled() || !$block->isLoggedIn()) {
    return;
}

$customerCode = $block->getErpCustomerCode();
if (!$customerCode) {
    return;
}

$summary = $block->getPurchaseSummary();
$mostPurchased = $block->getMostPurchasedProducts(8);
$suggestions = $block->getSuggestions(8);
