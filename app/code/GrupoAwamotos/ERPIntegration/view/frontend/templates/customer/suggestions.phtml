            <div class="erp-summary-item">
                <span class="erp-summary-value"><?= $block->formatPrice((float)($summary['valor_total'] ?? 0)) ?></span>
                <span class="erp-summary-label">Valor Total</span>
            </div>
            <div class="erp-summary-item">
                <span class="erp-summary-value"><?= (int)($summary['produtos_diferentes'] ?? 0) ?></span>
                <span class="erp-summary-label">Produtos Diferentes</span>
