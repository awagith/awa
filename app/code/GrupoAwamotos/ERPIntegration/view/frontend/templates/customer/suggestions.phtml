                    <span class="erp-product-sku"><?= $block->escapeHtml($product['codigo_material']) ?></span>
                    <span class="erp-product-name"><?= $block->escapeHtml($product['descricao']) ?></span>
                    <div class="erp-product-stats">
                        <span class="erp-stat">
                            <strong><?= (int)($product['clientes_compraram'] ?? 0) ?></strong> clientes compraram
                        </span>
                    </div>
                    <?php if (!empty($product['magento']['price'])): ?>
                    <div class="erp-product-price">
                        <?= $block->formatPrice((float)$product['magento']['price']) ?>
                    </div>
                    <?php endif; ?>
                </div>
                <div class="erp-product-actions">
                    <?php if ($block->isProductAvailable($product)): ?>
                    <a href="<?= $block->escapeUrl($block->getProductUrl($product)) ?>"
                       class="erp-btn erp-btn-primary">
                        Ver Produto
                    </a>
                    <?php else: ?>
                    <span class="erp-btn erp-btn-disabled">Indisponível</span>
                    <?php endif; ?>
                </div>
            </div>
            <?php endforeach; ?>
        </div>
    </div>
    <?php endif; ?>

</div>

