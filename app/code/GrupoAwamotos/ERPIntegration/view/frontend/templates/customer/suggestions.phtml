                        <td><?= (int)($order['qtd_itens'] ?? 0) ?></td>
                        <td><?= $block->formatPrice((float)($order['valor_total'] ?? 0)) ?></td>
                    </tr>
                    <?php endforeach; ?>
                </tbody>
            </table>
        </div>
    </div>
    <?php endif; ?>

