<?php
/**
 * Compact Suggestions Widget for Cart Page
 * Render lightweight shell and lazy-load content via AJAX on visibility.
 *
 * @var \GrupoAwamotos\ERPIntegration\Block\Customer\Suggestions $block
 */

if (!$block->isEnabled() || !$block->isLoggedIn()) {
    return;
}

$customerCode = $block->getErpCustomerCode();
if (!$customerCode) {
    return;
}
?>

<div class="erp-cart-suggestions-widget erp-loading" id="erp-cart-suggestions">
    <div class="erp-widget-header">
        <h3 class="erp-widget-title">
            <span class="erp-icon">💡</span>
            Sugestoes para voce
        </h3>
    </div>
    <div class="erp-widget-loading">
        <div class="erp-spinner"></div>
        <p>Carregando sugestoes personalizadas...</p>
    </div>
</div>

<script>
require(['jquery'], function ($) {
    'use strict';

    var widgetId = '#erp-cart-suggestions';
    var url = '<?= $block->escapeJs($block->getUrl('erpintegration/customer/suggestionsAjax')) ?>';
    var loaded = false;

    function loadSuggestions() {
        if (loaded) {
            return;
        }
        loaded = true;

        $.get(url)
            .done(function (html) {
                if (html && html.trim().length) {
                    $(widgetId).replaceWith(html);
                } else {
                    $(widgetId).remove();
                }
            })
            .fail(function () {
                $(widgetId).remove();
            });
    }

    var element = document.querySelector(widgetId);

    if (!element) {
        return;
    }

    if ('IntersectionObserver' in window) {
        var observer = new IntersectionObserver(function (entries) {
            if (entries[0] && entries[0].isIntersecting) {
                observer.disconnect();
                loadSuggestions();
            }
        }, { rootMargin: '250px 0px' });

        observer.observe(element);
        return;
    }

    if ('requestIdleCallback' in window) {
        window.requestIdleCallback(loadSuggestions, { timeout: 1200 });
        return;
    }

    window.setTimeout(loadSuggestions, 300);
});
</script>
