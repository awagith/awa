<?xml version="1.0"?>
<!--
/**
 * Customer Account Dashboard Layout
 *
 * Adds ERP purchase history and product suggestions to customer dashboard
 */
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <head>
        <css src="GrupoAwamotos_ERPIntegration::css/suggestions-page.css"/>
    </head>
    <body>
        <referenceContainer name="content">
            <block class="GrupoAwamotos\ERPIntegration\Block\Customer\Suggestions"
                   name="erp.customer.suggestions"
                   template="GrupoAwamotos_ERPIntegration::customer/suggestions.phtml"
                   after="-" />
        </referenceContainer>
    </body>
</page>
