<?xml version="1.0"?>
<!--
/**
 * Suggested Cart Page Layout
 *
 * Dedicated page for suggested cart feature
 */
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      layout="2columns-left"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">

    <head>
        <title>Carrinho Sugerido</title>
    </head>

    <update handle="customer_account"/>

    <body>
        <referenceContainer name="content">
            <block class="GrupoAwamotos\ERPIntegration\Block\Customer\Suggestions"
                   name="erp.customer.suggestedcart.page"
                   template="GrupoAwamotos_ERPIntegration::customer/suggestions.phtml"/>
        </referenceContainer>
    </body>
</page>
