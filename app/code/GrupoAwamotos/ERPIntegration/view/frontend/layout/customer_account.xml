<?xml version="1.0"?>
<!--
/**
 * Customer Account Navigation Layout
 *
 * Adds "Carrinho Sugerido" link to customer account menu
 */
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceBlock name="customer_account_navigation">
            <block class="Magento\Framework\View\Element\Html\Link\Current"
                   name="customer-account-navigation-suggested-cart-link">
                <arguments>
                    <argument name="label" xsi:type="string" translate="true">Carrinho Sugerido</argument>
                    <argument name="path" xsi:type="string">erpintegration/customer/suggestedcart</argument>
                </arguments>
            </block>
        </referenceBlock>
    </body>
</page>
