<?xml version="1.0"?>
<csp_whitelist xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
               xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Csp:etc/csp_whitelist.xsd">
    <policies>
        <policy id="script-src">
            <values>
                <value id="vlibras-script" type="host">vlibras.gov.br</value>
                <value id="vlibras-script-www" type="host">*.vlibras.gov.br</value>
                <value id="vlibras-cdn-jsdelivr" type="host">cdn.jsdelivr.net</value>
            </values>
        </policy>
        <policy id="connect-src">
            <values>
                <value id="vlibras-connect" type="host">vlibras.gov.br</value>
                <value id="vlibras-connect-www" type="host">*.vlibras.gov.br</value>
                <value id="vlibras-cdn-jsdelivr-connect" type="host">cdn.jsdelivr.net</value>
            </values>
        </policy>
        <policy id="img-src">
            <values>
                <value id="vlibras-img" type="host">vlibras.gov.br</value>
                <value id="vlibras-img-www" type="host">*.vlibras.gov.br</value>
                <value id="vlibras-cdn-jsdelivr-img" type="host">cdn.jsdelivr.net</value>
            </values>
        </policy>
        <policy id="style-src">
            <values>
                <value id="vlibras-style" type="host">vlibras.gov.br</value>
                <value id="vlibras-style-www" type="host">*.vlibras.gov.br</value>
                <value id="vlibras-cdn-jsdelivr-style" type="host">cdn.jsdelivr.net</value>
            </values>
        </policy>
        <policy id="font-src">
            <values>
                <value id="vlibras-font" type="host">vlibras.gov.br</value>
                <value id="vlibras-font-www" type="host">*.vlibras.gov.br</value>
                <value id="vlibras-cdn-jsdelivr-font" type="host">cdn.jsdelivr.net</value>
            </values>
        </policy>
        <policy id="frame-src">
            <values>
                <value id="vlibras-frame" type="host">vlibras.gov.br</value>
                <value id="vlibras-frame-www" type="host">*.vlibras.gov.br</value>
                <value id="vlibras-cdn-jsdelivr-frame" type="host">cdn.jsdelivr.net</value>
            </values>
        </policy>
    </policies>
</csp_whitelist>
