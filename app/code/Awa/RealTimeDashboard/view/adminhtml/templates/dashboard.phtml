<script>
require(['jquery'], function($) {
    'use strict';

    var refreshInterval = 30000;
    var ajaxUrl = $('#awa-realtime-dashboard').data('ajax-url');
    var autoRefreshTimer;

    function refreshDashboard() {
        $('#awa-btn-refresh').addClass('awa-spinning');
        $.ajax({
            url: ajaxUrl,
            type: 'GET',
            dataType: 'json',
            cache: false,
            success: function(data) {
                updateKPIs(data.summary);
                updateVisitors(data.visitors);
                updateProducts(data.viewed_products);
                updateSearches(data.recent_searches);
                updateTimeline(data.events_timeline);
                updateCarts(data.active_carts);
                updateOrders(data.recent_orders);
                $('#awa-server-time').text(data.server_time);
            },
            error: function() {
                console.error('AWA Dashboard: Erro ao atualizar dados');
            },
            complete: function() {
                $('#awa-btn-refresh').removeClass('awa-spinning');
            }
        });
    }

    function updateKPIs(s) {
        animateValue('#kpi-online-now', s.online_now);
        animateValue('#kpi-online-1h', s.online_1h);
        animateValue('#kpi-online-24h', s.online_24h);
        animateValue('#kpi-events-1h', s.events_1h);
        animateValue('#kpi-carts', s.carts_active);
        $('#kpi-carts-value').text(s.carts_value);
        animateValue('#kpi-orders', s.orders_today);
        $('#kpi-revenue').text(s.revenue_today);
        animateValue('#kpi-searches', s.searches_today);
    }

    function animateValue(selector, newVal) {
        var el = $(selector);
        var oldVal = parseInt(el.text()) || 0;
        newVal = parseInt(newVal) || 0;
        if (oldVal !== newVal) {
            el.text(newVal).addClass('awa-value-changed');
            setTimeout(function() { el.removeClass('awa-value-changed'); }, 1500);
        }
    }

    function timeAgo(dateStr) {
        var now = new Date();
        var past = new Date(dateStr.replace(' ', 'T') + 'Z');
        var diffMs = now - past;
        var diffMin = Math.floor(diffMs / 60000);
        var diffHour = Math.floor(diffMin / 60);
        var diffDay = Math.floor(diffHour / 24);
        if (diffDay > 0) return diffDay + 'd ' + (diffHour % 24) + 'h atrás';
        if (diffHour > 0) return diffHour + 'h ' + (diffMin % 60) + 'min atrás';
        if (diffMin > 0) return diffMin + 'min atrás';
        return 'Agora mesmo';
    }

    function updateVisitors(visitors) {
        var tbody = $('#awa-visitors-table tbody');
        tbody.empty();
        $.each(visitors, function(i, v) {
            var type = v.email
                ? '<span class="awa-tag awa-tag-customer">Cliente</span>'
                : '<span class="awa-tag awa-tag-anonymous">Anônimo</span>';
            var ident = v.email
                ? '<strong>' + escH(v.firstname + ' ' + v.lastname) + '</strong><br><small>' + escH(v.email) + '</small>'
                : '<span class="awa-muted">Visitante anônimo</span>';
            tbody.append('<tr>' +
                '<td><span class="awa-badge">#' + v.visitor_id + '</span></td>' +
                '<td>' + type + '</td>' +
                '<td>' + ident + '</td>' +
                '<td>' + escH(v.created_at) + '</td>' +
                '<td>' + escH(v.last_visit_at) + '</td>' +
                '<td><span class="awa-time-ago">' + timeAgo(v.last_visit_at) + '</span></td>' +
            '</tr>');
        });
    }

    function updateProducts(products) {
        var tbody = $('#awa-products-table tbody');
        tbody.empty();
        $.each(products, function(i, p) {
            tbody.append('<tr>' +
                '<td><strong>' + escH(p.product_name || 'Produto #' + p.product_id) + '</strong></td>' +
                '<td><span class="awa-badge">#' + p.product_id + '</span></td>' +
                '<td><span class="awa-time-ago">' + timeAgo(p.added_at) + '</span></td>' +
            '</tr>');
        });
    }

    function updateSearches(searches) {
        var tbody = $('#awa-searches-table tbody');
        tbody.empty();
        $.each(searches, function(i, s) {
            var noResult = parseInt(s.num_results) === 0
                ? ' <span class="awa-tag awa-tag-danger">Sem resultado!</span>' : '';
            var popW = Math.min(parseInt(s.popularity) * 5, 100);
            tbody.append('<tr>' +
                '<td><strong>"' + escH(s.query_text) + '"</strong>' + noResult + '</td>' +
                '<td>' + s.num_results + '</td>' +
                '<td><div class="awa-popularity-bar"><div class="awa-popularity-fill" style="width:' + popW + '%"></div></div><small>' + s.popularity + 'x</small></td>' +
                '<td><span class="awa-time-ago">' + timeAgo(s.updated_at) + '</span></td>' +
            '</tr>');
        });
    }

    function updateTimeline(events) {
        var container = $('#awa-timeline');
        container.empty();
        $.each(events, function(i, e) {
            var label = e.event_name, icon = '&#128196;';
            if (e.event_name.indexOf('view') !== -1) { label = 'Visualizou produto'; icon = '&#128065;'; }
            else if (e.event_name.indexOf('compare') !== -1) { label = 'Comparou produto'; icon = '&#128260;'; }
            else if (e.event_name.indexOf('wishlist') !== -1) { label = 'Adicionou à lista de desejos'; icon = '&#10084;'; }
            var prodHtml = e.product_name ? '<span class="awa-event-product">' + escH(e.product_name) + '</span>' : '';
            container.append(
                '<div class="awa-timeline-item">' +
                    '<div class="awa-timeline-dot"></div>' +
                    '<div class="awa-timeline-content">' +
                        '<div class="awa-timeline-event">' +
                            '<span class="awa-event-icon">' + icon + '</span>' +
                            '<span class="awa-event-label">' + escH(label) + '</span>' +
                            prodHtml +
                        '</div>' +
                        '<div class="awa-timeline-time">' + timeAgo(e.logged_at) + '</div>' +
                    '</div>' +
                '</div>'
            );
        });
    }

    function updateCarts(carts) {
        var container = $('.awa-panel-carts .awa-panel-body');
        container.empty();
        if (!carts.length) {
            container.append('<div class="awa-empty-state">Nenhum carrinho ativo no momento</div>');
            return;
        }
        $.each(carts, function(i, c) {
            var custHtml = c.customer_email
                ? '<span class="awa-cart-customer">' + escH(c.customer_firstname + ' — ' + c.customer_email) + '</span>'
                : '<span class="awa-muted">Anônimo</span>';
            var itemsHtml = '';
            if (c.items && c.items.length) {
                $.each(c.items, function(j, it) {
                    itemsHtml += '<div class="awa-cart-item">' +
                        '<span class="awa-item-name">' + escH(it.name) + '</span>' +
                        '<span class="awa-item-sku">' + escH(it.sku) + '</span>' +
                        '<span class="awa-item-qty">x' + parseInt(it.qty) + '</span>' +
                        '<span class="awa-item-price">R$ ' + parseFloat(it.row_total).toFixed(2).replace('.', ',') + '</span>' +
                    '</div>';
                });
                itemsHtml = '<div class="awa-cart-items">' + itemsHtml + '</div>';
            }
            container.append(
                '<div class="awa-cart-card">' +
                    '<div class="awa-cart-header">' +
                        '<div class="awa-cart-meta">' +
                            '<span class="awa-tag awa-tag-cart">Carrinho #' + c.entity_id + '</span>' +
                            custHtml +
                        '</div>' +
                        '<div class="awa-cart-total">' +
                            '<strong>R$ ' + parseFloat(c.grand_total).toFixed(2).replace('.', ',') + '</strong>' +
                            '<small>' + c.items_count + ' item(s)</small>' +
                        '</div>' +
                    '</div>' +
                    '<div class="awa-cart-details">' +
                        '<div class="awa-cart-ip"><span class="awa-label">IP:</span> ' + escH(c.remote_ip || '—') + '</div>' +
                        '<div class="awa-cart-time"><span class="awa-label">Atualizado:</span> <span class="awa-time-ago">' + timeAgo(c.updated_at) + '</span></div>' +
                    '</div>' +
                    itemsHtml +
                '</div>'
            );
        });
    }

    function updateOrders(orders) {
        var tbody = $('#awa-orders-table tbody');
        if (!tbody.length) return;
        tbody.empty();
        $.each(orders, function(i, o) {
            var statusClass = 'awa-tag-info';
            if (o.status === 'complete') statusClass = 'awa-tag-success';
            else if (o.status === 'processing') statusClass = 'awa-tag-warning';
            else if (o.status === 'canceled') statusClass = 'awa-tag-danger';
            else if (o.status === 'pending') statusClass = 'awa-tag-pending';
            tbody.append('<tr>' +
                '<td><span class="awa-badge">#' + escH(o.increment_id) + '</span></td>' +
                '<td><strong>' + escH((o.customer_firstname || '') + ' ' + (o.customer_lastname || '')) + '</strong><br><small>' + escH(o.customer_email || '') + '</small></td>' +
                '<td><strong>R$ ' + parseFloat(o.grand_total).toFixed(2).replace('.', ',') + '</strong></td>' +
                '<td><span class="awa-tag ' + statusClass + '">' + escH(o.status.charAt(0).toUpperCase() + o.status.slice(1)) + '</span></td>' +
                '<td><small>' + escH(o.remote_ip || '—') + '</small></td>' +
                '<td><span class="awa-time-ago">' + timeAgo(o.created_at) + '</span></td>' +
            '</tr>');
        });
    }

    function escH(str) {
        if (!str) return '';
        var div = document.createElement('div');
        div.appendChild(document.createTextNode(str));
        return div.innerHTML;
    }

    // Auto-refresh
    autoRefreshTimer = setInterval(refreshDashboard, refreshInterval);

    // Manual refresh
    $('#awa-btn-refresh').on('click', function() {
        refreshDashboard();
    });
});
</script>
