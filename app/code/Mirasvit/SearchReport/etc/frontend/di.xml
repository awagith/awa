<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

    <type name="Magento\Search\Api\SearchInterface">
        <plugin name="searchReport" type="Mirasvit\SearchReport\Plugin\SearchPlugin"/>
    </type>

    <type name="Magento\Framework\App\Response\Http">
        <plugin name="searchReport" type="Mirasvit\SearchReport\Plugin\ResponsePlugin"/>
    </type>

    <type name="Mirasvit\GdprCookie\Model\Config\RequiredCookieList">
        <arguments>
            <argument name="cookies" xsi:type="array">
                <item name="searchReport-log" xsi:type="string">searchReport-log</item>
            </argument>
        </arguments>
    </type>
</config>