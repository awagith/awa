<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <type name="Meta\Catalog\Model\Feed\ProductFeedManager">
        <arguments>
            <argument name="logger" xsi:type="object">Meta\BusinessExtension\Logger\VirtualLogger</argument>
        </arguments>
    </type>
    <virtualType name="Meta\BusinessExtension\Logger\VirtualLogger" type="Magento\Framework\Logger\Monolog">
        <arguments>
            <argument name="name" xsi:type="string">meta_fbe</argument>
            <argument name="handlers" xsi:type="array">
                <item name="system" xsi:type="object">Meta\BusinessExtension\Logger\Handler\VirtualHandler</item>
            </argument>
        </arguments>
    </virtualType>
    <virtualType name="Meta\BusinessExtension\Logger\Handler\VirtualHandler" type="Magento\Framework\Logger\Handler\Base">
        <arguments>
            <argument name="fileName" xsi:type="string">/var/log/meta_fbe.log</argument>
        </arguments>
    </virtualType>
</config>
