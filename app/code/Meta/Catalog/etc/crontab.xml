<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Cron:etc/crontab.xsd">
    <group id="default">
        <job name="meta_catalog_product_sync" instance="Meta\Catalog\Cron\ProductSyncCron" method="execute">
            <schedule>0 */4 * * *</schedule>
        </job>
        <job name="meta_catalog_category_sync" instance="Meta\Catalog\Cron\CategorySyncCron" method="execute">
            <schedule>0 2 * * *</schedule>
        </job>
    </group>
</config>
