root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.{yml,yaml,json}]
indent_size = 2

[{composer,auth}.json]
indent_size = 4

[db_schema_whitelist.json]
indent_size = 4
trim_trailing_whitespace = false

# ═══════════════════════════════════════════════════════════════
# XML — Magento layout XML é case-sensitive.
# Não reformatar automaticamente (quebraria referenceBlock etc.)
# ═══════════════════════════════════════════════════════════════
[*.xml]
indent_size = 4
indent_style = space
insert_final_newline = true
