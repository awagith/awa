# Auto detect text files and perform LF normalization
* text=auto eol=lf

# PHP
*.php text eol=lf
*.phtml text eol=lf

# Web
*.html text eol=lf
*.css text eol=lf
*.less text eol=lf
*.js text eol=lf
*.json text eol=lf

# Config
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.sh text eol=lf

# Binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.zip binary
*.tar.gz binary
*.pdf binary
