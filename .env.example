# Exemplo de variáveis de ambiente locais (helper scripts)
# Copie para .env e ajuste conforme necessário.

# scripts/populate_fitment_demo.php
LIMIT=20
MARCAS="Honda:Yamaha:Kawasaki:Suzuki"
MODELOS="CG 160:CB 500:Fazer 250:Ninja 400:GSX S750"
ANOS="2019:2020:2021:2022:2023"

# OpenSearch (opcional) - usado por scripts/opensearch_diagnose.php
OPENSEARCH_HOST=127.0.0.1
OPENSEARCH_PORT=9200
OPENSEARCH_SCHEME=http
OPENSEARCH_PREFIX=
